---
/**
 * BlogCard.astro — Santral design system card for blog listing.
 * Uses santral-hat border, Fraunces display type, patina-copper accents.
 */
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  coverImage: string;
  date: string;
  readTime: string;
  author: string;
  tags: string[];
}

const { slug, title, excerpt, coverImage, date, readTime, author, tags } = Astro.props;
---

<article class="group santral-hat relative overflow-hidden transition-all duration-300 hover:-translate-y-1">
  <a href={`/blog/${slug}/`} class="block">
    <!-- Cover image -->
    <div class="relative w-full overflow-hidden" style="aspect-ratio:16/9;">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
        loading="lazy"
      />
      <!-- Subtle gradient overlay for text legibility -->
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-void-ink)] via-transparent to-transparent opacity-60 pointer-events-none"></div>
    </div>

    <!-- Content -->
    <div class="p-5 md:p-6">
      <!-- Meta: date · readtime · author -->
      <div class="mb-3 flex flex-wrap items-center gap-2">
        <span class="font-mono text-[0.68rem] tracking-[0.16em] uppercase text-[var(--color-paper-ecru-mute)]">{date}</span>
        <span class="text-[var(--color-hairline-strong)]">·</span>
        <span class="font-mono text-[0.68rem] tracking-[0.16em] uppercase text-[var(--color-paper-ecru-mute)]">{readTime}</span>
        <span class="text-[var(--color-hairline-strong)]">·</span>
        <span class="font-mono text-[0.68rem] tracking-[0.16em] uppercase text-[var(--color-paper-ecru-mute)]">{author}</span>
      </div>

      <!-- Title -->
      <h3
        class="santral-display line-clamp-2 leading-[1.1] transition-colors duration-200 group-hover:text-[var(--color-patina-copper-bright)]"
        style="font-size:clamp(1.1rem,1.4vw,1.3rem);font-weight:400;letter-spacing:-0.02em;"
      >
        {title}
      </h3>

      <!-- Excerpt -->
      <p class="mt-3 line-clamp-2 text-[0.875rem] leading-[1.55] text-[var(--color-paper-ecru-dim)]">
        {excerpt}
      </p>

      <!-- Tags + arrow -->
      <div class="mt-5 flex items-end justify-between border-t border-[var(--color-hairline)] pt-4">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.slice(0, 3).map((tag) => (
              <span class="font-mono text-[0.62rem] tracking-[0.12em] uppercase text-[var(--color-patina-copper-bright)] border border-[var(--color-patina-copper-bright)]/30 px-2 py-0.5 rounded-sm">
                {tag}
              </span>
            ))}
          </div>
        )}
        <span class="font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[var(--color-paper-ecru-dim)] transition-colors group-hover:text-[var(--color-patina-copper-bright)] ml-auto">
          Oku →
        </span>
      </div>
    </div>
  </a>
</article>
