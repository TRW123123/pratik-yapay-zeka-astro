---
/**
 * BlogCard.astro — Card component for blog listing page.
 * Matches original Lovable design: dark theme, cover image, tags, metadata.
 */
interface Props {
  slug: string;
  title: string;
  excerpt: string;
  coverImage: string;
  date: string;
  readTime: string;
  author: string;
  tags: string[];
}

const { slug, title, excerpt, coverImage, date, readTime, author, tags } = Astro.props;
---

<article class="group relative">
  <a
    href={`/blog/${slug}/`}
    class="neon-bleed-border block overflow-hidden rounded-2xl bg-[var(--color-surface-light)]/40 backdrop-blur-sm transition-all duration-500 hover:-translate-y-1 hover:bg-[var(--color-surface-light)]/60 relative group"
  >
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-10"></div>
    <div class="relative aspect-[16/9] w-full overflow-hidden">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition duration-700 group-hover:scale-110"
        loading="lazy"
      />
    </div>
    <div class="p-4 md:p-5">
      <div class="mb-2 flex flex-wrap items-center gap-2 text-xs text-[var(--color-text-muted)]">
        <span>{date}</span>
        <span>•</span>
        <span>{readTime}</span>
        <span>•</span>
        <span>{author}</span>
      </div>
      <h3 class="line-clamp-2 text-xl font-bold tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors relative z-20">
        {title}
      </h3>
      <p class="mt-3 line-clamp-3 text-sm text-[var(--color-text-muted)] leading-relaxed relative z-20">
        {excerpt}
      </p>
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2 relative z-20">
          {tags.map((tag) => (
            <span class="rounded-full px-3 py-1 text-xs font-semibold text-[var(--color-primary)] bg-[var(--color-primary)]/10 border border-[var(--color-primary)]/20">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
