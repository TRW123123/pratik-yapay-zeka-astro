---
// FAQExecutive.astro

const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.' },
  { question: 'Veri güvenliği nasıl sağlanır?', answer: 'Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. Tüm altyapımız GDPR uyumlu olarak kurgulanmıştır.' },
  { question: 'Teknik bilgi gerekli mi?', answer: 'Hayır. Tüm süreci biz yönetiyoruz. Sizin sadece hedeflerinizi ve iş süreçlerinizi bizimle paylaşmanız yeterli.' },
];
---

<section id="faq-executive" class="py-32 bg-[#070913] relative overflow-hidden">
  <!-- Subtle Header Border -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="container mx-auto px-4 max-w-4xl relative z-10">
    <div class="text-center mb-20 gs-faq-header">
      <h2 class="text-3xl md:text-5xl font-bold mb-6 text-white tracking-tight">Sıkça Sorulan <span class="bg-gradient-to-r from-[var(--color-primary)] to-[#06B6D4] bg-clip-text text-transparent">Sorular</span></h2>
      <p class="text-[#8e95a3] text-lg font-light">Yapay zeka otomasyon altyapımız hakkında bilmeniz gereken her şey</p>
    </div>

    <div class="space-y-4 gs-faq-stagger">
      {faqItems.map((faq, index) => (
        <details class="group bg-[#0f121d]/90 backdrop-blur-xl border border-white/5 rounded-2xl transition-all duration-300 open:border-[var(--color-primary)]/30 open:shadow-[0_4px_30px_rgba(16,185,129,0.1)] relative overflow-hidden [&_summary::-webkit-details-marker]:hidden">
          
          <!-- Active Glow Border -->
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-[var(--color-primary)] to-[#06B6D4] opacity-0 group-open:opacity-100 transition-opacity duration-300"></div>

          <summary class="flex items-center justify-between p-6 md:p-8 cursor-pointer font-medium text-white/90 hover:text-white transition-colors relative z-10">
            <span class="text-lg">{faq.question}</span>
            <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center border border-white/10 group-open:bg-[var(--color-primary)]/10 group-open:border-[var(--color-primary)]/30 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white/50 group-open:text-[var(--color-primary)] group-open:rotate-45 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
              </svg>
            </div>
          </summary>
          <div class="px-6 md:px-8 pb-8 text-[#8e95a3] text-lg leading-relaxed relative z-10 animate-fade-in-down">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fade-in-down {
    animation: fadeInDown 0.4s ease-out forwards;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initFAQAnimations = () => {
    gsap.fromTo(".gs-faq-header",
      { y: 40, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 1,
        ease: "power3.out",
        scrollTrigger: {
          trigger: "#faq-executive",
          start: "top 80%",
        }
      }
    );

    gsap.fromTo(".gs-faq-stagger details",
      { y: 30, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.8,
        stagger: 0.1,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".gs-faq-stagger",
          start: "top 85%",
        }
      }
    );
  };

  initFAQAnimations();
  document.addEventListener('astro:after-swap', initFAQAnimations);
</script>
