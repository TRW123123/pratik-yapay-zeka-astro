---
import { buildContactHref } from '../lib/contactHref';

const pathname = Astro.url.pathname;
const footerCtaHref = buildContactHref({
  source: pathname,
  packageName: 'operasyon-haritasi',
  area: 'other',
  cta: 'footer-primary',
});
const footerNavContactHref = buildContactHref({
  source: pathname,
  cta: 'footer-nav-contact',
});
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface-light)]">
