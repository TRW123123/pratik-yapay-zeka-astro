---
import { buildContactHref } from '../lib/contactHref';

const pathname = Astro.url.pathname;
const footerCtaHref = buildContactHref({
  source: pathname,
  packageName: 'operasyon-haritasi',
  area: 'other',
  cta: 'footer-primary',
});
const footerNavContactHref = buildContactHref({
  source: pathname,
  cta: 'footer-nav-contact',
});
---

<footer class="relative border-t border-[var(--color-hairline-strong)] bg-[var(--color-void-ink)] mt-24">
  {/* Pre-footer CTA band */}
  <div class="border-b border-[var(--color-hairline)]">
    <div class="container mx-auto max-w-5xl px-6 py-14 lg:px-10 text-center">
      <span class="santral-overline block mb-6">Sonraki Adım · No.09</span>
      <h2 class="santral-display text-3xl leading-[1.1] md:text-5xl" style="font-weight:400;text-wrap:balance;">
        İşletmenizi <em class="santral-italic">dönüştürmeye</em> hazır mısınız?
      </h2>
      <p class="mt-6 santral-body max-w-2xl mx-auto">
        Hangi sürecinizin otomatikleşmeye en uygun olduğunu birlikte çıkaralım — ücretsiz, baskısız, 30 dakika.
      </p>
      <div class="mt-8 flex justify-center">
        <a href={footerCtaHref} class="santral-salter santral-salter-copper">
          Ücretsiz analiz alın
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 py-14 lg:px-6">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-5">
      <div class="space-y-5 lg:col-span-1">
        <a href="/" class="flex items-center gap-3" aria-label="Ana sayfa">
          <div class="flex h-9 w-9 items-center justify-center border border-[var(--color-hairline-strong)] bg-[var(--color-void-ink-deep)]" style="border-radius:2px">
            <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
              <circle cx="12" cy="9" r="2.5" fill="none" stroke="currentColor" stroke-width="1.2" class="text-[var(--color-patina-copper-bright)]"/>
              <path d="M12 11.5 L12 18 M8 18 L16 18" stroke="currentColor" stroke-width="1.2" class="text-[var(--color-patina-copper-bright)]" stroke-linecap="round"/>
              <circle cx="8" cy="7" r="0.8" fill="currentColor" class="text-[var(--color-patina-copper-bright)]"/>
              <circle cx="16" cy="7" r="0.8" fill="currentColor" class="text-[var(--color-patina-copper-bright)]"/>
            </svg>
          </div>
          <span class="font-mono text-[0.72rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-dim)]">Pratik · YZ</span>
        </a>
        <p class="text-sm text-[var(--color-paper-ecru-dim)] leading-relaxed">
          Büyüyen işletmeler için yapay zeka destekli otomasyon sistemleri.
        </p>
        <div class="flex items-center gap-2 pt-2">
          <span class="inline-block h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]" style="animation: morse-pulse 2.6s ease-in-out infinite"></span>
          <span class="font-mono text-[0.65rem] tracking-[0.16em] uppercase text-[var(--color-paper-ecru-mute)]">Hat · Açık</span>
        </div>
      </div>

      <div class="space-y-4 lg:col-span-1">
        <h3 class="santral-overline block">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Ana Sayfa</a></li>
          <li><a href="/cozumler/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Çözümler</a></li>
          <li><a href="/vaka-calismalari/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Vaka Çalışmaları</a></li>
          <li><a href={footerNavContactHref} class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Iletişim</a></li>
          <li><a href="/hakkimizda/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Hakkımızda</a></li>
          <li><a href="/blog/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Blog</a></li>
          <li><a href="/chatgpt/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">ChatGPT Rehberi</a></li>
