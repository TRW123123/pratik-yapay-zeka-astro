          <li><a href="/on-muhasebe-ve-fatura/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Ön Muhasebe Botu</a></li>
          <li><a href="/e-fatura-kesme-programi/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">E-Fatura Otomasyonu</a></li>
          <li><a href="/yapay-zeka-chatbot/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Yapay Zeka Chatbot</a></li>
          <li><a href="/whatsapp-ve-siparis-botlari/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">WhatsApp ve Sipariş Botlari</a></li>
          <li><a href="/b2b-musteri-bulma/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">B2B Müşteri Bulma</a></li>
          <li><a href="/b2b-musteri-takip-ve-plasiyer/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">B2B Takip ve Plasiyer</a></li>
