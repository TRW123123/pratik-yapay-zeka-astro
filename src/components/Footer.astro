<footer class="border-t border-[var(--color-border)] bg-[var(--color-surface-light)]">
  <div class="container mx-auto px-4 py-12 lg:px-6">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Logo + Description -->
      <div class="space-y-4">
        <a href="/" class="flex items-center space-x-2">
          <div class="h-8 w-8 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] flex items-center justify-center">
            <div class="w-4 h-4 bg-[var(--color-primary)] rounded-sm"></div>
          </div>
        </a>
        <p class="text-sm text-[var(--color-text-muted)]">
          Büyüyen işletmeler için yapay zeka destekli otomasyon.
        </p>
      </div>

      <!-- Menu -->
      <div class="space-y-4">
        <h3 class="text-sm font-semibold">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] transition-colors">Ana Sayfa</a></li>
          <li><a href="/cozumler/" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] transition-colors">Çözümler</a></li>
