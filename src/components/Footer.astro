        </ul>
        <div class="flex space-x-3 pt-2">
          <a href="https://www.youtube.com/@yapayzekapratik" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary-light)]" aria-label="YouTube">
