            <div class="h-4 w-4 rounded-sm bg-[var(--color-primary)]"></div>
          </div>
        </a>
        <p class="text-sm text-[var(--color-text-muted)]">
          Buyuyen isletmeler icin yapay zeka destekli otomasyon sistemleri.
        </p>
      </div>

      <div class="space-y-4 lg:col-span-1">
        <h3 class="text-sm font-semibold">Menu</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Ana Sayfa</a></li>
          <li><a href="/cozumler/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Cozumler</a></li>
