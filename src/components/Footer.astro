        <ul class="space-y-2 text-sm">
          <li><a href="/cozumler/" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] transition-colors">Tüm Çözümler</a></li>
          <li><a href="/cozumler/e-ticaret/musteri-iliskileri/" class="text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] transition-colors">E-Ticaret Otomasyonu</a></li>
