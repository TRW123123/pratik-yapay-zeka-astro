          <li><a href="/gecikme-zammi-hesaplama/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Gecikme Zammı</a></li>
          <li><a href="/vergi-iadesi-hesaplama/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Vergi Iadesi</a></li>
          <li><a href="/arac-deger-kaybi-hesaplama/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Araç Değer Kaybı</a></li>
          <li><a href="/kdv-hesaplama/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">KDV Hesaplama</a></li>
          <li><a href="/brutten-nete/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Brütten Nete</a></li>
          <li><a href="/e-arsiv-portali/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">E-Arsiv Portali</a></li>
          <li><a href="/defter-beyan/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Defter Beyan</a></li>
          <li><a href="/e-beyanname/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">E-Beyanname</a></li>
          <li><a href="/sgk-hizmet-dokumu/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">SGK Hizmet Dökümü</a></li>
          <li><a href="/ticaret-sicil-gazetesi/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Ticaret Sicil Gazetesi</a></li>
          <li><a href="/acik-fatura-kapali-fatura/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Açık ve Kapalı Fatura</a></li>
          <li><a href="/cari-hesap-ekstresi/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Cari Hesap Ekstresi</a></li>
          <li><a href="/mutabakat-mektubu/" class="transition-colors hover:text-[var(--color-primary-light)] text-[var(--color-text-muted)]">Mutabakat Mektubu</a></li>
        </ul>
      </div>

      <div class="space-y-4 lg:col-span-1">
