---
/**
 * Hero.astro — 1:1 faithful port of lovable-original Hero.tsx
 * Exact same copy, exact same layout. No creative changes.
 */
---

<section class="hero-section relative min-h-screen flex items-center justify-center" aria-label="Hero section">
  <!-- World-Class Background Effects -->
  <div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none mix-blend-screen" aria-hidden="true">
    <div class="w-[60vw] h-[400px] bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] blur-[140px] rounded-full"></div>
  </div>
  <div class="absolute inset-0 bg-grid-pattern opacity-20" aria-hidden="true"></div>
  
  <!-- Content -->
  <div class="relative z-10 container mx-auto px-6 text-center">
    <div class="max-w-5xl mx-auto space-y-8">
      <!-- Main Headlines -->
      <div class="space-y-4">
        <h1 class="headline text-5xl md:text-7xl lg:text-[5rem] text-white">
          <span class="block mb-4">Siz şirketi yönetin.</span>
          <span class="block text-[var(--color-primary)] pb-2 relative inline-block hero-underline">
            Biz sizin için 7/24 çalışan yapay zeka işçileri kuruyoruz.
          </span>
        </h1>
      </div>
      
      <div class="pt-12">
        <a
          href="/cozumler/"
          class="magnetic-glow-btn inline-flex items-center justify-center px-14 py-5 text-lg rounded-xl min-h-[60px]"
        >
          Şimdi ücretsiz başlayın
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-underline {
    position: relative;
  }
  .hero-underline::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-section:hover .hero-underline::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
