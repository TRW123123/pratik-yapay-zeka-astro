---
import { buildContactHref } from '../lib/contactHref';

const primaryCtaHref = buildContactHref({
  source: '/',
  packageName: 'operasyon-haritasi',
  area: 'other',
  cta: 'home-hero-primary',
});
---

<section data-santral-reveal class="hero-section relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24" aria-label="Hero section">
  {/* Ambient copper glow, top-right */}
  <div class="pointer-events-none absolute -top-32 right-[-10%] h-[520px] w-[620px] rounded-full opacity-[0.16] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>

  <div class="container relative z-10 mx-auto max-w-6xl px-6 lg:px-10">
    <div class="flex flex-col gap-12 md:flex-row md:items-start md:gap-16">
      {/* Left: Aside — mark + ana santral label */}
      <aside class="md:w-[260px] md:shrink-0 md:pt-3">
        <span class="santral-overline block">Ana Santral · No.07</span>
        <div class="mt-4 flex items-center gap-3" aria-hidden="true">
          <span class="h-[1px] w-12 bg-[var(--color-patina-copper-bright)]"></span>
          <span class="h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]" style="animation: morse-pulse 2.4s ease-in-out infinite"></span>
          <span class="h-[1px] flex-1 bg-[var(--color-hairline-strong)]"></span>
        </div>
        <p class="mt-5 font-mono text-[0.72rem] leading-relaxed tracking-[0.14em] uppercase text-[var(--color-paper-ecru-mute)]">
          TX · 2.4ms<br/>
          HAT · AÇIK<br/>
          YÜK · Normal
        </p>
      </aside>

      {/* Right: Content */}
      <div class="flex-1 max-w-3xl">
        <h1 class="santral-display text-4xl leading-[1.05] md:text-6xl lg:text-[4.25rem]" style="font-weight:400;text-wrap:balance;">
          Siz şirketi yönetin.
          <br/>
          <em class="santral-italic">Biz</em> sizin için 7/24 çalışan yapay zeka işçileri kuruyoruz.
        </h1>
        <p class="mt-8 santral-body text-lg md:text-xl max-w-2xl">
          Satış, CRM, pazarlama, muhasebe ve operasyon tarafında tekrar eden işleri sistemleştirip ekibinizin zamanını geri kazandırıyoruz.
        </p>

        <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
          <a href={primaryCtaHref} class="santral-salter santral-salter-copper">
            Ücretsiz analiz başlatın
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
            </svg>
          </a>
          <a href="/cozumler/" class="santral-salter">
            Çözümleri inceleyin
          </a>
        </div>

        <p class="mt-8 max-w-2xl text-sm leading-relaxed text-[var(--color-paper-ecru-mute)]">
          Hemen görüşme istemiyorsanız önce
          <a href="/ucretsiz-otomasyon-checklistesi/?kaynak=%2F" class="border-b border-[var(--color-patina-copper-bright)] text-[var(--color-patina-copper-bright)] transition hover:text-[var(--color-paper-ecru)]">
            ücretsiz otomasyon öncelik checklistini
          </a>
          isteyebilirsiniz.
        </p>

        {/* Trust strip */}
        <div class="mt-14 border-t border-[var(--color-hairline)] pt-6">
          <span class="santral-label block mb-3">KAYITLI MÜŞTERİLER · 001 — 006</span>
          <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[0.8rem] font-mono tracking-[0.08em] text-[var(--color-paper-ecru-dim)]">
            <span>Acilsatis</span>
            <span class="text-[var(--color-paper-ecru-mute)]">·</span>
            <span>Salevium</span>
            <span class="text-[var(--color-paper-ecru-mute)]">·</span>
            <span>ERPA Teknoloji</span>
            <span class="text-[var(--color-paper-ecru-mute)]">·</span>
            <span>Cemkimsan</span>
            <span class="text-[var(--color-paper-ecru-mute)]">·</span>
            <span>Car Studio AI</span>
            <span class="text-[var(--color-paper-ecru-mute)]">·</span>
            <span>Coach Bilge</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
