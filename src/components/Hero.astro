---
import { buildContactHref } from '../lib/contactHref';

const primaryCtaHref = buildContactHref({
  source: '/',
  packageName: 'operasyon-haritasi',
  area: 'other',
  cta: 'home-hero-primary',
});
---

<section class="hero-section relative flex min-h-screen items-center justify-center" aria-label="Hero section">
  <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-10 mix-blend-screen" aria-hidden="true">
    <div class="h-[400px] w-[60vw] rounded-full bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] blur-[140px]"></div>
  </div>
  <div class="absolute inset-0 bg-grid-pattern opacity-20" aria-hidden="true"></div>

  <div class="container relative z-10 mx-auto px-6 text-center">
    <div class="mx-auto max-w-5xl space-y-8">
      <div class="space-y-4">
        <h1 class="headline text-5xl text-white md:text-7xl lg:text-[5rem]">
          <span class="mb-4 block">Siz şirketi yönetin.</span>
          <span class="hero-underline relative inline-block pb-2 text-[var(--color-primary)]">
            Biz sizin için 7/24 çalışan yapay zeka işçileri kuruyoruz.
          </span>
        </h1>
        <p class="mx-auto max-w-3xl text-lg leading-relaxed text-[var(--color-text-muted)] md:text-xl">
          Satış, CRM, pazarlama, muhasebe ve operasyon tarafinda tekrar eden isleri sistemlestirip ekibinizin zamanini geri kazandiriyoruz.
        </p>
      </div>

      <div class="flex flex-col items-center justify-center gap-4 pt-8 sm:flex-row">
        <a
          href={primaryCtaHref}
          class="magnetic-glow-btn inline-flex min-h-[60px] items-center justify-center rounded-xl px-14 py-5 text-lg"
        >
          Ücretsiz analizi baslatin
        </a>
        <a
          href="/cozumler/"
          class="inline-flex min-h-[60px] items-center justify-center rounded-xl border border-[var(--color-border)] px-10 py-5 text-lg font-semibold text-[var(--color-text)] transition hover:border-[var(--color-primary)]/40 hover:text-[var(--color-primary-light)]"
        >
          Çözümleri inceleyin
        </a>
      </div>

      <p class="mx-auto max-w-2xl text-sm leading-relaxed text-[var(--color-text-muted)]">
        Hemen görüşme istemiyorsaniz önce
        <a href="/ucretsiz-otomasyon-checklistesi/?kaynak=%2F" class="font-semibold text-[var(--color-primary-light)] transition hover:text-[var(--color-primary)]">
          ücretsiz otomasyon öncelik checklistini
        </a>
        isteyebilirsiniz.
      </p>
    </div>
  </div>
</section>

<style>
  .hero-underline {
    position: relative;
  }
  .hero-underline::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 3px;
    background: linear-gradient(to right, var(--color-primary), var(--color-accent));
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hero-section:hover .hero-underline::after {
    transform: scaleX(1);
    transform-origin: left;
  }
</style>
