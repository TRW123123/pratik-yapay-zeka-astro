---
// src/components/HeroExecutive.astro
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-32 pb-24" id="hero-section">
  <!-- Executive High-Tech Background -->
  <div class="absolute inset-0 -z-10 bg-[#070913]">
    <!-- Tech Grid Substrate -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none"></div>
    
    <!-- Subtle Glows (Cyan & Deep Purple) -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60vw] h-[40vw] max-w-[800px] max-h-[500px] bg-gradient-to-b from-[#06B6D4]/10 to-transparent blur-[100px] rounded-full pointer-events-none"></div>
    <div class="absolute top-1/4 right-0 w-[40vw] h-[40vw] max-w-[600px] max-h-[600px] bg-gradient-to-bl from-[var(--color-primary)]/5 to-transparent blur-[120px] rounded-full pointer-events-none"></div>
    
    <!-- Noise Texture for Premium Tactile Feel -->
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  </div>

  <div class="container mx-auto px-4 max-w-6xl relative z-10 hero-content">
    
    <!-- Main Content -->
    <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
      
      <!-- Masked Headline for GSAP Reveal -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[1.10] tracking-tight mb-12">
        <div class="overflow-hidden pb-1">
          <div class="hero-heading-line text-white">Siz şirketi yönetin.</div>
        </div>
        <div class="overflow-hidden pb-1">
          <div class="hero-heading-line text-[var(--color-primary)] mt-2">
            Biz sizin için 7/24 çalışan
          </div>
        </div>
        <div class="overflow-hidden pb-4">
          <div class="hero-heading-line text-[var(--color-primary)]">
            yapay zeka işçileri kuruyoruz.
          </div>
        </div>
      </h1>


      <!-- The 'Liquid Metal' Executive Button Area -->
      <div class="hero-item flex flex-col sm:flex-row gap-6 items-center justify-center w-full mt-4">
        
        <!-- Primary CTA: Solid Lime Green Button -->
        <a href="/cozumler/" class="relative inline-flex items-center justify-center group overflow-hidden rounded-full">
          <!-- Button Core -->
          <div class="relative flex items-center gap-3 px-8 py-4 bg-[var(--color-primary)] text-[#0a0d14] font-bold rounded-full transition-all duration-300 group-hover:bg-[#10b981] group-hover:-translate-y-1 shadow-[0_4px_20px_rgba(163,230,53,0.3)]">
            <span class="text-lg tracking-wide z-10">Şimdi ücretsiz başlayın</span>
            <svg class="w-5 h-5 text-[#0a0d14] z-10 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>

      </div>

    </div>
  </div>
</section>

<style>
  /* Liquid Metal Button CSS */
  .mask-circular {
    -webkit-mask-image: radial-gradient(white, black);
    mask-image: radial-gradient(white, black);
  }
  
  .btn-border-mask {
    border: 1px solid transparent;
    background: linear-gradient(#0a0d14, #0a0d14) padding-box, 
                linear-gradient(to right, rgba(255,255,255,0.4), rgba(255,255,255,0.05)) border-box;
  }

  .animate-spin-slow {
    animation: spin 3s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Executive Entrance Animation (Cinematic & Smooth)
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Initial states
    gsap.set('.hero-heading-line', { yPercent: 120 });
    gsap.set('.hero-item', { y: 20, opacity: 0 });
    gsap.set('.glass-card', { y: 40, opacity: 0, scale: 0.98 });
    gsap.set('.gs-progress-bar', { scaleX: 0, transformOrigin: "left center" });

    // Staggered text mask reveal - Slow and authoritative
    tl.to('.hero-heading-line', {
      yPercent: 0,
      duration: 1.2,
      stagger: 0.15,
    }, 0.2);

    // Fade in text and buttons
    tl.to('.hero-item', {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.1,
    }, 0.6);

    // Float in metrics cards
    tl.to('.glass-card', {
      y: 0,
      opacity: 1,
      scale: 1,
      duration: 1.2,
      stagger: 0.2,
    }, 1.0);

    // Animate the progress bar inside the card to simulate data loading
    tl.to('.gs-progress-bar', {
      scaleX: 1,
      duration: 1.5,
      ease: 'power4.out'
    }, 1.6);

    // 2. 3D Mouse Parallax Effect (Very Subtle for Corporate Feel)
    const heroSection = document.getElementById('hero-section');
    const parallaxElements = document.querySelectorAll('.parallax-element');

    if (heroSection && parallaxElements.length > 0) {
      heroSection.addEventListener('mousemove', (e) => {
        const { clientX, clientY } = e;
        const centerX = window.innerWidth / 2;
        const centerY = window.innerHeight / 2;
        
        const moveX = (clientX - centerX) / centerX;
        const moveY = (clientY - centerY) / centerY;

        parallaxElements.forEach((el) => {
          const speed = parseFloat(el.getAttribute('data-speed') || '0');
          gsap.to(el, {
            x: moveX * 60 * speed,
            y: moveY * 60 * speed,
            rotationY: moveX * 5 * speed,
            rotationX: -moveY * 5 * speed,
            duration: 1.5,
            ease: 'power2.out'
          });
        });
      });
      
      heroSection.addEventListener('mouseleave', () => {
        gsap.to(parallaxElements, {
          x: 0,
          y: 0,
          rotationY: 0,
          rotationX: 0,
          duration: 2,
          ease: 'power3.out'
        });
      });
    }
  });
</script>
