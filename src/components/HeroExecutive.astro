---
// src/components/HeroExecutive.astro
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-32 pb-24" id="hero-section">
  <!-- Executive High-Tech Background -->
  <div class="absolute inset-0 -z-10 bg-[#070913]">
    <!-- Tech Grid Substrate -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_0%,#000_70%,transparent_100%)] pointer-events-none"></div>
    
    <!-- Subtle Glows (Cyan & Deep Purple) -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[60vw] h-[40vw] max-w-[800px] max-h-[500px] bg-gradient-to-b from-[#06B6D4]/10 to-transparent blur-[100px] rounded-full pointer-events-none"></div>
    <div class="absolute top-1/4 right-0 w-[40vw] h-[40vw] max-w-[600px] max-h-[600px] bg-gradient-to-bl from-[#8B5CF6]/5 to-transparent blur-[120px] rounded-full pointer-events-none"></div>
    
    <!-- Noise Texture for Premium Tactile Feel -->
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  </div>

  <div class="container mx-auto px-4 max-w-6xl relative z-10 hero-content">
    
    <!-- Enterprise Metric Card (Parallax) -->
    <div class="glass-card hidden lg:flex absolute -left-4 top-24 w-56 rounded-xl border border-white/10 bg-[#0f121df0] backdrop-blur-xl flex-col p-5 shadow-2xl skew-x-[-1deg] skew-y-[2deg] parallax-element" data-speed="0.04">
      <div class="flex justify-between items-center mb-4">
        <div class="text-xs text-white/50 font-medium uppercase tracking-wider">Maliyet Optimizasyonu</div>
        <div class="w-2 h-2 rounded-full bg-[#06B6D4] animate-pulse"></div>
      </div>
      <div class="flex items-baseline gap-2 mb-2">
        <div class="text-4xl font-bold tracking-tight text-white">-40%</div>
      </div>
      <div class="w-full h-1.5 bg-white/5 rounded-full overflow-hidden">
        <div class="w-[60%] h-full bg-gradient-to-r from-[#8B5CF6] to-[#06B6D4] gs-progress-bar"></div>
      </div>
      <div class="mt-3 text-[10px] text-white/40 font-mono">OPERASYONEL GİDERLER</div>
    </div>

    <!-- Secondary Metric Card -->
    <div class="glass-card hidden lg:flex absolute -right-8 bottom-16 w-48 rounded-xl border border-white/10 bg-[#0f121df0] backdrop-blur-xl flex-col p-5 shadow-2xl skew-x-[1deg] skew-y-[-2deg] parallax-element" data-speed="-0.03">
      <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center mb-4">
        <svg class="w-4 h-4 text-[#8B5CF6]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
      </div>
      <div class="text-2xl font-bold text-white mb-1">+300%</div>
      <div class="text-xs text-white/50">Satış Pipeline Kapasitesi</div>
    </div>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto text-center flex flex-col items-center">
      
      <!-- Premium Badge -->
      <div class="hero-item inline-flex items-center gap-2 px-4 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-md mb-10 shadow-inner">
        <div class="flex -space-x-2">
           <div class="w-5 h-5 rounded-full bg-white/20 border border-[#0f121d]"></div>
           <div class="w-5 h-5 rounded-full bg-white/30 border border-[#0f121d]"></div>
           <div class="w-5 h-5 rounded-full bg-[#06B6D4]/80 border border-[#0f121d]"></div>
        </div>
        <span class="text-xs font-semibold tracking-wide text-white/80 uppercase">100+ B2B ekip için pratik otomasyon kurguladık</span>
      </div>

      <!-- Masked Headline for GSAP Reveal -->
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.15] tracking-tight mb-8">
        <div class="overflow-hidden pb-2">
          <div class="hero-heading-line text-white">Siz şirketi yönetin.</div>
        </div>
        <div class="overflow-hidden pb-4">
          <div class="hero-heading-line bg-gradient-to-r from-white via-white to-[#a1a1aa] bg-clip-text text-transparent">
            Biz <span class="bg-gradient-to-r from-[#8B5CF6] to-[#06B6D4] bg-clip-text text-transparent">Yapay Zekayı</span> kurarız.
          </div>
        </div>
      </h1>

      <p class="hero-item text-lg md:text-2xl text-[#a1a1aa] max-w-2xl mb-12 font-light leading-relaxed">
        Yapay Zeka + Otomasyon ile Şirketinizi Daha da Büyütün – Fazladan Çaba Harcamadan.
      </p>

      <!-- The 'Liquid Metal' Executive Button Area -->
      <div class="hero-item flex flex-col sm:flex-row gap-6 items-center justify-center w-full mt-4">
        
        <!-- Primary CTA: Liquid Metal Border Effect -->
        <a href="/cozumler/" class="liquid-btn group relative inline-flex items-center justify-center">
          <!-- Button Ambient Glow -->
          <div class="absolute -inset-[2px] rounded-full bg-gradient-to-r from-[#06B6D4] to-[#8B5CF6] opacity-30 blur-md transition-opacity duration-500 group-hover:opacity-100"></div>
          
          <div class="absolute -inset-[1px] rounded-full bg-gradient-to-r from-white/20 to-white/0 btn-border-mask"></div>
          
          <!-- Liquid Border Spin -->
          <div class="absolute -inset-[1px] rounded-full overflow-hidden mask-circular">
             <div class="absolute inset-[-50%] bg-[conic-gradient(from_0deg,transparent_0_340deg,white_360deg)] animate-spin-slow mix-blend-screen opacity-60"></div>
          </div>

          <!-- Solid Button Core -->
          <div class="relative flex items-center gap-3 px-8 py-4 bg-[#0a0d14] border border-white/10 rounded-full backdrop-blur-xl shadow-[inset_0_1px_1px_rgba(255,255,255,0.15)] transition-colors duration-300 group-hover:bg-[#111622]">
            <span class="text-white font-medium text-lg tracking-wide z-10">Şimdi ücretsiz başlayın</span>
            <svg class="w-5 h-5 text-white z-10 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>

        <!-- Secondary CTA: Minimalist Underline -->
        <a href="#features" class="text-white/60 hover:text-white font-medium text-lg px-6 py-4 transition-all duration-300 border-b-2 border-transparent hover:border-white/20">
          Çözümlerimizi İncele
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Liquid Metal Button CSS */
  .mask-circular {
    -webkit-mask-image: radial-gradient(white, black);
    mask-image: radial-gradient(white, black);
  }
  
  .btn-border-mask {
    border: 1px solid transparent;
    background: linear-gradient(#0a0d14, #0a0d14) padding-box, 
                linear-gradient(to right, rgba(255,255,255,0.4), rgba(255,255,255,0.05)) border-box;
  }

  .animate-spin-slow {
    animation: spin 3s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Executive Entrance Animation (Cinematic & Smooth)
    const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

    // Initial states
    gsap.set('.hero-heading-line', { yPercent: 120 });
    gsap.set('.hero-item', { y: 20, opacity: 0 });
    gsap.set('.glass-card', { y: 40, opacity: 0, scale: 0.98 });
    gsap.set('.gs-progress-bar', { scaleX: 0, transformOrigin: "left center" });

    // Staggered text mask reveal - Slow and authoritative
    tl.to('.hero-heading-line', {
      yPercent: 0,
      duration: 1.2,
      stagger: 0.15,
    }, 0.2);

    // Fade in text and buttons
    tl.to('.hero-item', {
      y: 0,
      opacity: 1,
      duration: 1,
      stagger: 0.1,
    }, 0.6);

    // Float in metrics cards
    tl.to('.glass-card', {
      y: 0,
      opacity: 1,
      scale: 1,
      duration: 1.2,
      stagger: 0.2,
    }, 1.0);

    // Animate the progress bar inside the card to simulate data loading
    tl.to('.gs-progress-bar', {
      scaleX: 1,
      duration: 1.5,
      ease: 'power4.out'
    }, 1.6);

    // 2. 3D Mouse Parallax Effect (Very Subtle for Corporate Feel)
    const heroSection = document.getElementById('hero-section');
    const parallaxElements = document.querySelectorAll('.parallax-element');

    if (heroSection && parallaxElements.length > 0) {
      heroSection.addEventListener('mousemove', (e) => {
        const { clientX, clientY } = e;
        const centerX = window.innerWidth / 2;
        const centerY = window.innerHeight / 2;
        
        const moveX = (clientX - centerX) / centerX;
        const moveY = (clientY - centerY) / centerY;

        parallaxElements.forEach((el) => {
          const speed = parseFloat(el.getAttribute('data-speed') || '0');
          gsap.to(el, {
            x: moveX * 60 * speed,
            y: moveY * 60 * speed,
            rotationY: moveX * 5 * speed,
            rotationX: -moveY * 5 * speed,
            duration: 1.5,
            ease: 'power2.out'
          });
        });
      });
      
      heroSection.addEventListener('mouseleave', () => {
        gsap.to(parallaxElements, {
          x: 0,
          y: 0,
          rotationY: 0,
          rotationX: 0,
          duration: 2,
          ease: 'power3.out'
        });
      });
    }
  });
</script>
