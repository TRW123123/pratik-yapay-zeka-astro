---
const cases = [
  {
    company: 'Acilsatis',
    sector: 'E-Ticaret',
    slug: 'acilsatis',
    logo: '/logos/acilsatis.png',
    result: 'Hızlı bilinirlik ve daha istikrarlı trafik.',
    metric: '+%45 görünürlük',
  },
  {
    company: 'Car Studio AI',
    sector: 'Otomotiv',
    slug: 'car-studio-ai',
    logo: '/logos/car-studio-ai.png',
    result: 'Ekip büyütmeden yeni pazarlara açılma.',
    metric: '3x pazar genişlemesi',
  },
  {
    company: 'Salevium',
    sector: 'B2B SaaS',
    slug: 'salevium',
    logo: '/logos/salevium.png',
    result: 'İçerik üretimi saatlerden dakikalara indi.',
    metric: '%90 zaman tasarrufu',
  },
  {
    company: 'ERPA Teknoloji',
    sector: 'Yazılım · DE',
    slug: 'erpa-teknoloji',
    logo: '/logos/erpa-teknoloji.png',
    result: 'Yapay zeka destekli stratejik Avrupa pazarı girişi.',
    metric: 'İlk ayda meeting',
  },
  {
    company: 'Cemkimsan',
    sector: 'Kimya · İhracat',
    slug: 'cemkimsan',
    logo: '/logos/cemkimsan.png',
    result: '20+ ülkede satış ve pazarlama kampanyaları.',
    metric: '6 yeni fırsat',
  },
  {
    company: 'DKM Coach Bilge',
    sector: 'Koçluk · Eğitim',
    slug: 'dkm-coach-bilge',
    logo: '/logos/dkm-coach-bilge.png',
    result: 'Oyun formatında lead funnel ile yüzlerce ek lead.',
    metric: '+300 lead',
  },
];
---

<section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
  <div class="container mx-auto max-w-6xl px-6 lg:px-10">
    <div class="mb-12 flex items-center gap-4">
      <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
      <span class="santral-overline">Kayıtlar · 05 — 6 Vaka</span>
    </div>
    <div class="mb-14 max-w-3xl">
      <h2 class="santral-display text-3xl leading-[1.1] md:text-5xl" style="font-weight:400;text-wrap:balance;">
        Başarı <em class="santral-italic">Hikayeleri</em>
      </h2>
      <p class="mt-6 santral-body text-lg">
        <a href="/vaka-calismalari/" class="border-b border-[var(--color-patina-copper-bright)] text-[var(--color-patina-copper-bright)] transition hover:text-[var(--color-paper-ecru)]">Detaylı vaka çalışmalarımızı</a> inceleyin ve benzer süreçlerin nasıl dönüştüğünü görün.
      </p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {cases.map((item, i) => (
        <a href={`/vaka-calismalari/${item.slug}/`} class="santral-hat group relative block overflow-hidden p-7 lg:p-8">
          <div class="flex items-start justify-between">
            <span class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">
              Kayıt · {String(i + 1).padStart(3, '0')}
            </span>
            <span class="font-mono text-[0.68rem] tracking-[0.14em] text-[var(--color-paper-ecru-mute)]">
              {item.sector}
            </span>
          </div>
          <div class="mt-7 flex items-center gap-4">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center border border-[var(--color-hairline-strong)] bg-[var(--color-void-ink-deep)]" style="border-radius:2px">
              <img src={item.logo} alt={`${item.company} Logo`} width="32" height="32" loading="lazy" decoding="async" class="max-h-[28px] max-w-[28px] object-contain opacity-80 transition group-hover:opacity-100" />
            </div>
            <h3 class="santral-display text-xl md:text-[1.35rem] transition-colors group-hover:text-[var(--color-patina-copper-bright)]" style="font-weight:500;letter-spacing:-0.01em">
              {item.company}
            </h3>
          </div>
          <p class="mt-5 text-[0.9rem] leading-[1.55] text-[var(--color-paper-ecru-dim)]">{item.result}</p>
          <div class="mt-7 flex items-end justify-between border-t border-[var(--color-hairline)] pt-4">
            <div>
              <span class="santral-label block">Sonuç</span>
              <span class="mt-1 font-mono text-sm text-[var(--color-patina-copper-bright)]">{item.metric}</span>
            </div>
            <span class="font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[var(--color-paper-ecru-dim)] transition-colors group-hover:text-[var(--color-patina-copper-bright)]">
              Detay →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
