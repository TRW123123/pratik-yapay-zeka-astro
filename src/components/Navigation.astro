---
const pathname = Astro.url.pathname;
import { buildContactHref } from '../lib/contactHref';

const navItems = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/cozumler/', label: 'Cozumler' },
  { href: '/vaka-calismalari/', label: 'Vaka Calismalari' },
  { href: '/blog/', label: 'Blog' },
  { href: buildContactHref({ source: pathname, cta: 'nav-primary-contact' }), label: 'Iletisim' },
];

const solutionItems = [
  { href: '/crm-programi/', label: 'CRM ve Musteri Takibi' },
  { href: '/marketing-otomasyonu/', label: 'Lead ve Marketing Otomasyonu' },
  { href: '/whatsapp-ve-siparis-botlari/', label: 'WhatsApp ve Siparis Akisi' },
  { href: '/on-muhasebe-ve-fatura/', label: 'On Muhasebe ve Fatura' },
  { href: '/teklif-hazirlama-programi/', label: 'Teklif ve Onay Akisi' },
  { href: '/b2b-musteri-bulma/', label: 'B2B Arastirma ve Outreach' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="sticky top-0 z-50 w-full border-b border-[var(--color-border)]/30 bg-[var(--color-surface)]/40 shadow-[0_1px_20px_rgba(163,230,53,0.03)] backdrop-blur-xl" aria-label="Main navigation">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="flex h-16 items-center justify-between">
      <a href="/" class="group flex items-center space-x-3" aria-label="Homepage">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-white/5 bg-[var(--color-surface-light)] shadow-[0_0_15px_rgba(163,230,53,0)] transition-all duration-300 group-hover:border-[var(--color-primary)]/40 group-hover:shadow-[0_0_15px_rgba(163,230,53,0.15)]">
          <div class="h-4 w-4 rounded-sm bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)]"></div>
        </div>
      </a>

      <div class="hidden md:flex md:items-center md:space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'relative text-sm font-medium transition-colors',
              isActive(item.href) ? 'text-[var(--color-primary-light)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary-light)]',
            ]}
          >
            {item.label}
          </a>
        ))}

        <div class="group relative">
          <button
            id="solutions-dropdown-btn"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="solutions-dropdown-panel"
            class:list={[
              'inline-flex items-center gap-1 text-sm font-medium transition-colors',
              pathname.includes('/cozumler') ? 'text-[var(--color-primary-light)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary-light)]',
            ]}
          >
            Kisa Yollar
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>

          <div id="solutions-dropdown-panel" role="menu" class="invisible absolute left-0 top-full z-[60] mt-2 w-72 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-light)] opacity-0 shadow-xl transition-all duration-200 group-hover:visible group-hover:opacity-100">
            <div class="py-2">
              {solutionItems.map((item) => (
                <a href={item.href} role="menuitem" class="block px-4 py-2.5 text-sm text-[var(--color-text-muted)] transition-colors hover:bg-[var(--color-surface)]/50 hover:text-[var(--color-primary-light)]">
                  {item.label}
                </a>
              ))}
              <div class="mt-1 border-t border-[var(--color-border)] pt-1">
                <a href="/cozumler/" class="block px-4 py-2.5 text-sm font-semibold text-[var(--color-text)] transition-colors hover:text-[var(--color-primary-light)]">
                  Tum Cozumler ->
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <button id="mobile-menu-btn" class="p-2 text-[var(--color-text)] md:hidden" aria-label="Menuyu ac veya kapat" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-[var(--color-border)] bg-[var(--color-surface-light)] md:hidden">
    <div class="container mx-auto space-y-2 px-4 py-4">
      {navItems.map((item) => (
        <a href={item.href} class:list={['block rounded-md px-3 py-2 text-sm transition-colors', isActive(item.href) ? 'bg-[var(--color-border)]/30 text-[var(--color-primary-light)]' : 'text-[var(--color-text)] hover:bg-[var(--color-border)]/30']}>
          {item.label}
        </a>
      ))}
      <div class="mt-2 border-t border-[var(--color-border)] pt-2">
        <span class="px-3 text-xs uppercase tracking-wider text-[var(--color-text-muted)]">Kisa Yollar</span>
        {solutionItems.map((item) => (
          <a href={item.href} class="block rounded-md px-3 py-2 text-sm text-[var(--color-text)] transition-colors hover:bg-[var(--color-border)]/30">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    btn?.setAttribute('aria-expanded', String(!isHidden));
  });

  const dropBtn = document.getElementById('solutions-dropdown-btn');
  const dropPanel = document.getElementById('solutions-dropdown-panel');

  function openDropdown() {
    dropPanel?.classList.remove('invisible', 'opacity-0');
    dropPanel?.classList.add('visible', 'opacity-100');
    dropBtn?.setAttribute('aria-expanded', 'true');
  }

  function closeDropdown() {
    dropPanel?.classList.add('invisible', 'opacity-0');
    dropPanel?.classList.remove('visible', 'opacity-100');
    dropBtn?.setAttribute('aria-expanded', 'false');
  }

  dropBtn?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      const isExpanded = dropBtn.getAttribute('aria-expanded') === 'true';
      isExpanded ? closeDropdown() : openDropdown();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!dropBtn?.contains(e.target as Node) && !dropPanel?.contains(e.target as Node)) {
      closeDropdown();
    }
  });
</script>
