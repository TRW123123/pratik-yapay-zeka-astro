---
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: 'Ana Sayfa' },
  { href: '/vaka-calismalari/', label: 'Vaka Çalışmaları' },
  { href: '/blog/', label: 'Blog' },
];

const solutionItems = [
  { href: '/cozumler/lead-generation/', label: 'Yapay Zeka Lead Üretimi' },
  { href: '/cozumler/pazarlama-otomasyonu/', label: 'Pazarlama Otomasyonu' },
  { href: '/cozumler/satis-otomasyonu/', label: 'Satış Otomasyonu' },
  { href: '/cozumler/crm-otomasyonu/', label: 'CRM Otomasyonu' },
  { href: '/cozumler/musteri-hizmeti-otomasyonu/', label: 'Müşteri Hizmeti Otomasyonu' },
  { href: '/yapay-zeka-otomasyonu/', label: 'Yapay Zeka Otomasyonu' },
  { href: '/cozumler/almanya-ihracat/', label: '🇩🇪 Almanya\'ya İhracat' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="sticky top-0 z-50 w-full border-b border-[var(--color-border)]/50 bg-[var(--color-surface)]/80 backdrop-blur-md" aria-label="Main navigation">
  <div class="container mx-auto px-4 lg:px-6">
    <div class="flex h-16 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex items-center space-x-3 group" aria-label="Homepage">
        <div class="h-8 w-8 rounded-lg bg-[var(--color-surface-light)] border border-[var(--color-border)] group-hover:border-[var(--color-primary)]/50 transition-all duration-300 flex items-center justify-center">
          <div class="w-4 h-4 bg-[var(--color-primary)] rounded-sm"></div>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex md:items-center md:space-x-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors relative',
              isActive(item.href) ? 'text-[var(--color-primary-light)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary-light)]'
            ]}
          >
            {item.label}
          </a>
        ))}

        <!-- Solutions Dropdown -->
        <div class="relative group">
          <button
            class:list={[
              'text-sm font-medium transition-colors inline-flex items-center gap-1',
              pathname.includes('/cozumler') ? 'text-[var(--color-primary-light)]' : 'text-[var(--color-text)] hover:text-[var(--color-primary-light)]'
            ]}
          >
            Çözümler
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute top-full left-0 mt-2 w-64 bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-[60]">
            <div class="py-2">
              {solutionItems.map((item) => (
                <a href={item.href} class="block px-4 py-2.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] hover:bg-[var(--color-surface)]/50 transition-colors">
                  {item.label}
                </a>
              ))}
              <div class="border-t border-[var(--color-border)] mt-1 pt-1">
                <a href="/cozumler/" class="block px-4 py-2.5 text-sm font-semibold text-[var(--color-text)] hover:text-[var(--color-primary-light)] transition-colors">
                  Tüm Çözümler →
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-[var(--color-text)]" aria-label="Toggle menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-[var(--color-surface-light)] border-t border-[var(--color-border)]">
    <div class="container mx-auto px-4 py-4 space-y-2">
      {navItems.map((item) => (
        <a href={item.href} class:list={['block px-3 py-2 rounded-md text-sm transition-colors', isActive(item.href) ? 'text-[var(--color-primary-light)] bg-[var(--color-border)]/30' : 'text-[var(--color-text)] hover:bg-[var(--color-border)]/30']}>
          {item.label}
        </a>
      ))}
      <div class="border-t border-[var(--color-border)] pt-2 mt-2">
        <span class="px-3 text-xs text-[var(--color-text-muted)] uppercase tracking-wider">Çözümler</span>
        {solutionItems.map((item) => (
          <a href={item.href} class="block px-3 py-2 rounded-md text-sm text-[var(--color-text)] hover:bg-[var(--color-border)]/30 transition-colors">
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
