---
/*
 * BaseLayout.astro — Base layout for ALL pages
 *
 * PITFALL MITIGATIONS APPLIED:
 * #1 (Canonical Suicide): Dynamic canonical per page
 * #2 (SPA Shell): Full static HTML, no <div id="root">
 * #5 (Google Fonts): Local @fontsource/poppins, NO external <link>
 * #7 (Cookie/Analytics): Vanilla JS in public/, loaded via is:inline
 * #12 (CSP): Strict headers in public/_headers
 */

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  schemaType?: 'WebPage' | 'AboutPage' | 'ContactPage' | 'FAQPage' | 'CollectionPage';
}

const {
  title,
  description,
  ogImage = '/og-homepage.jpg',
  ogType = 'website',
  noindex = false,
  breadcrumbs = [],
  schemaType = 'WebPage',
} = Astro.props;

// PITFALL #1 FIX: Dynamic canonical per page
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// Schema.org: LocalBusiness (global, appears on all pages)
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Pratik Yapay Zeka',
  alternateName: 'ST-Automatisierung',
  url: Astro.site?.toString() || 'https://yapayzekapratik.com',
  logo: new URL('/logo.png', Astro.site).href,
  description: 'Yapay zeka ve otomasyon danışmanlığı. Lead generation, satış, pazarlama ve müşteri hizmeti otomasyonu.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Heidestraße 2',
    addressLocality: 'Schwerte',
    postalCode: '58239',
    addressCountry: 'DE',
  },
  email: 's.tepecik@pratik-yapayzeka.com',
  sameAs: [
    'https://www.youtube.com/@yapayzekapratik',
    'https://www.tiktok.com/@yapayzekapratik',
    'https://www.instagram.com/yapayzekapratik',
  ],
  areaServed: ['TR', 'DE'],
  priceRange: '$$',
};

// Schema.org: WebSite (for sitelinks search box)
const webSiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Pratik Yapay Zeka',
  url: Astro.site?.toString() || 'https://yapayzekapratik.com',
};

// Schema.org: BreadcrumbList (if breadcrumbs provided)
const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((bc, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: bc.name,
    item: new URL(bc.url, Astro.site).href,
  })),
} : null;

// Schema.org: Current WebPage
const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: title,
  description: description,
  url: canonicalURL.href,
  isPartOf: {
    '@type': 'WebSite',
    name: 'Pratik Yapay Zeka',
    url: Astro.site?.toString() || 'https://yapayzekapratik.com',
  },
};

import '../styles/global.css';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
---

<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- PITFALL #1 FIX: Unique title + description per page -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- PITFALL #1 FIX: Dynamic canonical per page -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- hreflang: Turkish primary + x-default (Fix 4.6) -->
    <link rel="alternate" hreflang="tr" href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- SEO: Robots -->
    {noindex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:site_name" content="Pratik Yapay Zeka" />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- PITFALL #5 FIX: NO <link> to fonts.googleapis.com here! -->
    <!-- Poppins is loaded locally via @fontsource in global.css -->

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
  </head>

  <body class="overflow-x-hidden relative">
    <Navigation />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- PITFALL #7 FIX: Cookie consent banner — GA4 only loads after explicit acceptance -->
    <CookieConsent />
  </body>
</html>
