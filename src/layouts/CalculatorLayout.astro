---
import BaseLayout from './BaseLayout.astro';
import ROICalculator from '../components/ROICalculator';
import LeadPathways from '../components/LeadPathways.astro';
import { buildContactHref } from '../lib/contactHref';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  schema?: string;
}

const { title, description, keywords, ogImage, schema } = Astro.props;

const pathname = Astro.url.pathname;
const hrContactHref = (cta: string) => buildContactHref({ source: pathname, packageName: 'ik-surec-analizi', area: 'other', cta });
const financeContactHref = (cta: string) => buildContactHref({ source: pathname, packageName: 'finans-operasyon-analizi', area: 'finance-accounting', cta });
const commerceContactHref = (cta: string) => buildContactHref({ source: pathname, packageName: 'operasyon-haritasi', area: 'other', cta });
const shortName = title.split('|')[0].trim();
const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Hesaplama Araclari ve Çözümler', url: '/cozumler/' },
  { name: shortName, url: pathname },
];

const hrSignals = [
  '/maas-hesaplama-motoru/',
  '/bordro-hesaplama/',
  '/brutten-nete/',
  '/sgk-hizmet-dokumu/',
  '/kidem-tazminati-hesaplama/',
  '/ihbar-tazminati-hesaplama/',
  '/isverene-maliyet-hesaplama/',
  '/fazla-mesai-hesaplama/',
  '/yillik-izin-ucreti-hesaplama/',
];

const financeSignals = [
  '/kdv-hesaplama/',
  '/vergi-iadesi-hesaplama/',
  '/e-beyanname/',
  '/defter-beyan/',
  '/e-arsiv-portali/',
  '/mutabakat-mektubu/',
  '/cari-hesap-ekstresi/',
  '/acik-fatura-kapali-fatura/',
];

const hrNextSteps = [
  {
    href: '/brutten-nete/',
    title: 'IK süreçlerini yardim masasi gibi yönetin',
    description: 'Brütten nete, personel soruları ve tekrar eden IK islemlerini tek akista otomatikleştirin.',
    badge: 'HR',
  },
  {
    href: '/sgk-hizmet-dokumu/',
    title: 'Aday ve personel dogrulama akislarini guclendirin',
    description: 'Özellikle ise alim ve risk kontrol sureclerinde belge tabanlı otomasyonu derinlestirin.',
    badge: 'Check',
  },
  {
    href: hrContactHref('calculator-nextstep-contact'),
    title: 'Kendi surecinize gore teknik analiz alin',
    description: 'Hazır içerik yerine size uygun senaryo cizmek için kısa bir on analiz talep edin.',
    badge: 'Lead',
  },
];

const financeNextSteps = [
  {
    href: '/on-muhasebe-ve-fatura/',
    title: 'Muhasebe veri girisini merkezden azaltin',
    description: 'Belge okumadan ERP kaydina kadar daha büyük resmi kuran ana çözüm sayfasi.',
    badge: 'Finance',
  },
  {
    href: '/e-beyanname/',
    title: 'Beyanname ve kontrol akislarini ilerletin',
    description: 'Özellikle uyum ve dogrulama tarafinda daha net operasyonel akislar için bakin.',
    badge: 'Compliance',
  },
  {
    href: '/mutabakat-mektubu/',
    title: 'Takip ve mutabakat süreçlerini birlestirin',
    description: 'Yanıtsız e-postalar, tekrar eden follow-up ve ay sonu kapanis yukunu azaltin.',
    badge: 'Follow-up',
  },
];

const commerceNextSteps = [
  {
    href: '/teklif-hazirlama-programi/',
    title: 'Teklif hazırlama surecini toparlayin',
    description: 'Fiyat, kur ve teklif akisini daha kontrollu ve hızlı hale getirin.',
    badge: 'Quoting',
  },
  {
    href: '/e-ticaret-ve-pazaryeri-otomasyonu/',
    title: 'Sipariş ve operasyon akisini sistemlestirin',
    description: 'Pazaryeri, kargo ve fatura akisini daha büyük bir operasyon mantigina baglayin.',
    badge: 'Commerce',
  },
  {
    href: '/stok-takibi-programi/',
    title: 'Stok ve kanal senkronunu guclendirin',
    description: 'Operasyon tarafinda elle takip yerine daha gerçek zamanli bir yapı kurun.',
    badge: 'Inventory',
  },
];

const proofCases = [
  {
    href: '/vaka-calismalari/cemkimsan/',
    title: 'Cemkimsan vaka calismasi',
    description: 'Operasyonel yuk ve satış/pazarlama akislarinin otomasyonla nasıl olceklendigini inceleyin.',
    badge: 'Operations',
  },
  {
    href: '/vaka-calismalari/erpa-teknoloji/',
    title: 'ERPA Teknoloji vaka calismasi',
    description: 'B2B araştırma, lead toplama ve sistematik akış tarafinda guven kuran bir örnek.',
    badge: 'B2B',
  },
  {
    href: '/vaka-calismalari/car-studio-ai/',
    title: 'Car Studio AI vaka calismasi',
    description: 'Küçük ekiplerle daha olceklenebilir otomasyon mantiginin pratik sonucunu gorun.',
    badge: 'Scale',
  },
];

const currentTrack = hrSignals.some((signal) => pathname.startsWith(signal))
  ? 'hr'
  : financeSignals.some((signal) => pathname.startsWith(signal))
    ? 'finance'
    : 'commerce';

const nextSteps = currentTrack === 'hr' ? hrNextSteps : currentTrack === 'finance' ? financeNextSteps : commerceNextSteps;
const contactHref = (cta: string) => currentTrack === 'hr'
  ? hrContactHref(cta)
  : currentTrack === 'finance'
    ? financeContactHref(cta)
    : commerceContactHref(cta);

const offerMap = {
  hr: {
    badge: 'IK analizi',
    title: 'Bu sayfadan projeye geçiş nasıl olur?',
    description: 'Tekil hesap yerine IK ekibinizde hangi tekrar eden sorularin ve hangi bordro adimlarinin sürekli zaman yedigini cikaririz.',
    bullets: [
      'IK destek ve bordro akışında tekrar eden taleplerin ayrimi',
      'Puantaj, izin, çıkış veya personel self-service için ilk otomasyon dugumu',
      'Size uygun ilk kurulum senaryosu',
    ],
    cta: 'IK süreç analizini iste',
  },
  finance: {
    badge: 'Finans analizi',
    title: 'Bu sayfadan projeye geçiş nasıl olur?',
    description: 'Belge, kayit, tahsilat ve kontrol akislarinda manuel tekrar nerede olusuyor birlikte netlestiririz.',
    bullets: [
      'Belge ve veri girişi darboagazlarinin tespiti',
      'Tahsilat, mutabakat veya beyan akışında kopus noktalarinin ayrimi',
      'Finans operasyonu için ilk otomasyon önerisi',
    ],
    cta: 'Finans analizini iste',
  },
  commerce: {
    badge: 'Operasyon analizi',
    title: 'Bu sayfadan projeye geçiş nasıl olur?',
    description: 'Hesap ya da bilgi ihtiyacının gerçekte hangi operasyon akisina baglandigini belirler ve size uygun ilk sistemi tarif ederiz.',
    bullets: [
      'Tekrarlayan operasyon adimlarinin ayrimi',
      'Sipariş, teklif veya stok akisindaki tekrar isin tespiti',
      'Hızlı geri dönüş verecek ilk kurulum plani',
    ],
    cta: 'Operasyon analizini iste',
  },
};

const currentOffer = offerMap[currentTrack];
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <main class="bg-[var(--color-void-ink-deep)] text-[var(--color-paper-ecru)] selection:bg-[var(--color-patina-copper-bright)] selection:text-[var(--color-void-ink-deep)]">
    <style is:inline>
      .theme-text { color: var(--color-patina-copper-bright); }
      .theme-border { border-color: var(--color-patina-copper-bright); }
      .theme-bg { background-color: var(--color-patina-copper-bright); color: var(--color-void-ink-deep) !important; }
      .theme-glow-bg { background: radial-gradient(circle, rgba(224, 150, 84, 0.15) 0%, transparent 70%); }
    </style>

    <article data-santral-reveal class="relative pb-16 pt-28 md:pt-36 lg:pb-24">
      <div class="pointer-events-none absolute -top-32 right-[-10%] h-[420px] w-[520px] rounded-full opacity-[0.14] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>

      <div class="container relative z-10 mx-auto max-w-4xl px-6 lg:px-10">
        <div class="flex items-center gap-4 mb-10">
          <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
          <span class="santral-overline">Hesaplama · Rehber</span>
        </div>
        <div class="santral-calc-prose prose prose-lg max-w-none text-[var(--color-paper-ecru-dim)] prose-headings:text-[var(--color-paper-ecru)] prose-a:text-[var(--color-patina-copper-bright)] hover:prose-a:text-[var(--color-paper-ecru)] prose-strong:text-[var(--color-paper-ecru)]">
          <slot />
        </div>
      </div>
    </article>

    <ROICalculator client:visible sectorName="Operasyon" />

    <LeadPathways
      title="Bu sayfayi bir cikmaz değil, geçiş noktasi yapin"
      description="Hesaplama niyetli ziyaretciler bile guven ve sonraki adım görmek ister. Bu nedenle ilgili çözümler ve proof katmani burada dogrudan görünür olmali."
      caseStudies={proofCases}
      nextSteps={nextSteps}
      contactHref={contactHref('calculator-lead-pathways')}
    />

    <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-20">
      <div class="container mx-auto max-w-6xl px-6 lg:px-10">
        <div class="santral-hat p-8 md:p-10" style="border-color: rgba(224, 150, 84, 0.28)">
          <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
            <div class="max-w-2xl">
              <span class="santral-overline block" style="color: var(--color-patina-copper-bright)">{currentOffer.badge}</span>
              <h2 class="mt-4 santral-display text-3xl md:text-4xl" style="font-weight:500;text-wrap:balance">{currentOffer.title}</h2>
              <p class="mt-4 santral-body text-base md:text-lg">{currentOffer.description}</p>
            </div>
            <a href={contactHref('calculator-offer-panel')} class="santral-salter santral-salter-copper shrink-0">
              {currentOffer.cta}
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
              </svg>
            </a>
          </div>

          <div class="mt-8 grid gap-4 md:grid-cols-3 pt-6 border-t border-[var(--color-hairline)]">
            {currentOffer.bullets.map((item, i) => (
              <div class="flex items-start gap-3">
                <span class="font-mono text-[0.72rem] tracking-[0.14em] text-[var(--color-patina-copper-bright)] pt-[3px]">{String(i + 1).padStart(2, '0')}</span>
                <p class="text-sm leading-[1.6] text-[var(--color-paper-ecru-dim)]">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
      <div class="container mx-auto max-w-4xl px-6 lg:px-10 text-center">
        <div class="mb-8 flex items-center justify-center gap-4">
          <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
          <span class="santral-overline">Başlatma · Sonraki Adım</span>
          <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
        </div>
        <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">
          Manuel hesaplamaları ve olası <em class="santral-italic">cezaları</em> bitirin
        </h2>
        <p class="mt-6 santral-body max-w-2xl mx-auto">
          Excel formülleriyle şirketinizi riske atmayın. Yasalara uyumlu, 7/24 çalışan ve sıfıra yakın hata ile operasyon yöneten bir yapay zeka asistanı kurmak için ücretsiz teknik analiz talep edin.
        </p>
        <div class="mt-10 flex justify-center">
          <a href={contactHref('calculator-final-cta')} class="santral-salter santral-salter-copper">
            Projeyi başlat
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  {schema && <script type="application/ld+json" set:html={schema} />}
</BaseLayout>
