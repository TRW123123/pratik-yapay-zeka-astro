---
import BaseLayout from './BaseLayout.astro';
import ROICalculator from '../components/ROICalculator';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogImage?: string;
  schema?: string;
}

const {
  title,
  description,
  keywords,
  ogImage,
  schema
} = Astro.props;

const pathname = Astro.url.pathname;
const shortName = title.split('|')[0].trim();
const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Hesaplama Araçları & Çözümler', url: '/cozumler/' },
  { name: shortName, url: pathname },
];
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <main class="bg-[#0B0F14] text-white selection:bg-[#A3E635] selection:text-black">
    <!-- Dynamic Theme Styles -->
    <style is:inline>
      .theme-text { color: #A3E635; }
      .theme-border { border-color: #A3E635; }
      .theme-bg { background-color: #A3E635; color: #0B0F14 !important; }
      .theme-glow-bg { background: radial-gradient(circle, rgba(163, 230, 53, 0.15) 0%, transparent 70%); }
    </style>

    <article class="pt-32 pb-16 lg:pt-40 lg:pb-24">
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[800px] rounded-full blur-[150px] pointer-events-none opacity-40 theme-glow-bg"></div>
      
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl relative z-10 prose prose-invert prose-lg prose-headings:text-white prose-p:text-gray-400 prose-a:text-[#A3E635] hover:prose-a:text-[#84CC16] prose-strong:text-gray-200">
        <slot />
      </div>
    </article>

    <ROICalculator client:visible sectorName="Operasyon" />

    <!-- FINAL CTA HOOK -->
    <section class="py-24 lg:py-32 relative overflow-hidden">
      <div class="absolute inset-0 theme-bg opacity-[0.02] pointer-events-none"></div>
      
      <div class="container mx-auto px-4 text-center max-w-5xl relative z-10">
        <div class="bg-[#FFFFFF]/[0.02] backdrop-blur-2xl rounded-[3rem] p-12 lg:p-24 shadow-2xl border border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 pointer-events-none blur-3xl" style="background: radial-gradient(circle at center, rgba(163, 230, 53, 0.15) 0%, transparent 70%);"></div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-black mb-8 text-white tracking-tight leading-[1.1] relative z-10">
            Manuel Hesaplamaları ve Olası Cezaları Bitirin
          </h2>
          <p class="text-lg md:text-xl text-gray-400 mb-12 max-w-3xl mx-auto font-medium leading-relaxed relative z-10">
            Excel formülleriyle şirketinizi riske atmayın. Yasalara tam uyumlu, 7/24 çalışan ve sıfır hata ile operasyon yöneten yapay zeka asistanınızı kurmak için ücretsiz teknik analiz talep edin.
          </p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 relative z-10">
            <a href="/iletisim/" class="group relative px-12 py-6 font-black rounded-2xl transition-all duration-500 text-xl inline-flex items-center gap-3 text-black hover:-translate-y-1 theme-bg" style="box-shadow: 0 0 30px rgba(163, 230, 53, 0.15);">
              Projeyi Başlat
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>

  {schema && <script type="application/ld+json" set:html={schema} />}
</BaseLayout>
