---
import BaseLayout from './BaseLayout.astro';
import { buildContactHref } from '../lib/contactHref';

interface Metric {
  value: string;
  label: string;
}

interface LinkCard {
  href: string;
  title: string;
  description: string;
  badge?: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  companyName: string;
  industry: string;
  challenge: string;
  solution: string;
  results: string[];
  metrics: Metric[];
  quote?: string;
  quoteAuthor?: string;
  relatedSolutions?: LinkCard[];
  analysisPackage?: string;
  analysisArea?: string;
  analysisLabel?: string;
}

const {
  title,
  description,
  ogImage,
  companyName,
  industry,
  challenge,
  solution,
  results,
  metrics,
  quote,
  quoteAuthor,
  relatedSolutions = [],
  analysisPackage = 'lead-flow-audit',
  analysisArea = 'marketing-leads',
  analysisLabel = 'Benzer bir akışı kendi sirketinize uyarlayin',
} = Astro.props;

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Vaka Çalışmaları', url: '/vaka-calismalari/' },
  { name: companyName, url: Astro.url.pathname },
];

const contactHref = buildContactHref({
  source: Astro.url.pathname,
  packageName: analysisPackage,
  area: analysisArea,
  cta: 'case-study-primary',
});

const caseStudySchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `${companyName} — ${industry}`,
  description: description,
  author: {
    '@type': 'Organization',
    name: 'Pratik Yapay Zeka',
    url: 'https://yapayzekapratik.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Pratik Yapay Zeka',
    url: 'https://yapayzekapratik.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://yapayzekapratik.com/apple-touch-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': new URL(Astro.url.pathname, Astro.site).href,
  },
  image: ogImage ? new URL(ogImage, Astro.site).href : 'https://yapayzekapratik.com/og-homepage.jpg',
  articleSection: 'Vaka Calismasi',
  inLanguage: 'tr-TR',
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <section data-santral-reveal class="relative overflow-hidden pt-24 pb-14 md:pt-32">
    <div class="pointer-events-none absolute -top-32 left-[-10%] h-[420px] w-[520px] rounded-full opacity-[0.12] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>

    <div class="container mx-auto max-w-6xl px-6 lg:px-10 relative z-10">
      <a href="/vaka-calismalari/" class="mb-8 inline-flex items-center gap-2 font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[var(--color-paper-ecru-mute)] transition-colors hover:text-[var(--color-patina-copper-bright)]">
        ← Tüm vaka çalışmaları
      </a>

      <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-16">
        <aside class="md:w-[240px] md:shrink-0 md:pt-2">
          <span class="santral-overline block">Kayıt · {industry}</span>
          <div class="mt-4 flex items-center gap-3" aria-hidden="true">
            <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
            <span class="h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]"></span>
            <span class="h-[1px] flex-1 bg-[var(--color-hairline-strong)]"></span>
          </div>
          <p class="mt-5 font-mono text-[0.72rem] leading-relaxed tracking-[0.14em] uppercase text-[var(--color-paper-ecru-mute)]">
            Sektör · {industry}<br/>
            Durum · Canlı
          </p>
        </aside>
        <div class="flex-1 max-w-3xl">
          <h1 class="santral-display text-4xl leading-[1.05] md:text-6xl lg:text-[4.25rem]" style="font-weight:400;text-wrap:balance;">
            {companyName}
          </h1>
          <p class="mt-6 font-mono text-[0.82rem] tracking-[0.08em] text-[var(--color-patina-copper-bright)]">{industry}</p>
        </div>
      </div>

      <div class="mt-14 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {metrics.map((m) => (
          <div class="santral-hat p-6 text-center">
            <p class="mb-2 santral-display text-3xl font-mono text-[var(--color-patina-copper-bright)]" style="font-weight:500">{m.value}</p>
            <p class="santral-label">{m.label}</p>
          </div>
        ))}
      </div>

      <div class="space-y-8">
        <div class="santral-hat p-8 md:p-10" style="border-left: 3px solid var(--color-ink-bleed)">
          <span class="santral-overline block mb-4">Zorluk · 01</span>
          <h2 class="santral-display text-2xl md:text-3xl mb-4" style="font-weight:500">Zorluk</h2>
          <p class="santral-body text-lg leading-relaxed">{challenge}</p>
        </div>

        <div class="santral-hat p-8 md:p-10" style="border-left: 3px solid var(--color-oxide-teal-bright)">
          <span class="santral-overline block mb-4">Çözüm · 02</span>
          <h2 class="santral-display text-2xl md:text-3xl mb-4" style="font-weight:500">Çözüm</h2>
          <p class="santral-body text-lg leading-relaxed">{solution}</p>
        </div>

        <div class="santral-hat p-8 md:p-10" style="border-left: 3px solid var(--color-patina-copper-bright)">
          <span class="santral-overline block mb-4">Sonuçlar · 03</span>
          <h2 class="santral-display text-2xl md:text-3xl mb-4" style="font-weight:500">Sonuçlar</h2>
          <ul class="space-y-3">
            {results.map((r) => (
              <li class="flex items-start gap-3">
                <span class="mt-2 shrink-0 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]"></span>
                <span class="text-[0.98rem] leading-[1.68] text-[var(--color-paper-ecru-dim)]">{r}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {quote && (
        <blockquote class="relative mt-16 border-l-[3px] border-[var(--color-patina-copper-bright)] bg-[var(--color-void-ink)]/55 py-6 pl-8 pr-8" style="border-radius:0 2px 2px 0">
          <div class="absolute -left-3 -top-5 santral-display text-6xl text-[var(--color-patina-copper-bright)] opacity-60" style="font-weight:400">"</div>
          <p class="relative z-10 mb-4 santral-display text-xl italic md:text-2xl leading-[1.35] text-[var(--color-paper-ecru)]" style="font-weight:400">{quote}</p>
          {quoteAuthor && <cite class="font-mono text-[0.78rem] tracking-[0.14em] uppercase text-[var(--color-patina-copper-bright)] not-italic">— {quoteAuthor}</cite>}
        </blockquote>
      )}

      <div class="mt-20 grid gap-5 lg:grid-cols-[1.15fr_0.85fr]">
        <div class="santral-hat p-7 lg:p-8">
          <div class="flex items-center justify-between gap-4 mb-6">
            <span class="santral-overline">İlgili · 04</span>
            <a href="/cozumler/" class="font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[var(--color-patina-copper-bright)] transition hover:text-[var(--color-paper-ecru)]">
              Tüm çözümler →
            </a>
          </div>
          <h2 class="santral-display text-2xl md:text-3xl mb-6" style="font-weight:500">İlgili çözüm sayfaları</h2>

          <div class="space-y-3">
            {relatedSolutions.map((item) => (
              <a href={item.href} class="block border border-[var(--color-hairline)] bg-[var(--color-void-ink-deep)]/55 p-5 transition-all hover:border-[var(--color-patina-copper)] hover:-translate-y-0.5" style="border-radius:2px">
                {item.badge && (
                  <span class="santral-label block mb-2">{item.badge}</span>
                )}
                <h3 class="santral-display text-base md:text-lg" style="font-weight:500">{item.title}</h3>
                <p class="mt-2 text-[0.85rem] leading-[1.55] text-[var(--color-paper-ecru-dim)]">{item.description}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="santral-hat p-7 lg:p-8 flex flex-col" style="border-color: rgba(224, 150, 84, 0.28)">
          <div class="flex items-center gap-2 mb-6">
            <span class="inline-block h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]" style="animation: morse-pulse 2.6s ease-in-out infinite"></span>
            <span class="santral-overline">Dönüşüm · Sonraki Adım</span>
          </div>
          <h2 class="santral-display text-2xl md:text-3xl" style="font-weight:400;line-height:1.15;text-wrap:balance">{analysisLabel}</h2>
          <p class="mt-5 text-[0.9rem] leading-[1.65] text-[var(--color-paper-ecru-dim)]">
            Bu vaka çalışması size tanıdık geliyorsa, kendi sürecinizde aynı darboğazları ve ilk otomasyon fırsatını birlikte çıkaralım.
          </p>

          <ul class="mt-6 space-y-2 text-[0.85rem] text-[var(--color-paper-ecru-dim)]">
            <li class="flex items-start gap-2"><span class="text-[var(--color-patina-copper-bright)] mt-[4px]">·</span> Benzer süreçlere göre analiz önceliği</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-patina-copper-bright)] mt-[4px]">·</span> Ekibinize uygun ilk otomasyon düğümü</li>
            <li class="flex items-start gap-2"><span class="text-[var(--color-patina-copper-bright)] mt-[4px]">·</span> Uygulanabilir sonraki adım planı</li>
          </ul>

          <a href={contactHref} class="santral-salter santral-salter-copper mt-auto pt-5 justify-center">
            Ücretsiz analizi talep et
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(caseStudySchema)} />
</BaseLayout>
