---
import BaseLayout from './BaseLayout.astro';

interface Metric {
  value: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  companyName: string;
  industry: string;
  challenge: string;
  solution: string;
  results: string[];
  metrics: Metric[];
  quote?: string;
  quoteAuthor?: string;
}

const { title, description, ogImage, companyName, industry, challenge, solution, results, metrics, quote, quoteAuthor } = Astro.props;

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Vaka Çalışmaları', url: '/vaka-calismalari/' },
  { name: companyName, url: Astro.url.pathname },
];
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <section class="py-32 lg:py-48 relative overflow-hidden">
    <!-- Ambient Glow Background -->
    <div class="absolute top-[20%] left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[var(--color-primary)]/5 rounded-full blur-[120px] pointer-events-none opacity-50"></div>
    <div class="container mx-auto px-4 max-w-4xl relative z-10">
      <a href="/vaka-calismalari/" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary-light)] transition-colors mb-8 inline-block">← Tüm Vaka Çalışmaları</a>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">{companyName}</h1>
      <p class="text-[var(--color-primary-light)] font-medium mb-8">{industry}</p>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
        {metrics.map((m) => (
          <div class="neon-bleed-border bg-[var(--color-surface-light)]/50 backdrop-blur-sm rounded-xl p-6 text-center group relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <p class="text-3xl font-extrabold text-[var(--color-primary)] mb-1">{m.value}</p>
            <p class="text-xs font-medium text-[var(--color-text-muted)] tracking-wider uppercase">{m.label}</p>
          </div>
        ))}
      </div>

      <div class="space-y-8">
        <div class="neon-bleed-border bg-[var(--color-surface-light)]/50 backdrop-blur-sm rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-1 h-full bg-[var(--color-primary)]/50"></div>
          <h2 class="text-2xl font-semibold mb-4 text-[var(--color-text)]">Zorluk</h2>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">{challenge}</p>
        </div>
        <div class="neon-bleed-border bg-[var(--color-surface-light)]/50 backdrop-blur-sm rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-1 h-full bg-[var(--color-accent)]/50"></div>
          <h2 class="text-2xl font-semibold mb-4 text-[var(--color-text)]">Çözüm</h2>
          <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">{solution}</p>
        </div>
        <div class="neon-bleed-border bg-[var(--color-surface-light)]/50 backdrop-blur-sm rounded-2xl p-8 relative overflow-hidden group">
          <div class="absolute top-0 left-0 w-1 h-full bg-gradient-to-b from-[var(--color-primary)] to-[var(--color-accent)]"></div>
          <h2 class="text-2xl font-semibold mb-4 text-[var(--color-text)]">Sonuçlar</h2>
          <ul class="space-y-2">
            {results.map((r) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                <span class="text-[var(--color-text-muted)] text-lg">{r}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      {quote && (
        <blockquote class="mt-16 border-l-4 border-[var(--color-primary)] pl-8 py-6 bg-[var(--color-primary)]/5 rounded-r-2xl relative">
          <div class="absolute -left-3 -top-3 text-[var(--color-primary)]/20 text-6xl font-serif">"</div>
          <p class="text-xl italic mb-4 text-[var(--color-text)] leading-relaxed relative z-10">"{quote}"</p>
          {quoteAuthor && <cite class="text-sm font-semibold uppercase tracking-wider text-[var(--color-primary)]">— {quoteAuthor}</cite>}
        </blockquote>
      )}

      <div class="mt-20 text-center">
        <a href="/cozumler/" class="magnetic-glow-btn bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-[#0B0F14] font-bold px-8 py-4 rounded-xl transition-all duration-300 text-lg inline-flex items-center gap-2">
          <span>Ücretsiz Analiz Talep Et</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
