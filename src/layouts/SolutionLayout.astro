---
/**
 * SolutionLayout.astro — Reusable layout for all 5 solution pages.
 * Prevents code duplication across lead-gen, sales, marketing, CRM, customer service pages.
 */
import BaseLayout from './BaseLayout.astro';

interface ProcessStep {
  title: string;
  description: string;
}

interface Feature {
  title: string;
  description: string;
}

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  heroTitle: string;
  heroSubtitle: string;
  problems: string[];
  processTitle: string;
  processSteps: ProcessStep[];
  featuresTitle: string;
  features: Feature[];
  benefitsTitle: string;
  benefits: string[];
  caseStudyDescription: string;
  finalCtaTitle: string;
  finalCtaSubtitle: string;
  sectorTheme?: string;
}

const {
  title,
  description,
  ogImage,
  heroTitle,
  heroSubtitle,
  problems,
  processTitle,
  processSteps,
  featuresTitle,
  features,
  benefitsTitle,
  benefits,
  caseStudyDescription,
  finalCtaTitle,
  finalCtaSubtitle,
  sectorTheme = 'default'
} = Astro.props;

const pathname = Astro.url.pathname;
const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Çözümler', url: '/cozumler/' },
  { name: heroTitle.split(' – ')[0], url: pathname },
];

// Map sectors to gradient/glow colors for deep customization
const themeColors: Record<string, { primary: string, accent: string, glow: string }> = {
  'emlak': { primary: '#F59E0B', accent: '#D97706', glow: 'rgba(245, 158, 11, 0.15)' }, // Amber
  'hukuk': { primary: '#3B82F6', accent: '#2563EB', glow: 'rgba(59, 130, 246, 0.18)' }, // Blue
  'muhasebe': { primary: '#10B981', accent: '#059669', glow: 'rgba(16, 185, 129, 0.15)' }, // Emerald
  'e-ticaret': { primary: '#A855F7', accent: '#9333EA', glow: 'rgba(168, 85, 247, 0.15)' }, // Purple
  'default': { primary: '#A3E635', accent: '#84CC16', glow: 'rgba(163, 230, 53, 0.15)' } // Base Lime
};

const currentTheme = themeColors[sectorTheme] || themeColors['default'];
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <!-- Inject dynamic CSS vars into main tag for 100% reliable scoping in Astro -->
  <style is:inline>
    .theme-text { color: var(--themePrimary); }
    .theme-border { border-color: var(--themePrimary); }
    .theme-bg { background-color: var(--themePrimary); color: #0B0F14 !important; }
    .theme-glow-bg { background: radial-gradient(circle, var(--themeGlow) 0%, transparent 70%); }
    .theme-btn { background-color: var(--themePrimary); color: #0B0F14; }
    .theme-btn:hover { background-color: var(--themeAccent); box-shadow: 0 0 25px var(--themeGlow); }
    
    body {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
  </style>

  <main class="bg-[#0B0F14] text-white overflow-hidden relative selection:bg-[var(--themePrimary)] selection:text-black" style={`--themePrimary: ${currentTheme.primary}; --themeAccent: ${currentTheme.accent}; --themeGlow: ${currentTheme.glow}; --color-primary: ${currentTheme.primary}; --color-primary-dark: ${currentTheme.accent};`}>
    
    <!-- Hero Section -->
    <section class="py-32 lg:py-48 relative overflow-hidden">
      <!-- Ambient Background Architecture -->
      <div class="absolute inset-0 bg-[url('/noise.png')] opacity-[0.03] mix-blend-overlay pointer-events-none"></div>
      <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[1000px] h-[1000px] rounded-full blur-[160px] pointer-events-none opacity-50 theme-glow-bg"></div>
      
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl text-center relative z-10">
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/5 border border-white/10 mb-8 backdrop-blur-md opacity-0" data-gsap="fade-up">
          <span class="w-2.5 h-2.5 rounded-full theme-bg animate-pulse shadow-[0_0_10px_var(--themePrimary)]"></span>
          <span class="text-sm font-bold tracking-widest text-[#E2E8F0] uppercase letter-spacing-[0.2em]">
            {sectorTheme !== 'default' ? `${sectorTheme.split('-').join(' ')} Çözümü` : 'Yapay Zeka Otomasyonu'}
          </span>
        </div>
        
        <h1 class="text-3xl md:text-5xl lg:text-5xl xl:text-5xl font-black mb-8 leading-[1.1] tracking-tight text-transparent bg-clip-text bg-gradient-to-br from-white via-gray-200 to-gray-500 opacity-0" data-gsap="fade-up" data-delay="0.1">
          {heroTitle}
        </h1>
        <p class="text-base md:text-lg lg:text-xl text-gray-400 mb-12 max-w-3xl mx-auto font-medium leading-relaxed opacity-0" data-gsap="fade-up" data-delay="0.2">
          {heroSubtitle}
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-6 opacity-0" data-gsap="fade-up" data-delay="0.3">
          <a href="/iletisim/" class="group relative px-10 py-5 font-bold rounded-2xl transition-all duration-300 hover:-translate-y-1 overflow-hidden theme-bg" style="box-shadow: 0 0 25px var(--themeGlow);">
             <span class="relative z-10 text-black flex items-center justify-center gap-3 text-lg">
                Sistemi Kurun 
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
             </span>
          </a>
        </div>
      </div>
    </section>

    <!-- 1. BENTO BOX: RESILIENT HARD METRICS -->
    <section class="py-24 relative z-10">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <div class="flex flex-col mb-16 items-center text-center">
          <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">{benefitsTitle || "Ölçülebilir Operasyonel Kazanımlar"}</h2>
          <p class="text-gray-400 max-w-2xl text-lg font-medium">B2B süreçlerinize entegre edilen yapay zekanın gerçek dünya sonuçları.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-fr">
          {benefits.map((benefit, i) => {
             // Extract exactly the percentage/multiplier to make it massive
             // Added \d+\/\d+ to explicitly catch patterns like "7/24" without breaking them apart
             const metricValueMatch = benefit.match(/(\d+\/\d+|\+?%\d+(?:\.\d+)?|\d+x|\d+\+? saat|\d+ dakika|\d+\+?)/i);
             const massiveMetric = metricValueMatch ? metricValueMatch[0] : "";
             const remainingText = benefit.replace(massiveMetric, "").trim();

             return (
              <div class="flex flex-col h-full group backdrop-blur-[24px] saturate-[150%] bg-[#FFFFFF]/[0.02] border border-white/[0.05] rounded-[2rem] p-8 lg:p-10 hover:bg-[#FFFFFF]/[0.04] transition-all duration-500 relative overflow-hidden hover:border-white/[0.1] hover:-translate-y-1">
                <!-- Theme Glow Bloom Follower effect -->
                <div class="absolute -inset-px opacity-0 group-hover:opacity-100 transition-opacity duration-1000 pointer-events-none blur-2xl" style="background: radial-gradient(circle at top right, var(--themeGlow) 0%, transparent 60%);"></div>
                
                <div class="relative z-10 flex flex-col h-full">
                  <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 border border-white/10 bg-black/50 shadow-lg relative theme-text">
                    {i % 3 === 0 && <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>}
                    {i % 3 === 1 && <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
                    {i % 3 === 2 && <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>}
                  </div>
                  
                  {massiveMetric ? (
                    <>
                      <div class="text-4xl md:text-5xl lg:text-6xl font-black mb-4 tracking-tighter theme-text">{massiveMetric}</div>
                      <p class="text-gray-300 leading-relaxed text-base lg:text-lg font-medium flex-grow">{remainingText}</p>
                    </>
                  ) : (
                    <p class="text-gray-300 leading-relaxed text-base lg:text-lg font-medium flex-grow" set:html={benefit.replace(/(\d+\/\d+|\+?%\d+(?:'[a-z]+|\.\d+)?|\d+x|\d+\+? saat|\d+ dakika|\d+\+?|%[0-9.]+)/gi, '<strong class="theme-text text-3xl font-black block mb-2">$1</strong>')} />
                  )}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    </section>

    <!-- 2. RESILIENT PAIN POINTS (Abstract Warning Cards) -->
    <section class="py-24 bg-[#0F151B]/50 border-y border-white/5 relative z-10">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <h2 class="text-3xl md:text-5xl font-black mb-16 text-center tracking-tight text-white">Mevcut Sistemdeki Kanama Noktaları</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
          {problems.map((problem) => (
            <div class="flex items-start gap-4 flex-col justify-start bg-[#170505]/60 backdrop-blur-md rounded-2xl p-8 border border-red-900/30 relative overflow-hidden group hover:border-red-800/50 transition-colors">
              <div class="absolute top-0 right-0 p-6 opacity-[0.05] group-hover:opacity-10 transition-opacity text-red-500">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" class="w-32 h-32" fill="currentColor"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm0,192a88,88,0,1,1,88-88A88.1,88.1,0,0,1,128,216Zm-8-80V80a8,8,0,0,1,16,0v56a8,8,0,0,1-16,0Zm20,36a12,12,0,1,1-12-12A12,12,0,0,1,140,172Z"></path></svg>
              </div>
              
              <div class="bg-red-500/10 p-3 rounded-xl shrink-0 text-red-500 border border-red-500/20 relative z-10 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              </div>
              <p class="text-gray-300 text-lg leading-relaxed font-medium relative z-10">{problem}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 3. PROCESS STEPS (Abstract Timeline Layout) -->
    <section class="py-32 relative z-10">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative z-10">
        <div class="text-center mb-20">
           <h2 class="text-3xl md:text-5xl font-black tracking-tight mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">{processTitle}</h2>
           <p class="text-gray-400 max-w-2xl mx-auto text-lg font-medium">Tahmine dayalı değil, veriye dayalı mimari kurulum süreci.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4 relative">
          <!-- Desktop connecting line -->
          <div class="hidden lg:block absolute top-[28px] left-[12%] right-[12%] h-[2px] bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
          
          {processSteps.map((step, i) => (
            <div class="relative pt-8 lg:pt-0 pl-8 lg:pl-0 border-l-2 border-white/5 lg:border-l-0 group flex flex-col items-start lg:items-center text-left lg:text-center h-full">
               
               <div class="absolute left-[-2px] lg:left-auto lg:top-[-4px] lg:relative lg:mb-8 z-10">
                 <!-- The glowing node -->
                 <div class="w-14 h-14 rounded-full bg-[#0B0F14] border-2 border-white/10 flex items-center justify-center font-black text-xl text-white shadow-lg transition-all duration-500 group-hover:border-[var(--themePrimary)] group-hover:shadow-[0_0_20px_var(--themeGlow)] group-hover:-translate-y-1 relative overflow-hidden">
                    <div class="absolute inset-0 opacity-0 group-hover:opacity-20 transition-opacity" style="background-color: var(--themePrimary);"></div>
                    <span class="relative z-10">{i + 1}</span>
                 </div>
               </div>
               
               <h3 class="font-black text-2xl mb-3 text-white">{step.title}</h3>
               <p class="text-gray-400 font-medium leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. FEATURES (Asymmetrical Bento) -->
    <section class="py-24 relative z-10 bg-[#0F151B]/30 border-t border-white/5">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <h2 class="text-3xl md:text-5xl font-black mb-16 text-center tracking-tight text-white drop-shadow-md">{featuresTitle}</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
          {features.map((feature, index) => (
            <div class={`flex flex-col h-full bg-[#FFFFFF]/[0.02] backdrop-blur-md border border-white/5 rounded-[2rem] p-8 lg:p-10 relative overflow-hidden group transition-all duration-500 hover:border-white/10 ${index === 0 ? 'md:col-span-2' : ''} ${index === 3 && features.length > 3 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
              <!-- Hover slide effect line -->
              <div class="absolute top-0 left-0 w-full h-1 opacity-0 group-hover:opacity-100 transition-opacity" style="background-color: var(--themePrimary);"></div>
              
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6 bg-white/5 border border-white/5 group-hover:bg-white/10 transition-colors" style="color: var(--themePrimary);">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 256 256"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path></svg>
              </div>
              
              <h3 class="text-2xl font-black mb-4 text-white">{feature.title}</h3>
              <p class="text-gray-400 leading-relaxed text-lg font-medium">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. FINAL CTA HOOK -->
    <section class="py-32 relative overflow-hidden">
      <div class="absolute inset-0 theme-bg opacity-[0.02] pointer-events-none"></div>
      
      <div class="container mx-auto px-4 text-center max-w-5xl relative z-10">
        <div class="bg-[#FFFFFF]/[0.02] backdrop-blur-2xl rounded-[3rem] p-12 lg:p-24 shadow-2xl border border-white/10 relative overflow-hidden group">
          <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-1000 pointer-events-none blur-3xl" style="background: radial-gradient(circle at center, var(--themeGlow) 0%, transparent 70%);"></div>
          
          <h2 class="text-3xl md:text-4xl lg:text-5xl font-black mb-8 text-white tracking-tight leading-[1.1] relative z-10">{finalCtaTitle}</h2>
          <p class="text-lg md:text-xl text-gray-400 mb-12 max-w-3xl mx-auto font-medium leading-relaxed relative z-10">{finalCtaSubtitle}</p>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-6 relative z-10">
            <a href="/iletisim/" class="group relative px-12 py-6 font-black rounded-2xl transition-all duration-500 text-xl inline-flex items-center gap-3 text-black hover:-translate-y-1 theme-bg" style="box-shadow: 0 0 30px var(--themeGlow);">
              Projeyi Başlat
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
