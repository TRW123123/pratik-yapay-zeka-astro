---
import BaseLayout from './BaseLayout.astro';
import ROICalculator from '../components/ROICalculator';
import LeadPathways from '../components/LeadPathways.astro';
import { buildContactHref } from '../lib/contactHref';

interface ProcessStep {
  title: string;
  description: string;
}

interface Feature {
  title: string;
  description: string;
}

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  schema?: string;
  keywords?: string;
  ogImage?: string;
  heroTitle: string;
  heroSubtitle: string;
  problems: string[];
  processTitle: string;
  processSteps: ProcessStep[];
  featuresTitle: string;
  features: Feature[];
  benefitsTitle: string;
  benefits: string[];
  caseStudyDescription: string;
  finalCtaTitle: string;
  finalCtaSubtitle: string;
  sectorTheme?: string;
  faqs?: FAQ[];
  sectorName?: string;
}

const {
  title,
  description,
  schema,
  ogImage,
  heroTitle,
  heroSubtitle,
  problems,
  processTitle,
  processSteps,
  featuresTitle,
  features,
  benefitsTitle,
  benefits,
  caseStudyDescription,
  finalCtaTitle,
  finalCtaSubtitle,
  sectorTheme = 'default',
  faqs = [],
  sectorName = '',
} = Astro.props;

const pathname = Astro.url.pathname;
const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Çözümler', url: '/cozumler/' },
  { name: heroTitle, url: pathname },
];

const themeColors: Record<string, { primary: string; accent: string; glow: string }> = {
  default: { primary: 'var(--color-patina-copper-bright)', accent: 'var(--color-patina-copper)', glow: 'rgba(224, 150, 84, 0.15)' },
};

const currentTheme = themeColors[sectorTheme] || themeColors.default;
const growthContactHref = (cta: string) => buildContactHref({ source: pathname, packageName: 'lead-flow-audit', area: 'marketing-leads', cta });
const operationsContactHref = (cta: string) => buildContactHref({ source: pathname, packageName: 'operasyon-haritasi', area: 'finance-accounting', cta });

const proofCaseMap = {
  growth: [
    {
      href: '/vaka-calismalari/acilsatis/',
      title: 'Acilsatis vaka calismasi',
      description: 'Operasyon ve görünürlük tarafinda otomasyonla daha hızlı ivme kazanilan akışı inceleyin.',
      badge: 'Lead akış',
    },
    {
      href: '/vaka-calismalari/dkm-coach-bilge/',
      title: 'DKM / Coach Bilge vaka calismasi',
      description: 'Lead funnel tarafinda oyunlastirilmis kurgunun nasıl sonuca donustugunu gorun.',
      badge: 'Funnel',
    },
    {
      href: '/vaka-calismalari/salevium/',
      title: 'Salevium vaka calismasi',
      description: 'Içerik ve dagitim otomasyonunun zaman kazancini nasıl carpana cevirdigine bakin.',
      badge: 'Içerik',
    },
  ],
  operations: [
    {
      href: '/vaka-calismalari/cemkimsan/',
      title: 'Cemkimsan vaka calismasi',
      description: 'Çok ulkeli satış ve pazarlama operasyonunda otomasyonun nasıl olceklendigini inceleyin.',
      badge: 'Operasyon',
    },
    {
      href: '/vaka-calismalari/erpa-teknoloji/',
      title: 'ERPA Teknoloji vaka calismasi',
      description: 'B2B araştırma ve Avrupa odakli lead generation tarafinda proof ariyorsaniz iyi bir referans.',
      badge: 'B2B',
    },
    {
      href: '/vaka-calismalari/car-studio-ai/',
      title: 'Car Studio AI vaka calismasi',
      description: 'Küçük ekiple daha fazla pazar ve daha hızlı akış kurmanin mantigini gorun.',
      badge: 'Ölçek',
    },
  ],
};

const nextStepMap = {
  growth: [
    {
      href: '/crm-programi/',
      title: 'CRM ve müşteri takibini guclendirin',
      description: 'Talep, mesaj ve gorusmeleri manuel veri girişi olmadan toplayan temel ticari yapı.',
      badge: 'Commercial',
    },
    {
      href: '/marketing-otomasyonu/',
      title: 'Lead akislarini hizlandirin',
      description: 'Form, reklam ve inbound trafigi gecikmeden otomasyon akislariyla karsilayin.',
      badge: 'Demand',
    },
    {
      href: '/whatsapp-ve-siparis-botlari/',
      title: 'WhatsApp üzerinden dönüşümü artırın',
      description: 'Mesajlasma tabanlı satış veya destek akislarinda daha hızlı cevap yapısı kurun.',
      badge: 'Conversation',
    },
  ],
  operations: [
    {
      href: '/on-muhasebe-ve-fatura/',
      title: 'Muhasebe ve fatura akislarini otomatikleştirin',
      description: 'Belge okuma, kayit ve aktarim tarafindaki manuel yukleri azaltan merkez sayfa.',
      badge: 'Finance',
    },
    {
      href: '/teklif-hazirlama-programi/',
      title: 'Teklif surecini hizlandirin',
      description: 'Excel tabanlı teklif ve fiyatlama süreçlerini daha kontrollu hale getirin.',
      badge: 'Quoting',
    },
    {
      href: '/e-ticaret-ve-pazaryeri-otomasyonu/',
      title: 'E-ticaret operasyonunu toparlayin',
      description: 'Sipariş, fatura, kargo ve kanal akisini tek sistem mantigiyla ele alin.',
      badge: 'Commerce',
    },
  ],
};

const growthSignals = [
  '/crm-programi/',
  '/marketing-otomasyonu/',
  '/whatsapp-ve-siparis-botlari/',
  '/yapay-zeka-chatbot/',
  '/b2b-musteri-bulma/',
  '/kurumsal-e-posta-otomasyonu/',
  '/cozumler/emlak/',
  '/cozumler/hukuk/',
  '/cozumler/e-ticaret/',
];

const selectedTrack = growthSignals.some((signal) => pathname.startsWith(signal)) ? 'growth' : 'operations';
const proofCases = proofCaseMap[selectedTrack];
const nextSteps = nextStepMap[selectedTrack];
const contactHref = (cta: string) => selectedTrack === 'growth' ? growthContactHref(cta) : operationsContactHref(cta);

const offerMap = {
  growth: {
    badge: 'Lead audit',
    title: 'Ilk gorusmede ne alirsiniz?',
    description: 'Talep akisinin nerede koptugunu, hangi kanalin gerçekten is urettigini ve hangi otomasyon adiminin en hızlı geri dönüş saglayacagini cikaririz.',
    bullets: [
      'Lead kaynagi ve ilk temas hizi analizi',
      'CRM, form, WhatsApp ve takip akışında kopus noktalarinin tespiti',
      'Size uygun ilk otomasyon senaryosu',
    ],
    cta: 'Lead akış analizini iste',
  },
  operations: {
    badge: 'Operasyon analizi',
    title: 'Ilk gorusmede ne alirsiniz?',
    description: 'Manuel veri girisinin, onay beklemelerinin ve ekipler arasi tekrar isin nerede olustugunu netlestirir; ilk otomasyon dugumunu birlikte seceriz.',
    bullets: [
      'Süreç haritası ve darboagaz tespiti',
      'Belge, onay ve takip akışında tekrar eden adimlarin ayrimi',
      'En hızlı geri dönüş verecek ilk kurulum önerisi',
    ],
    cta: 'Operasyon analizini iste',
  },
};

const currentOffer = offerMap[selectedTrack];

const faqSchema = faqs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqs.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: heroTitle,
  description,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Pratik Yapay Zeka',
    url: Astro.site?.toString() || 'https://yapayzekapratik.com',
  },
  areaServed: [
    { '@type': 'Country', name: 'Türkiye' },
    { '@type': 'Country', name: 'Deutschland' },
  ],
  serviceType: `${sectorName} Yapay Zeka Otomasyonu`,
};
---

<BaseLayout title={title} description={description} ogImage={ogImage} breadcrumbs={breadcrumbs}>
  <style is:inline>
    .theme-text { color: var(--themePrimary); }
    .theme-border { border-color: var(--themePrimary); }
    .theme-bg { background-color: var(--themePrimary); color: var(--color-void-ink-deep) !important; }
    .theme-glow-bg { background: radial-gradient(circle, var(--themeGlow) 0%, transparent 70%); }
    .theme-btn { background-color: var(--themePrimary); color: var(--color-void-ink-deep); }
    .theme-btn:hover { background-color: var(--themeAccent); box-shadow: 0 0 25px var(--themeGlow); }

    body {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
  </style>

  <main
    class="relative overflow-hidden bg-[var(--color-void-ink-deep)] text-[var(--color-paper-ecru)] selection:bg-[var(--themePrimary)] selection:text-[var(--color-void-ink-deep)]"
    style={`--themePrimary: ${currentTheme.primary}; --themeAccent: ${currentTheme.accent}; --themeGlow: ${currentTheme.glow}; --color-primary: ${currentTheme.primary}; --color-primary-dark: ${currentTheme.accent};`}
  >
    <article>
      <section data-santral-reveal class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
        <div class="pointer-events-none absolute -top-32 right-[-10%] h-[420px] w-[520px] rounded-full opacity-[0.14] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>

        <div class="container relative z-10 mx-auto max-w-6xl px-6 lg:px-10">
          <div class="flex flex-col gap-10 md:flex-row md:items-start md:gap-16">
            <aside class="md:w-[260px] md:shrink-0 md:pt-3">
              <span class="santral-overline block">
                {sectorTheme !== 'default' ? `${sectorTheme.split('-').join(' ')} · Modül` : 'Çözüm · Modül'}
              </span>
              <div class="mt-4 flex items-center gap-3" aria-hidden="true">
                <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
                <span class="h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)]" style="animation: morse-pulse 2.6s ease-in-out infinite"></span>
                <span class="h-[1px] flex-1 bg-[var(--color-hairline-strong)]"></span>
              </div>
              <p class="mt-5 font-mono text-[0.72rem] leading-relaxed tracking-[0.14em] uppercase text-[var(--color-paper-ecru-mute)]">
                HAT · AÇIK<br/>
                KURULUM · Hızlı<br/>
                GARANTİ · %50
              </p>
            </aside>
            <div class="flex-1 max-w-3xl">
              <h1 class="santral-display text-4xl leading-[1.05] md:text-6xl lg:text-[3.8rem]" style="font-weight:400;text-wrap:balance;">
                {heroTitle}
              </h1>
              <p class="mt-8 santral-body text-lg md:text-xl max-w-2xl">
                {heroSubtitle}
              </p>
              <div class="mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                <a href={contactHref('solution-hero-cta')} class="santral-salter santral-salter-copper">
                  Sistemi kurun
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
                  </svg>
                </a>
                <a href="/vaka-calismalari/" class="santral-salter">
                  Vaka çalışmalarını gör
                </a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
        <div class="container mx-auto max-w-6xl px-6 lg:px-10">
          <div class="mb-12 flex items-center gap-4">
            <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
            <span class="santral-overline">Kazanım · 01 — Ölçülebilir</span>
          </div>
          <div class="mb-14 max-w-3xl">
            <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">
              {benefitsTitle || 'Ölçülebilir operasyonel kazanımlar'}
            </h2>
            <p class="mt-5 santral-body text-lg">
              B2B süreçlerinize entegre edilen yapay zekanın gerçek dünya sonuçları.
            </p>
          </div>

          <div class="grid auto-rows-fr grid-cols-1 gap-5 md:grid-cols-3">
            {benefits.map((benefit, i) => {
              const safeBenefit = benefit ? benefit.toString() : '';
              const metricValueMatch = safeBenefit.match(/(\d+\/\d+|\+?%\d+(?:\.\d+)?|\d+x|\d+\+? saat|\d+ dakika|\d+\+?)/i);
              const massiveMetric = metricValueMatch ? metricValueMatch[0] : '';
              const remainingText = safeBenefit.replace(massiveMetric, '').trim();

              return (
                <article class="santral-hat flex h-full flex-col p-7 lg:p-8">
                  <span class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">
                    Kazanım · {String(i + 1).padStart(2, '0')}
                  </span>
                  {massiveMetric ? (
                    <>
                      <div class="mt-5 santral-display text-4xl md:text-5xl lg:text-[3.5rem] text-[var(--color-patina-copper-bright)]" style="font-weight:500;letter-spacing:-0.02em">{massiveMetric}</div>
                      <p class="mt-4 flex-grow santral-body text-[0.98rem] leading-[1.65]">{remainingText}</p>
                    </>
                  ) : (
                    <p class="mt-5 flex-grow santral-body text-[0.98rem] leading-[1.65]" set:html={safeBenefit.replace(/(\d+\/\d+|\+?%\d+(?:'[a-z]+|\.\d+)?|\d+x|\d+\+? saat|\d+ dakika|\d+\+?|%[0-9.]+)/gi, '<strong class="santral-display text-2xl md:text-3xl block mb-2 text-[var(--color-patina-copper-bright)]" style="font-weight:500">$1</strong>')} />
                  )}
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
        <div class="container mx-auto max-w-6xl px-6 lg:px-10">
          <div class="mb-12 flex items-center gap-4">
            <span class="h-[1px] w-10 bg-[var(--color-ink-bleed)]"></span>
            <span class="santral-overline" style="color: var(--color-ink-bleed)">Tanı · 02 — Kanama Noktaları</span>
          </div>
          <div class="mb-14 max-w-3xl">
            <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">
              Mevcut sistemdeki <em class="santral-italic" style="color: var(--color-ink-bleed)">kanama noktaları</em>
            </h2>
          </div>

          <div class="grid auto-rows-fr grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {problems.map((problem, i) => (
              <article class="santral-hat p-7 lg:p-8" style="border-left: 3px solid var(--color-ink-bleed)">
                <div class="flex items-center justify-between mb-5">
                  <span class="inline-flex items-center gap-2 font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-ink-bleed)]">
                    <span class="inline-block h-[5px] w-[5px] rounded-full bg-[var(--color-ink-bleed)]" style="animation: morse-pulse 2.4s ease-in-out infinite"></span>
                    Hata · {String(i + 1).padStart(2, '0')}
                  </span>
                </div>
                <p class="santral-body text-base md:text-lg leading-[1.65]">{problem}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
        <div class="container mx-auto max-w-6xl px-6 lg:px-10">
          <div class="mb-12 flex items-center gap-4">
            <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
            <span class="santral-overline">Süreç · 03 — Kurulum</span>
          </div>
          <div class="mb-16 max-w-3xl">
            <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">{processTitle}</h2>
            <p class="mt-5 santral-body text-lg">Tahmine değil, veriye dayalı mimari kurulum süreci.</p>
          </div>

          <div class="grid grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-4">
            {processSteps.map((step, i) => (
              <article class="santral-hat group relative flex h-full flex-col p-7 lg:p-8">
                <div class="mb-6 flex items-start justify-between">
                  <div class="flex h-12 w-12 items-center justify-center border border-[var(--color-hairline-strong)] bg-[var(--color-void-ink-deep)] santral-display text-xl text-[var(--color-patina-copper-bright)] transition-all group-hover:border-[var(--color-patina-copper-bright)]" style="font-weight:500;border-radius:2px">
                    {i + 1}
                  </div>
                  <span class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım</span>
                </div>
                <h3 class="santral-display text-xl md:text-[1.35rem]" style="font-weight:500;letter-spacing:-0.01em">{step.title}</h3>
                <p class="mt-3 text-[0.9rem] leading-[1.6] text-[var(--color-paper-ecru-dim)]">{step.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
        <div class="container mx-auto max-w-6xl px-6 lg:px-10">
          <div class="mb-12 flex items-center gap-4">
            <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
            <span class="santral-overline">Özellik · 04 — Bento</span>
          </div>
          <div class="mb-14 max-w-3xl">
            <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">{featuresTitle}</h2>
          </div>

          <div class="grid auto-rows-fr grid-cols-1 gap-5 md:grid-cols-2 lg:grid-cols-3">
            {features.map((feature, index) => (
              <article class={`santral-hat group flex h-full flex-col p-7 lg:p-8 ${index === 0 ? 'md:col-span-2' : ''} ${index === 3 && features.length > 3 ? 'md:col-span-2 lg:col-span-1' : ''}`}>
                <div class="mb-5 flex items-center justify-between">
                  <div class="flex h-11 w-11 items-center justify-center border border-[var(--color-hairline-strong)] bg-[var(--color-void-ink-deep)] text-[var(--color-patina-copper-bright)]" style="border-radius:2px">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 256 256"><path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path></svg>
                  </div>
                  <span class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">
                    Modül · {String(index + 1).padStart(2, '0')}
                  </span>
                </div>
                <h3 class="santral-display text-xl md:text-[1.35rem]" style="font-weight:500;letter-spacing:-0.01em">{feature.title}</h3>
                <p class="mt-3 santral-body text-base leading-[1.65]">{feature.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      {faqs.length > 0 && (
        <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
          <div class="container mx-auto max-w-5xl px-6 lg:px-10">
            <div class="mb-12 flex items-center gap-4">
              <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
              <span class="santral-overline">Talimatname · 06 — Sık Sorulanlar</span>
            </div>
            <h2 class="mb-12 santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">
              Sıkça Sorulan <em class="santral-italic">Sorular</em>
            </h2>
            <div class="space-y-3">
              {faqs.map((faq, i) => (
                <details class="santral-hat group overflow-hidden">
                  <summary class="flex cursor-pointer items-start justify-between gap-4 p-6 transition-colors list-none">
                    <span class="flex items-start gap-4">
                      <span class="font-mono text-[0.72rem] tracking-[0.14em] text-[var(--color-paper-ecru-mute)] pt-1 shrink-0">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <span class="santral-display text-base md:text-lg text-[var(--color-paper-ecru)] group-open:text-[var(--color-patina-copper-bright)] transition-colors" style="font-weight:500">
                        {faq.question}
                      </span>
                    </span>
                    <svg class="h-5 w-5 shrink-0 text-[var(--color-paper-ecru-mute)] transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m-8-8h16" />
                    </svg>
                  </summary>
                  <div class="px-6 pb-6 pl-16 text-[0.95rem] leading-[1.72] text-[var(--color-paper-ecru-dim)]">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </section>
      )}

      <ROICalculator client:visible sectorName={sectorName} />

      <LeadPathways
        title="Bu sayfadan sonra ziyaretciyi kaybetmeyin"
        description="Sorunu anlayan biri genelde iki seye bakar: buna dair gerçek proof var mi ve bir sonraki mantikli sayfa hangisi. Bu blok o geçişi kolaylastirir."
        caseStudies={proofCases}
        nextSteps={nextSteps}
        contactHref={contactHref('solution-lead-pathways')}
      />

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-20 md:py-24">
        <div class="container mx-auto max-w-6xl px-6 lg:px-10">
          <div class="santral-hat p-8 md:p-10" style="border-color: rgba(224, 150, 84, 0.28)">
            <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
              <div class="max-w-2xl">
                <span class="santral-overline block" style="color: var(--color-patina-copper-bright)">{currentOffer.badge}</span>
                <h2 class="mt-4 santral-display text-3xl md:text-4xl" style="font-weight:500;text-wrap:balance">{currentOffer.title}</h2>
                <p class="mt-4 santral-body text-base md:text-lg">{currentOffer.description}</p>
              </div>

              <a href={contactHref('solution-offer-panel')} class="santral-salter santral-salter-copper shrink-0">
                {currentOffer.cta}
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
                </svg>
              </a>
            </div>

            <div class="mt-8 grid gap-4 md:grid-cols-3 pt-6 border-t border-[var(--color-hairline)]">
              {currentOffer.bullets.map((item, i) => (
                <div class="flex items-start gap-3">
                  <span class="font-mono text-[0.72rem] tracking-[0.14em] text-[var(--color-patina-copper-bright)] pt-[3px]">{String(i + 1).padStart(2, '0')}</span>
                  <p class="text-sm leading-[1.6] text-[var(--color-paper-ecru-dim)]">{item}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-24 md:py-32">
        <div class="container relative z-10 mx-auto max-w-4xl px-6 lg:px-10 text-center">
          <div class="mb-8 flex items-center justify-center gap-4">
            <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
            <span class="santral-overline">Başlatma · Sonraki Adım</span>
            <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
          </div>

          <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">{finalCtaTitle}</h2>
          <p class="mt-6 santral-body max-w-2xl mx-auto">{finalCtaSubtitle}</p>

          <div class="mt-10 flex justify-center">
            <a href={contactHref('solution-final-cta')} class="santral-salter santral-salter-copper">
              Projeyi başlat
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
              </svg>
            </a>
          </div>
        </div>
      </section>
    </article>

    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    {schema && <script type="application/ld+json" set:html={schema} />}
  </main>
</BaseLayout>
