---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Araç Değer Kaybı Hesaplama | Filo Hasar ve Basvuru Takip Akışı';
const description = 'Araç değer kaybı ihtiyacı çoğu zaman tek tutar hesaplamak değil; hasar dosyasini, evrak akisini ve basvuru takibini sistemli yonetmektir.';
const keywords = 'araç değer kaybı hesaplama, filo hasar takibi, sigorta basvurusu, hasar dosyasi, değer kaybı süreci';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi değer kaybı hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayır. Bu sayfa, araç değer kaybı sürecinin neden evrak, hasar kaydi ve basvuru takibi odakli olduğunu anlatır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asıl sorun hangi noktada buyur?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asıl sorun genelde tek rakamı bulmakta değil; hasar evraklarini toparlamak, dosya durumunu izlemek ve basvuru surecini geciktirmeden ilerletmektir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler için daha anlamlidir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Birden fazla araç veya tekrar eden hasar dosyasi olan filo ekipleri ve operasyonel takip yukü yüksek yapilar için daha anlamlidir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Filo Hasar ve Dosya Takibi</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Araç Değer Kaybı Konusunu Tek Hesap Yerine Dosya ve Basvuru Süreci Olarak Yönetin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Araç değer kaybı ihtiyacı tek bir tahmini tutardan ibaret değildir. Özellikle filo veya tekrar eden hasar dosyalarinda asıl zorluk, hasar bilgisini toplamak, ilgili evrakları duzenlemek ve dosya durumunu geciktirmeden takip etmektir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Hasar Bilgisi</h2>
        <p class="text-muted-foreground">Kaza, rapor, servis ve eksper bilgisi farklı yerlerde dağinik kalabilir.</p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Evrak Akışı</h2>
        <p class="text-muted-foreground">Basvuru için gereken belgeler eksik veya gec toplaniyorsa süreç agirlasir.</p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Dosya Takibi</h2>
        <p class="text-muted-foreground">Hangi dosyanin hangi aşamada olduğu görünmüyorsa hak kaybı ve zaman kaybı riski artar.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-sm border border-border">
      <h2 class="text-2xl font-semibold mb-6">Araç Değer Kaybı Sürecinin Zorlastigi Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Filo yapilarinda:</strong> Birden fazla dosya ayni anda ilerlediginde takip kişilere dağılabilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Evrak yogun sureclerde:</strong> Eksper, servis ve sigorta arasindaki bilgi akışı yavaslayabilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Takip eksikliginde:</strong> Dosyanin hangi aşamada takildigi gec fark edilir.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Işaret Ettigi Asıl Çözüm</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Araç değer kaybı konusu bizim için bir hasar dosyasi ve basvuru takibi problemidir. Değer, tahmini tutar vermekten çok hasar verisini toparlamak, evrak akislarini görünür hale getirmek ve dosyayi sonuca daha düzenli tasimakta ortaya çıkar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Hasar Dosyasi Toplama</h3>
          <p class="text-sm text-muted-foreground">Kaza ve onarim bilgisi daha tekil bir dosya mantiginda toplanir.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Evrak Kontrolu</h3>
          <p class="text-sm text-muted-foreground">Eksik belge ve geciken adımlar daha erken fark edilir.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Basvuru Takibi</h3>
          <p class="text-sm text-muted-foreground">Dosyanin hangi aşamada olduğu ve sonraki adım daha net gorulur.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi değer kaybı hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayır. Bu sayfa, araç değer kaybı sürecinin neden evrak, hasar kaydi ve basvuru takibi odakli olduğunu anlatır.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asıl sorun hangi noktada buyur?</h3>
          <p class="text-muted-foreground">Asıl sorun genelde tek rakamı bulmakta değil; hasar evraklarini toparlamak ve dosya durumunu düzenli takip etmektedir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler için daha anlamlidir?</h3>
          <p class="text-muted-foreground">Birden fazla araç veya tekrar eden hasar dosyasi olan filo ekipleri için daha anlamlidir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
