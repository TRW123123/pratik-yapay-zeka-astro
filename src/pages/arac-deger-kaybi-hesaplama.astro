---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Arac Deger Kaybi Hesaplama | Filo Hasar ve Basvuru Takip Akisi';
const description = 'Arac deger kaybi ihtiyaci cogu zaman tek tutar hesaplamak degil; hasar dosyasini, evrak akisini ve basvuru takibini sistemli yonetmektir.';
const keywords = 'arac deger kaybi hesaplama, filo hasar takibi, sigorta basvurusu, hasar dosyasi, deger kaybi sureci';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi deger kaybi hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa, arac deger kaybi surecinin neden evrak, hasar kaydi ve basvuru takibi odakli oldugunu anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asil sorun hangi noktada buyur?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asil sorun genelde tek rakami bulmakta degil; hasar evraklarini toparlamak, dosya durumunu izlemek ve basvuru surecini geciktirmeden ilerletmektir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler icin daha anlamlidir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Birden fazla arac veya tekrar eden hasar dosyasi olan filo ekipleri ve operasyonel takip yukü yuksek yapilar icin daha anlamlidir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Filo Hasar ve Dosya Takibi</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Arac Deger Kaybi Konusunu Tek Hesap Yerine Dosya ve Basvuru Sureci Olarak Yonetin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Arac deger kaybi ihtiyaci tek bir tahmini tutardan ibaret degildir. Ozellikle filo veya tekrar eden hasar dosyalarinda asil zorluk, hasar bilgisini toplamak, ilgili evraklari duzenlemek ve dosya durumunu geciktirmeden takip etmektir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Hasar Bilgisi</h2>
        <p class="text-muted-foreground">Kaza, rapor, servis ve eksper bilgisi farkli yerlerde dağinik kalabilir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Evrak Akisi</h2>
        <p class="text-muted-foreground">Basvuru icin gereken belgeler eksik veya gec toplaniyorsa surec agirlasir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Dosya Takibi</h2>
        <p class="text-muted-foreground">Hangi dosyanin hangi asamada oldugu görünmüyorsa hak kaybi ve zaman kaybi riski artar.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Arac Deger Kaybi Surecinin Zorlastigi Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Filo yapilarinda:</strong> Birden fazla dosya ayni anda ilerlediginde takip kişilere dağılabilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Evrak yogun sureclerde:</strong> Eksper, servis ve sigorta arasindaki bilgi akisi yavaslayabilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Takip eksikliginde:</strong> Dosyanin hangi asamada takildigi gec fark edilir.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asil Cozum</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Arac deger kaybi konusu bizim icin bir hasar dosyasi ve basvuru takibi problemidir. Deger, tahmini tutar vermekten cok hasar verisini toparlamak, evrak akislarini gorunur hale getirmek ve dosyayi sonuca daha duzenli tasimakta ortaya cikar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Hasar Dosyasi Toplama</h3>
          <p class="text-sm text-muted-foreground">Kaza ve onarim bilgisi daha tekil bir dosya mantiginda toplanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Evrak Kontrolu</h3>
          <p class="text-sm text-muted-foreground">Eksik belge ve geciken adimlar daha erken fark edilir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Basvuru Takibi</h3>
          <p class="text-sm text-muted-foreground">Dosyanin hangi asamada oldugu ve sonraki adim daha net gorulur.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi deger kaybi hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa, arac deger kaybi surecinin neden evrak, hasar kaydi ve basvuru takibi odakli oldugunu anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asil sorun hangi noktada buyur?</h3>
          <p class="text-muted-foreground">Asil sorun genelde tek rakami bulmakta degil; hasar evraklarini toparlamak ve dosya durumunu duzenli takip etmektedir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler icin daha anlamlidir?</h3>
          <p class="text-muted-foreground">Birden fazla arac veya tekrar eden hasar dosyasi olan filo ekipleri icin daha anlamlidir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
