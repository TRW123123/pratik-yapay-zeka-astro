---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { sanitizeHtml } from '../../lib/sanitizeHtml';
import type { BlogPost } from '../../lib/supabase';
import { marked } from 'marked';

interface LinkCard {
  href: string;
  title: string;
  description: string;
  badge?: string;
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/blog/');
}

const { data, error } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('language', 'tr')
  .eq('status', 'published')
  .maybeSingle();

if (error || !data) {
  return Astro.redirect('/404');
}

const post = data as BlogPost;
const rawHtmlContent = await marked(post.content);
let htmlContent = sanitizeHtml(rawHtmlContent);

// Add slug IDs to all H2 headings for ToC anchors
function turkishSlug(s: string): string {
  return s
    .toLowerCase()
    .replace(/ğ/g, 'g').replace(/ü/g, 'u').replace(/ş/g, 's')
    .replace(/ı/g, 'i').replace(/İ/g, 'i').replace(/ö/g, 'o').replace(/ç/g, 'c')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .substring(0, 60);
}

const tocItems: { id: string; text: string }[] = [];
htmlContent = htmlContent.replace(/<h2>([^<]+)<\/h2>/g, (_, text: string) => {
  const id = turkishSlug(text);
  tocItems.push({ id, text });
  return `<h2 id="${id}">${text}</h2>`;
});
const formattedDate = new Date(post.published_at || post.created_at || '').toLocaleDateString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const topicalText = [post.title, post.excerpt, post.category, ...(post.tags || [])]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();

const isGrowth = /(lead|marketing|pazarlama|linkedin|outbound|email|crm|satis|musteri)/.test(topicalText);
const isFinance = /(muhasebe|fatura|tahsilat|finans|beyan|kdv|vergi|mutabakat|cari)/.test(topicalText);
const isHr = /(ik|insan kaynak|bordro|maas|sgk|izin|mesai|tazminat)/.test(topicalText);

const relatedSolutions: LinkCard[] = isFinance
  ? [
      {
        href: '/on-muhasebe-ve-fatura/',
        title: 'On muhasebe ve fatura otomasyonu',
        description: 'Belge, veri girisi ve kontrol akislarini daha sistemli hale getirin.',
        badge: 'Finance',
      },
      {
        href: '/mutabakat-mektubu/',
        title: 'Mutabakat ve takip akislarini kurun',
        description: 'Ay sonu kapanis ve takip yukunu azaltan daha operasyonel sayfa.',
        badge: 'Follow-up',
      },
      {
        href: '/e-beyanname/',
        title: 'Uyum ve beyan akislarini guclendirin',
        description: 'Beyan, kontrol ve dokuman sureclerinde tekrar isi azaltin.',
        badge: 'Compliance',
      },
    ]
  : isHr
    ? [
        {
          href: '/maas-hesaplama-motoru/',
          title: 'IK ve bordro akislarini toparlayin',
          description: 'Tekil hesaplardan ekip ici surec otomasyonuna gecis icin ana giris sayfasi.',
          badge: 'HR',
        },
        {
          href: '/bordro-hesaplama/',
          title: 'Bordro destek akislarini sadeletin',
          description: 'Tekrarlayan maas, puantaj ve personel taleplerini duzenli yonetin.',
          badge: 'Payroll',
        },
        {
          href: '/sgk-hizmet-dokumu/',
          title: 'Belge ve personel dogrulama akislarini iyilestirin',
          description: 'IK ekiplerinde belge tabanli tekrar isi azaltmak icin.',
          badge: 'Ops',
        },
      ]
    : [
        {
          href: '/marketing-otomasyonu/',
          title: 'Marketing otomasyonu',
          description: 'Form, icerik, outbound ve lead takip akislarini tek sistem mantiginda ele alin.',
          badge: 'Growth',
        },
        {
          href: '/crm-programi/',
          title: 'CRM programi',
          description: 'Gorusme, takip ve pipeline kayiplarini azaltan merkez sayfa.',
          badge: 'CRM',
        },
        {
          href: '/b2b-musteri-bulma/',
          title: 'B2B musteri bulma',
          description: 'Arastirma, hedef hesap secimi ve nitelikli outbound tarafini guclendirin.',
          badge: 'Outbound',
        },
      ];

const contactPackage = isFinance ? 'finans-operasyon-analizi' : isHr ? 'ik-surec-analizi' : 'lead-flow-audit';
const contactArea = isFinance ? 'finance-accounting' : isHr ? 'other' : 'marketing-leads';
const contactHref = `/iletisim/?kaynak=${encodeURIComponent(`/blog/${post.slug}/`)}&paket=${contactPackage}&alan=${contactArea}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.published_at || post.created_at,
  dateModified: post.published_at || post.created_at,
  author: {
    '@type': 'Person',
    name: post.author,
    ...(post.author_bio && { description: post.author_bio }),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Pratik Yapay Zeka',
    url: 'https://yapayzekapratik.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://yapayzekapratik.com/apple-touch-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://yapayzekapratik.com/blog/${post.slug}/`,
  },
  image: post.og_image_url || post.cover_image_url || 'https://yapayzekapratik.com/og-homepage.jpg',
  articleBody: post.content.substring(0, 500),
  keywords: (post.tags || []).join(', '),
  articleSection: post.category,
  inLanguage: 'tr-TR',
};

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.title, url: `/blog/${post.slug}/` },
];
---

<BaseLayout
  title={post.meta_title || `${post.title} | Pratik Yapay Zeka`}
  description={post.meta_description || post.excerpt}
  ogImage={post.og_image_url || post.cover_image_url || '/og-homepage.jpg'}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  {/* Reading Progress Bar — sticky top */}
  <div id="reading-progress" class="fixed left-0 top-0 z-50 h-[3px] w-0 bg-[var(--color-primary)] shadow-[0_0_16px_rgba(163,230,53,0.6)] transition-[width] duration-150 ease-out"></div>

  <article class="bg-[#0B0F14] py-16 lg:py-24">
    <div class="container mx-auto max-w-3xl px-4">
      <a href="/blog/" class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-primary-light)]">
        <span aria-hidden="true">←</span> Tüm blog yazıları
      </a>

      {/* Category + read-time eyebrow */}
      <div class="mb-6 flex items-center gap-3 font-mono text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">
        <span>{post.category || 'Rehber'}</span>
        <span class="text-[var(--color-border)]">·</span>
        <span class="text-[var(--color-text-muted)]">{post.read_time || 5} dakika okuma</span>
      </div>

      <h1 class="mb-6 text-4xl font-extrabold md:text-5xl lg:text-6xl text-white leading-[1.04] tracking-tight">{post.title}</h1>

      {post.excerpt && (
        <p class="mb-10 text-xl text-[var(--color-text-muted)] md:text-2xl leading-[1.4]">{post.excerpt}</p>
      )}

      {/* Author card row — premium SVG avatar with gradient + ring */}
      <div class="author-row mb-12 flex flex-col gap-4 border-b border-[var(--color-border)]/60 pb-6 md:flex-row md:items-center">
        <div class="flex items-center gap-4">
          <div class="relative flex h-14 w-14 shrink-0 items-center justify-center">
            <svg class="absolute inset-0 h-full w-full" viewBox="0 0 56 56">
              <defs>
                <linearGradient id="avGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#a3e635" />
                  <stop offset="100%" stop-color="#65a30d" />
                </linearGradient>
              </defs>
              <circle cx="28" cy="28" r="27" fill="url(#avGrad)" />
              <circle cx="28" cy="28" r="27" fill="none" stroke="#d9f99d" stroke-width="0.5" opacity="0.4" />
            </svg>
            <span class="relative text-xl font-black text-[#0B0F14] tracking-tight">{(post.author || 'P').charAt(0)}</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="text-base font-semibold text-white">{post.author}</div>
            <div class="mt-0.5 text-sm text-[var(--color-text-muted)] line-clamp-2">
              {formattedDate} {post.author_bio ? `· ${post.author_bio.split('.')[0]}` : ''}
            </div>
          </div>
        </div>
        {(post.tags || []).length > 0 && (
          <div class="flex flex-wrap gap-1.5 md:ml-auto md:justify-end">
            {(post.tags || []).slice(0, 4).map((tag) => (
              <span class="tag-pill rounded-full border border-[var(--color-primary)]/25 px-2.5 py-0.5 text-xs font-medium text-[var(--color-primary-light)] transition-all">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>

      {post.cover_image_url && (
        <img
          src={post.cover_image_url}
          alt={post.cover_image_alt || post.title}
          class="blog-hero-image mb-16 h-auto rounded-2xl"
        />
      )}

      {/* Sticky ToC sidebar (desktop only) */}
      {tocItems.length > 2 && (
        <nav aria-label="İçindekiler" class="blog-toc pointer-events-none fixed top-24 left-6 z-20 hidden w-64 xl:block">
          <div class="pointer-events-auto rounded-xl border border-[var(--color-border)] bg-[var(--color-surface-light)]/80 p-5 backdrop-blur-md">
            <div class="mb-3 font-mono text-[10px] font-bold uppercase tracking-[0.2em] text-[var(--color-primary)]">İçindekiler</div>
            <ul class="space-y-2.5">
              {tocItems.map((item, idx) => (
                <li>
                  <a
                    href={`#${item.id}`}
                    data-toc-target={item.id}
                    class="toc-link group flex gap-2.5 text-sm text-[var(--color-text-muted)] transition-colors hover:text-white"
                  >
                    <span class="font-mono text-[11px] text-[var(--color-primary)]/60 group-hover:text-[var(--color-primary)]">
                      {String(idx + 1).padStart(2, '0')}
                    </span>
                    <span class="leading-[1.35]">{item.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </nav>
      )}

      <div
        class="blog-content prose prose-invert prose-lg max-w-none prose-headings:text-white prose-headings:font-semibold prose-p:text-[var(--color-text-muted)] prose-a:text-[var(--color-primary-light)] prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-code:rounded prose-code:bg-[var(--color-surface-light)] prose-code:px-1.5 prose-code:py-0.5 prose-code:text-[var(--color-primary-light)] prose-pre:rounded-xl prose-pre:border prose-pre:border-[var(--color-border)] prose-pre:bg-[var(--color-surface-light)] prose-blockquote:border-[var(--color-primary)] prose-blockquote:text-[var(--color-text-muted)] prose-li:text-[var(--color-text-muted)] prose-img:rounded-xl"
        set:html={htmlContent}
      />

      <style is:global>
        /* ================ Blog Reading Experience ================ */

        /* Full-bleed hero + inline images — viewport breakout */
        .blog-hero-image,
        .blog-content img {
          display: block;
          width: min(1400px, calc(100vw - 4rem));
          max-width: none;
          position: relative;
          left: 50%;
          transform: translateX(-50%);
          margin-top: 3rem;
          margin-bottom: 3rem;
          border: 1px solid var(--color-border);
          border-radius: 16px;
        }
        .blog-hero-image {
          margin-top: 0;
          margin-bottom: 4rem;
        }

        /* Hide duplicate first-h1 in markdown body */
        .blog-content > h1:first-child { display: none; }

        /* H2 section headers — numbered, lime underline accent */
        .blog-content {
          counter-reset: section;
        }
        .blog-content h2 {
          counter-increment: section;
          position: relative;
          margin-top: 4rem !important;
          margin-bottom: 1.5rem !important;
          padding-top: 2rem;
          padding-left: 0;
          font-size: 2.25rem !important;
          line-height: 1.15 !important;
          letter-spacing: -0.02em;
          border-top: 1px solid var(--color-border);
        }
        .blog-content h2::before {
          content: counter(section, decimal-leading-zero);
          display: block;
          margin-bottom: 0.5rem;
          font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
          font-size: 0.75rem;
          font-weight: 700;
          letter-spacing: 0.2em;
          color: var(--color-primary);
          text-transform: uppercase;
        }

        /* H3 sub-headings */
        .blog-content h3 {
          margin-top: 2.5rem !important;
          font-size: 1.5rem !important;
          color: white !important;
        }

        /* First paragraph after H2 = lead — larger, brighter, italic-feel */
        .blog-content h2 + p {
          font-size: 1.25rem !important;
          line-height: 1.5 !important;
          color: rgba(229, 231, 235, 0.92) !important;
          margin-top: 1rem !important;
          margin-bottom: 1.75rem !important;
        }
        .blog-content h2 + p::first-letter {
          font-size: 1.45em;
          font-weight: 700;
          color: var(--color-primary);
        }

        /* Blockquote → callout */
        .blog-content blockquote {
          position: relative;
          margin: 2.5rem 0 !important;
          padding: 1.5rem 1.5rem 1.5rem 2rem !important;
          border-left: 4px solid var(--color-primary) !important;
          border-radius: 0 12px 12px 0;
          background: linear-gradient(90deg, rgba(163, 230, 53, 0.08) 0%, rgba(163, 230, 53, 0) 60%);
          font-style: normal !important;
          font-size: 1.15rem;
          line-height: 1.55;
          color: white !important;
        }
        .blog-content blockquote p {
          color: white !important;
        }

        /* Horizontal rule as visual break */
        .blog-content hr {
          margin: 3.5rem auto !important;
          width: 40%;
          border: none;
          border-top: 1px solid var(--color-border);
          opacity: 0.5;
        }

        /* Lists spacing */
        .blog-content ul li,
        .blog-content ol li {
          margin: 0.5rem 0 !important;
          line-height: 1.65;
        }

        /* Strong emphasis */
        .blog-content strong {
          color: white !important;
          font-weight: 700;
        }

        /* Link styling in content */
        .blog-content a {
          color: var(--color-primary-light) !important;
          text-decoration: none !important;
          border-bottom: 1px solid var(--color-primary)/30;
          transition: all 0.15s;
        }
        .blog-content a:hover {
          color: var(--color-primary) !important;
          border-bottom-color: var(--color-primary);
        }

        /* Smooth scroll for ToC anchors */
        html { scroll-behavior: smooth; scroll-padding-top: 6rem; }

        /* ToC link hover micro-interaction */
        .toc-link {
          padding: 4px 0;
          transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), color 0.15s;
        }
        .toc-link:hover {
          transform: translateX(4px);
        }
        .toc-link.is-active {
          color: white !important;
          transform: translateX(2px);
        }
        .toc-link.is-active span:first-child {
          color: var(--color-primary) !important;
          font-weight: 700;
        }
        .toc-link.is-active::before {
          content: '';
          position: absolute;
          left: -16px;
          top: 50%;
          width: 8px;
          height: 8px;
          border-radius: 50%;
          background: var(--color-primary);
          box-shadow: 0 0 16px rgba(163, 230, 53, 0.7);
          transform: translateY(-50%);
        }
        .toc-link {
          position: relative;
        }

        /* Tag pill hover */
        .tag-pill:hover {
          background: rgba(163, 230, 53, 0.12);
          border-color: var(--color-primary) !important;
          color: var(--color-primary) !important;
        }

        /* CTA button glow + scale */
        .cta-btn {
          transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.2s;
        }
        .cta-btn:hover {
          transform: translateY(-2px) scale(1.02);
          box-shadow: 0 0 48px rgba(163, 230, 53, 0.55);
        }

        /* Mobile adjustments */
        @media (max-width: 1100px) {
          .blog-hero-image,
          .blog-content img {
            width: 100%;
            left: 0;
            transform: none;
          }
        }
        @media (max-width: 768px) {
          .blog-content h2 {
            font-size: 1.75rem !important;
            margin-top: 3rem !important;
          }
          .blog-content h2 + p {
            font-size: 1.1rem !important;
          }
          .blog-content blockquote {
            font-size: 1.05rem;
            padding: 1.25rem 1.25rem 1.25rem 1.5rem !important;
          }
          .blog-hero-image,
          .blog-content img {
            margin-top: 2rem;
            margin-bottom: 2rem;
          }
        }
      </style>

      {/* Final CTA Block after content */}
      <div class="mt-20 overflow-hidden rounded-3xl border border-[var(--color-primary)]/30 bg-gradient-to-br from-[var(--color-primary)]/10 via-[var(--color-surface-light)] to-[var(--color-surface-light)] p-8 md:p-12">
        <div class="mb-4 font-mono text-[11px] font-bold uppercase tracking-[0.2em] text-[var(--color-primary)]">
          Sıradaki adım
        </div>
        <h3 class="mb-4 text-2xl font-extrabold text-white md:text-3xl leading-[1.15]">
          Bu yazının içeriğini kendi şirketinize uyarlayalım.
        </h3>
        <p class="mb-8 max-w-2xl text-[var(--color-text-muted)] md:text-lg leading-[1.55]">
          45 dakikalık ücretsiz görüşmede şirketinizdeki süreçleri birlikte haritalayıp, hangi otomasyonun size en hızlı geri dönüş sağlayacağını net söyleriz. Baskı yok — sadece sayısal bir analiz.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <a href="/iletisim/" class="cta-btn inline-flex items-center gap-2 rounded-full bg-[var(--color-primary)] px-7 py-3.5 text-base font-bold text-[#0B0F14] shadow-[0_0_32px_rgba(163,230,53,0.4)]">
            Ücretsiz analizi talep et <span aria-hidden="true">→</span>
          </a>
          <div class="text-sm text-[var(--color-text-muted)]">
            <span class="text-[var(--color-primary)] font-bold">%50 Geri İade Garantisi</span> · Hedef tutmazsa yarısı iade
          </div>
        </div>
      </div>

      {/* Reading progress + ToC scroll spy */}
      <script is:inline>
        (function () {
          const progressEl = document.getElementById('reading-progress');
          const article = document.querySelector('article');
          const tocLinks = document.querySelectorAll('.toc-link');
          const headings = document.querySelectorAll('.blog-content h2[id]');

          function onScroll() {
            if (article && progressEl) {
              const rect = article.getBoundingClientRect();
              const total = article.offsetHeight - window.innerHeight;
              const scrolled = Math.min(Math.max(-rect.top, 0), total);
              const pct = total > 0 ? (scrolled / total) * 100 : 0;
              progressEl.style.width = pct + '%';
            }
            if (tocLinks.length && headings.length) {
              let active = null;
              headings.forEach((h) => {
                const r = h.getBoundingClientRect();
                if (r.top < 160) active = h.id;
              });
              tocLinks.forEach((l) => {
                if (l.dataset.tocTarget === active) l.classList.add('is-active');
                else l.classList.remove('is-active');
              });
            }
          }
          document.addEventListener('scroll', onScroll, { passive: true });
          onScroll();
        })();
      </script>

      {post.author_bio && (
        <div class="mt-12 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-light)] p-6">
          <h2 class="mb-2 text-lg font-semibold text-white">Yazar hakkinda</h2>
          <p class="text-[var(--color-text-muted)]">{post.author_bio}</p>
        </div>
      )}

      <div class="mt-16 grid gap-8 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="rounded-[2rem] border border-[var(--color-border)] bg-[var(--color-surface-light)]/60 p-8">
          <h2 class="text-2xl font-semibold text-white">Ilgili sonraki sayfalar</h2>
          <div class="mt-6 space-y-4">
            {relatedSolutions.map((item) => (
              <a href={item.href} class="block rounded-2xl border border-[var(--color-border)] bg-black/10 p-5 transition hover:-translate-y-0.5 hover:border-[var(--color-primary)]/40">
                {item.badge && (
                  <div class="mb-3 inline-flex rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]">
                    {item.badge}
                  </div>
                )}
                <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[var(--color-text-muted)]">{item.description}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-[2rem] border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/8 p-8">
          <div class="inline-flex rounded-full border border-[var(--color-primary)]/25 bg-[var(--color-primary)]/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]">
            Donusum
          </div>
          <h2 class="mt-5 text-3xl font-black tracking-tight text-white">Bu konuyu kendi surecinize uygulamak ister misiniz?</h2>
          <p class="mt-4 text-sm leading-relaxed text-[var(--color-text-muted)]">
            Kisa bir analiz ile bu yazidaki fikrin sizin ekipte nerede en hizli geri donus uretecegini birlikte belirleyelim.
          </p>

          <ul class="mt-6 space-y-3 text-sm text-[var(--color-text-muted)]">
            <li>Sayfaya gore kaynak takibi</li>
            <li>Konuya uygun analiz paketi</li>
            <li>Somut sonraki adim onerisi</li>
          </ul>

          <a href={contactHref} class="mt-8 inline-flex w-full items-center justify-center rounded-2xl bg-[var(--color-primary)] px-5 py-4 text-center text-base font-black text-black transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-light)]">
            Ucretsiz analizi talep et
          </a>
        </div>
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
