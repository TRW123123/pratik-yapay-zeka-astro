---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { supabase } from '../../lib/supabase';
import { sanitizeHtml } from '../../lib/sanitizeHtml';
import type { BlogPost } from '../../lib/supabase';
import { marked } from 'marked';

interface LinkCard {
  href: string;
  title: string;
  description: string;
  badge?: string;
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/blog/');
}

const { data, error } = await supabase
  .from('blog_posts')
  .select('*')
  .eq('slug', slug)
  .eq('language', 'tr')
  .eq('status', 'published')
  .maybeSingle();

if (error || !data) {
  return Astro.redirect('/404');
}

const post = data as BlogPost;
const rawHtmlContent = await marked(post.content);
let htmlContent = sanitizeHtml(rawHtmlContent);

// Add slug IDs to all H2 headings for ToC anchors
function turkishSlug(s: string): string {
  return s
    .toLowerCase()
    .replace(/ğ/g, 'g').replace(/ü/g, 'u').replace(/ş/g, 's')
    .replace(/ı/g, 'i').replace(/İ/g, 'i').replace(/ö/g, 'o').replace(/ç/g, 'c')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '')
    .substring(0, 60);
}

const tocItems: { id: string; text: string }[] = [];
htmlContent = htmlContent.replace(/<h2>([^<]+)<\/h2>/g, (_, text: string) => {
  const id = turkishSlug(text);
  tocItems.push({ id, text });
  return `<h2 id="${id}">${text}</h2>`;
});
const formattedDate = new Date(post.published_at || post.created_at || '').toLocaleDateString('tr-TR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const topicalText = [post.title, post.excerpt, post.category, ...(post.tags || [])]
  .filter(Boolean)
  .join(' ')
  .toLowerCase();

const isGrowth = /(lead|marketing|pazarlama|linkedin|outbound|email|crm|satis|musteri)/.test(topicalText);
const isFinance = /(muhasebe|fatura|tahsilat|finans|beyan|kdv|vergi|mutabakat|cari)/.test(topicalText);
const isHr = /(ik|insan kaynak|bordro|maas|sgk|izin|mesai|tazminat)/.test(topicalText);

const relatedSolutions: LinkCard[] = isFinance
  ? [
      {
        href: '/on-muhasebe-ve-fatura/',
        title: 'On muhasebe ve fatura otomasyonu',
        description: 'Belge, veri girisi ve kontrol akislarini daha sistemli hale getirin.',
        badge: 'Finance',
      },
      {
        href: '/mutabakat-mektubu/',
        title: 'Mutabakat ve takip akislarini kurun',
        description: 'Ay sonu kapanis ve takip yukunu azaltan daha operasyonel sayfa.',
        badge: 'Follow-up',
      },
      {
        href: '/e-beyanname/',
        title: 'Uyum ve beyan akislarini guclendirin',
        description: 'Beyan, kontrol ve dokuman sureclerinde tekrar isi azaltin.',
        badge: 'Compliance',
      },
    ]
  : isHr
    ? [
        {
          href: '/maas-hesaplama-motoru/',
          title: 'IK ve bordro akislarini toparlayin',
          description: 'Tekil hesaplardan ekip ici surec otomasyonuna gecis icin ana giris sayfasi.',
          badge: 'HR',
        },
        {
          href: '/bordro-hesaplama/',
          title: 'Bordro destek akislarini sadeletin',
          description: 'Tekrarlayan maas, puantaj ve personel taleplerini duzenli yonetin.',
          badge: 'Payroll',
        },
        {
          href: '/sgk-hizmet-dokumu/',
          title: 'Belge ve personel dogrulama akislarini iyilestirin',
          description: 'IK ekiplerinde belge tabanli tekrar isi azaltmak icin.',
          badge: 'Ops',
        },
      ]
    : [
        {
          href: '/marketing-otomasyonu/',
          title: 'Marketing otomasyonu',
          description: 'Form, icerik, outbound ve lead takip akislarini tek sistem mantiginda ele alin.',
          badge: 'Growth',
        },
        {
          href: '/crm-programi/',
          title: 'CRM programi',
          description: 'Gorusme, takip ve pipeline kayiplarini azaltan merkez sayfa.',
          badge: 'CRM',
        },
        {
          href: '/b2b-musteri-bulma/',
          title: 'B2B musteri bulma',
          description: 'Arastirma, hedef hesap secimi ve nitelikli outbound tarafini guclendirin.',
          badge: 'Outbound',
        },
      ];

const contactPackage = isFinance ? 'finans-operasyon-analizi' : isHr ? 'ik-surec-analizi' : 'lead-flow-audit';
const contactArea = isFinance ? 'finance-accounting' : isHr ? 'other' : 'marketing-leads';
const contactHref = `/iletisim/?kaynak=${encodeURIComponent(`/blog/${post.slug}/`)}&paket=${contactPackage}&alan=${contactArea}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.published_at || post.created_at,
  dateModified: post.published_at || post.created_at,
  author: {
    '@type': 'Person',
    name: post.author,
    ...(post.author_bio && { description: post.author_bio }),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Pratik Yapay Zeka',
    url: 'https://yapayzekapratik.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://yapayzekapratik.com/apple-touch-icon.png',
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `https://yapayzekapratik.com/blog/${post.slug}/`,
  },
  image: post.og_image_url || post.cover_image_url || 'https://yapayzekapratik.com/og-homepage.jpg',
  articleBody: post.content.substring(0, 500),
  keywords: (post.tags || []).join(', '),
  articleSection: post.category,
  inLanguage: 'tr-TR',
};

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Blog', url: '/blog/' },
  { name: post.title, url: `/blog/${post.slug}/` },
];
---

<BaseLayout
  title={post.meta_title || `${post.title} | Pratik Yapay Zeka`}
  description={post.meta_description || post.excerpt}
  ogImage={post.og_image_url || post.cover_image_url || '/og-homepage.jpg'}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  {/* Reading Progress — 2px lime line */}
  <div id="reading-progress" class="fixed left-0 top-0 z-50 h-[2px] w-0 bg-[var(--color-primary)] transition-[width] duration-75 ease-out" style="opacity:0.9"></div>

  <article class="bg-gradient-to-b from-[#08090a] via-[#0a0c10] to-[#08090a] pt-12 pb-24 lg:pt-16 lg:pb-32">
    {/* ─── OUTER CONTAINER ─── */}
    <div class="mx-auto max-w-[1400px] px-6 lg:px-10 xl:px-14">

      {/* Back link */}
      <a href="/blog/" class="mb-10 inline-flex items-center gap-2 text-sm font-medium text-[#62666d] transition-colors hover:text-[var(--color-primary)]">
        <span aria-hidden="true">←</span> Tüm blog yazıları
      </a>

      {/* ══════════════════════════════════════════
          HERO — Split grid: text left, image right
          ══════════════════════════════════════════ */}
      <div class={`mb-14 ${post.cover_image_url ? 'grid grid-cols-1 items-center gap-12 lg:grid-cols-[1fr_480px] xl:grid-cols-[1fr_560px]' : ''}`}>

        {/* Left: Text */}
        <div>
          {/* Eyebrow badge */}
          <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/[0.06] px-3.5 py-1.5">
            <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-[var(--color-primary)]"></span>
            <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-primary)]">
              {post.category || 'Rehber'} · {post.read_time || 5} dk okuma
            </span>
          </div>

          <h1 class="mb-6 text-[2.25rem] font-extrabold leading-[1.07] tracking-[-0.04em] text-[#f7f8f8] md:text-[3rem] lg:text-[3.5rem]">
            {post.title}
          </h1>

          {post.excerpt && (
            <p class="mb-8 max-w-[52ch] text-base leading-[1.65] text-[#8a8f98] md:text-lg">
              {post.excerpt}
            </p>
          )}

          {/* Author row */}
          <div class="mb-7 flex items-center gap-3">
            <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-white/[0.08] bg-white/[0.04]">
              <span class="text-sm font-bold text-[#f7f8f8]">{(post.author || 'P').charAt(0)}</span>
            </div>
            <div>
              <div class="text-sm font-semibold text-[#d0d6e0]">{post.author}</div>
              <div class="text-xs text-[#62666d]">{formattedDate}</div>
            </div>
          </div>

          {/* Trust badges */}
          <div class="flex flex-wrap gap-2">
            {['KVKK uyumlu', '%50 Geri İade', 'Self-Hosted'].map((badge) => (
              <span class="inline-flex items-center gap-1.5 rounded-full border border-white/[0.07] bg-white/[0.025] px-3 py-1 text-[11px] font-medium text-[#8a8f98]">
                <span class="text-[var(--color-primary)] text-[10px]">✓</span> {badge}
              </span>
            ))}
          </div>
        </div>

        {/* Right: Cover image */}
        {post.cover_image_url && (
          <div class="relative mt-8 lg:mt-0">
            <img
              src={post.cover_image_url}
              alt={post.cover_image_alt || post.title}
              class="blog-hero-image h-auto w-full rounded-2xl border border-white/[0.07] shadow-[0_16px_64px_rgba(0,0,0,0.5)]"
            />
            {/* Floating tag pills */}
            {(post.tags || []).length > 0 && (
              <div class="absolute bottom-4 left-4 flex flex-wrap gap-1.5">
                {(post.tags || []).slice(0, 3).map((tag) => (
                  <span class="rounded-full border border-white/[0.12] bg-black/65 px-2.5 py-0.5 text-[10px] font-medium text-white/80 backdrop-blur-sm">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
            {/* Subtle glow behind image */}
            <div class="absolute -bottom-8 left-1/2 -z-10 h-40 w-[70%] -translate-x-1/2 rounded-full bg-[var(--color-primary)]/10 blur-[60px] pointer-events-none"></div>
          </div>
        )}
      </div>

      {/* Divider */}
      <div class="mb-12 h-px bg-white/[0.06]"></div>

      {/* ══════════════════════════════════════════
          CONTENT + SIDEBAR  (2-column grid at xl+)
          ══════════════════════════════════════════ */}
      <div class="grid grid-cols-1 gap-x-16 xl:grid-cols-[minmax(0,1fr)_280px]">

        {/* ── Main prose column ── */}
        <div class="min-w-0">
          <div
            class="blog-content prose prose-invert max-w-none
              prose-headings:text-[#f7f8f8] prose-headings:font-bold
              prose-p:text-[#8a8f98] prose-p:leading-[1.65]
              prose-a:text-[var(--color-primary)] prose-a:no-underline hover:prose-a:opacity-75
              prose-strong:text-[#f7f8f8] prose-strong:font-semibold
              prose-code:rounded prose-code:bg-white/[0.04] prose-code:px-1.5 prose-code:py-0.5 prose-code:text-[var(--color-primary-light)]
              prose-pre:rounded-xl prose-pre:border prose-pre:border-white/[0.06] prose-pre:bg-white/[0.02]
              prose-blockquote:border-white/[0.06] prose-blockquote:text-[#d0d6e0]
              prose-li:text-[#8a8f98] prose-li:leading-[1.6]
              prose-img:rounded-xl prose-hr:border-white/[0.06]
              prose-table:text-[#8a8f98] prose-th:text-[#f7f8f8]"
            set:html={htmlContent}
          />

          {/* ── CTA Block ── */}
          <div class="mt-20 relative overflow-hidden rounded-2xl border border-[var(--color-primary)]/20 bg-gradient-to-br from-[var(--color-primary)]/[0.09] via-white/[0.02] to-transparent p-8 md:p-10">
            <div class="absolute -top-20 -right-20 h-48 w-48 rounded-full bg-[var(--color-primary)]/20 blur-[80px] pointer-events-none"></div>
            <div class="relative">
              <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/[0.08] px-3 py-1">
                <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-primary)]"></span>
                <span class="text-xs font-semibold text-[var(--color-primary)]">Sıradaki adım</span>
              </div>
              <h3 class="mb-3 text-2xl font-bold leading-[1.15] tracking-[-0.025em] text-[#f7f8f8] md:text-3xl">
                Bu konuyu kendi süreçlerinize uyarlayalım.
              </h3>
              <p class="mb-7 max-w-[52ch] text-[#8a8f98] leading-[1.65]">
                45 dakikalık ücretsiz görüşmede hangi otomasyonun size en hızlı geri dönüş sağlayacağını net söyleriz.
              </p>
              <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <a href={contactHref} class="cta-btn inline-flex items-center justify-center gap-2 rounded-full bg-[var(--color-primary)] px-7 py-3.5 text-sm font-bold text-[#08090a] shadow-[0_0_28px_rgba(163,230,53,0.3)]">
                  Ücretsiz analizi talep et <span aria-hidden="true">→</span>
                </a>
                <a href="/iletisim/" class="inline-flex items-center justify-center gap-2 rounded-full border border-white/[0.08] bg-white/[0.02] px-6 py-3 text-sm font-medium text-[#d0d6e0] transition-all hover:bg-white/[0.04] hover:text-white">
                  Nasıl çalışıyoruz
                </a>
              </div>
              <div class="mt-5 flex flex-wrap gap-4 text-xs text-[#62666d]">
                {['%50 Geri İade Garantisi', 'Hedef tutmazsa yarısı iade', 'Self-Hosted altyapı'].map((item) => (
                  <span class="flex items-center gap-1.5"><span class="text-[var(--color-primary)]">✓</span> {item}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        {/* ── Sticky Sidebar ── */}
        <aside class="hidden xl:block">
          <div class="sticky top-24 space-y-5">

            {/* ToC card */}
            {tocItems.length > 2 && (
              <nav aria-label="İçindekiler" class="rounded-xl border border-white/[0.07] bg-[#0d0e10]/95 p-5 backdrop-blur-sm">
                <div class="mb-4 font-mono text-[10px] font-medium uppercase tracking-[0.2em] text-[#62666d]">İçindekiler</div>
                <ul class="space-y-1">
                  {tocItems.map((item, idx) => (
                    <li>
                      <a
                        href={`#${item.id}`}
                        data-toc-target={item.id}
                        class="toc-link group flex items-start gap-2.5 rounded-lg px-2 py-1.5 text-[13px] text-[#62666d] transition-all hover:bg-white/[0.03] hover:text-[#d0d6e0]"
                      >
                        <span class="mt-px font-mono text-[10px] shrink-0 text-[var(--color-primary)]/50 group-hover:text-[var(--color-primary)]">
                          {String(idx + 1).padStart(2, '0')}
                        </span>
                        <span class="leading-[1.4]">{item.text}</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </nav>
            )}

            {/* Mini CTA card */}
            <div class="rounded-xl border border-[var(--color-primary)]/[0.18] bg-[var(--color-primary)]/[0.05] p-5">
              <div class="mb-3 text-xs font-semibold uppercase tracking-[0.15em] text-[var(--color-primary)]">Ücretsiz analiz</div>
              <p class="mb-4 text-sm leading-[1.55] text-[#8a8f98]">
                Hangi süreçlerinizi otomasyona alacağınızı birlikte belirleyelim.
              </p>
              <a href={contactHref} class="block w-full rounded-full bg-[var(--color-primary)] py-2.5 text-center text-sm font-bold text-[#08090a] transition-all hover:-translate-y-0.5 hover:shadow-[0_0_24px_rgba(163,230,53,0.4)]">
                Talep et →
              </a>
            </div>

            {/* Reading stats */}
            <div class="rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3 text-xs text-[#62666d]">
              <div class="flex items-center justify-between">
                <span>Okuma süresi</span>
                <span class="font-semibold text-[#8a8f98]">{post.read_time || 5} dk</span>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <span>Kategori</span>
                <span class="font-semibold text-[#8a8f98]">{post.category || 'Rehber'}</span>
              </div>
            </div>

          </div>
        </aside>
      </div>

      {/* ── Author bio ── */}
      {post.author_bio && (
        <div class="mt-16 rounded-2xl border border-white/[0.06] bg-white/[0.02] p-6">
          <h2 class="mb-2 text-lg font-semibold text-[#f7f8f8]">Yazar hakkında</h2>
          <p class="text-[#8a8f98]">{post.author_bio}</p>
        </div>
      )}

      {/* ── Related solutions ── */}
      <div class="mt-16 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="rounded-2xl border border-white/[0.07] bg-white/[0.015] p-7">
          <h2 class="text-xl font-bold text-[#f7f8f8]">İlgili sonraki sayfalar</h2>
          <div class="mt-5 space-y-3">
            {relatedSolutions.map((item) => (
              <a href={item.href} class="group flex items-start gap-4 rounded-xl border border-white/[0.06] bg-black/10 p-4 transition hover:-translate-y-0.5 hover:border-[var(--color-primary)]/30">
                {item.badge && (
                  <span class="mt-0.5 shrink-0 rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/10 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-[var(--color-primary)]">
                    {item.badge}
                  </span>
                )}
                <div>
                  <div class="text-sm font-semibold text-[#d0d6e0] group-hover:text-white transition-colors">{item.title}</div>
                  <div class="mt-1 text-xs leading-[1.55] text-[#62666d]">{item.description}</div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <div class="relative overflow-hidden rounded-2xl border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/[0.07] p-7">
          <div class="absolute -top-16 -right-16 h-40 w-40 rounded-full bg-[var(--color-primary)]/15 blur-[60px] pointer-events-none"></div>
          <div class="relative">
            <span class="inline-flex rounded-full border border-[var(--color-primary)]/25 bg-[var(--color-primary)]/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">Dönüşüm</span>
            <h2 class="mt-4 text-2xl font-extrabold leading-[1.15] tracking-tight text-[#f7f8f8]">
              Bu konuyu kendi sürecinize uygulayın.
            </h2>
            <p class="mt-3 text-sm leading-[1.6] text-[#8a8f98]">
              Kısa bir analizle bu yazıdaki fikrin sizin ekipte nerede en hızlı geri dönüş üreteceğini birlikte belirleriz.
            </p>
            <ul class="mt-5 space-y-2 text-sm text-[#62666d]">
              {['Sayfaya göre kaynak takibi', 'Konuya uygun analiz paketi', 'Somut sonraki adım önerisi'].map((item) => (
                <li class="flex items-center gap-2"><span class="text-[var(--color-primary)]">→</span> {item}</li>
              ))}
            </ul>
            <a href={contactHref} class="mt-6 inline-flex w-full items-center justify-center rounded-full bg-[var(--color-primary)] py-3.5 text-sm font-bold text-[#08090a] transition hover:-translate-y-0.5 hover:shadow-[0_0_28px_rgba(163,230,53,0.4)]">
              Ücretsiz analizi talep et
            </a>
          </div>
        </div>
      </div>

    </div>{/* /outer container */}
  </article>

  {/* ════════════════════════════════
      GLOBAL STYLES
      ════════════════════════════════ */}
  <style is:global>
    /* Motion tokens */
    :root {
      --spring-smooth: cubic-bezier(0.16, 1, 0.3, 1);
      --spring-snap: cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    html { scroll-behavior: smooth; scroll-padding-top: 5rem; }

    /* ── Hero image ── */
    .blog-hero-image {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 20px;
    }

    /* ── Blog content images ── */
    .blog-content img {
      display: block;
      width: 100%;
      height: auto;
      margin-top: 2.25rem;
      margin-bottom: 2.25rem;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 12px;
    }

    /* Hide duplicate H1 from markdown */
    .blog-content > h1:first-child { display: none; }

    /* Section counter */
    .blog-content { counter-reset: section; }

    /* ── H2 — numbered, border top ── */
    .blog-content h2 {
      counter-increment: section;
      position: relative;
      margin-top: 4.5rem !important;
      margin-bottom: 1rem !important;
      padding-top: 2rem;
      font-size: 1.75rem !important;
      line-height: 1.12 !important;
      letter-spacing: -0.025em;
      color: #f7f8f8 !important;
      font-weight: 700 !important;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .blog-content h2::before {
      content: '§' counter(section);
      display: block;
      margin-bottom: 0.6rem;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.18em;
      color: #62666d;
    }

    /* ── H3 ── */
    .blog-content h3 {
      margin-top: 2rem !important;
      font-size: 1.125rem !important;
      font-weight: 600 !important;
      letter-spacing: -0.01em;
      color: #f7f8f8 !important;
    }

    /* ── Lead paragraph (first after H2) ── */
    .blog-content h2 + p {
      font-size: 1.0625rem !important;
      line-height: 1.65 !important;
      color: #c4cad4 !important;
      margin-bottom: 1.25rem !important;
    }

    /* ── Body text ── */
    .blog-content p {
      color: #8a8f98 !important;
      line-height: 1.7 !important;
      font-size: 1rem !important;
    }

    /* ── Blockquote — glass card ── */
    .blog-content blockquote {
      position: relative;
      margin: 2rem 0 !important;
      padding: 1.375rem 1.625rem !important;
      border-left: none !important;
      border: 1px solid rgba(255,255,255,0.08) !important;
      border-radius: 14px;
      background: rgba(255,255,255,0.025);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      font-style: normal !important;
    }
    .blog-content blockquote::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      bottom: 0;
      width: 3px;
      border-radius: 99px;
      background: linear-gradient(to bottom, var(--color-primary), transparent);
    }
    .blog-content blockquote p {
      color: #c4cad4 !important;
      font-size: 0.9375rem !important;
      line-height: 1.65 !important;
      margin: 0 !important;
    }
    .blog-content blockquote strong { color: #f7f8f8 !important; }

    /* ── HR ── */
    .blog-content hr {
      margin: 3.5rem auto !important;
      border: none;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    /* ── Lists ── */
    .blog-content ul li,
    .blog-content ol li {
      margin: 0.35rem 0 !important;
      line-height: 1.65;
      color: #8a8f98 !important;
      font-size: 1rem !important;
    }

    /* ── Strong ── */
    .blog-content strong {
      color: #f7f8f8 !important;
      font-weight: 600;
    }

    /* ── Links ── */
    .blog-content a {
      color: var(--color-primary) !important;
      text-decoration: none !important;
      transition: opacity 0.15s;
    }
    .blog-content a:hover { opacity: 0.75; }

    /* ── ToC ── */
    .toc-link {
      position: relative;
      transition: color 0.15s var(--spring-snap), background 0.15s;
    }
    .toc-link.is-active {
      color: #f7f8f8 !important;
      background: rgba(255,255,255,0.04);
    }
    .toc-link.is-active span:first-child {
      color: var(--color-primary) !important;
    }

    /* ── CTA button ── */
    .cta-btn {
      transition: all 0.25s var(--spring-smooth);
    }
    .cta-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 0 40px rgba(163,230,53,0.45), 0 4px 16px rgba(0,0,0,0.3);
    }

    /* ── Section reveal ── */
    .blog-content h2,
    .blog-content blockquote,
    .blog-content img {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.55s var(--spring-smooth), transform 0.55s var(--spring-smooth);
    }
    .blog-content h2.revealed,
    .blog-content blockquote.revealed,
    .blog-content img.revealed {
      opacity: 1;
      transform: translateY(0);
    }

    /* ── Mobile overrides ── */
    @media (max-width: 768px) {
      .blog-content h2 {
        font-size: 1.375rem !important;
        margin-top: 3rem !important;
        padding-top: 1.5rem;
      }
      .blog-content h2 + p { font-size: 1rem !important; }
      .blog-content blockquote { padding: 1rem 1.25rem !important; }
      .blog-content img { margin-top: 1.5rem; margin-bottom: 1.5rem; }
    }
  </style>

  {/* ── Scroll spy + reveal ── */}
  <script is:inline>
    (function () {
      const progressEl = document.getElementById('reading-progress');
      const article = document.querySelector('article');
      const tocLinks = document.querySelectorAll('.toc-link');
      const headings = document.querySelectorAll('.blog-content h2[id]');

      function onScroll() {
        if (article && progressEl) {
          const rect = article.getBoundingClientRect();
          const total = article.offsetHeight - window.innerHeight;
          const scrolled = Math.min(Math.max(-rect.top, 0), total);
          const pct = total > 0 ? (scrolled / total) * 100 : 0;
          progressEl.style.width = pct + '%';
        }
        if (tocLinks.length && headings.length) {
          let active = null;
          headings.forEach(function(h) {
            const r = h.getBoundingClientRect();
            if (r.top < 160) active = h.id;
          });
          tocLinks.forEach(function(l) {
            if (l.dataset.tocTarget === active) l.classList.add('is-active');
            else l.classList.remove('is-active');
          });
        }
      }
      document.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // Reveal on scroll
      const revealTargets = document.querySelectorAll(
        '.blog-content h2, .blog-content blockquote, .blog-content img'
      );
      if ('IntersectionObserver' in window) {
        const obs = new IntersectionObserver(function(entries) {
          entries.forEach(function(e) {
            if (e.isIntersecting) {
              e.target.classList.add('revealed');
              obs.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -40px 0px', threshold: 0.08 });
        revealTargets.forEach(function(el) { obs.observe(el); });
      } else {
        revealTargets.forEach(function(el) { el.classList.add('revealed'); });
      }
    })();
  </script>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
</BaseLayout>
