---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog - Pratik Yapay Zeka" description="Yapay zeka, otomasyon ve dijital dönüşüm hakkında pratik rehberler ve vaka çalışmaları.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">Blog</h1>
      <p class="text-lg text-[var(--color-text-muted)]">Pratik yapay zeka destekli büyüme için içgörüler ve vaka çalışmaları.</p>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-4xl">
      <p class="text-center text-[var(--color-text-muted)]">Blog yazıları yakında burada yayınlanacak.</p>
    </div>
  </section>
</BaseLayout>
