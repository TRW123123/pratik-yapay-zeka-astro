---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Bordro Hesaplama | Puantaj, Kontrol ve Bordro Hazirlik Akisi';
const description = 'Bordro hesaplama arayan ekipler icin asil darbogaz hesap degil; puantaj, kesinti, kontrol ve onay adimlarinin daginik ilerlemesidir.';
const keywords = 'bordro hesaplama, puantaj otomasyonu, bordro kontrolu, bordro hazirlama, ik bordro sureci';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bordro hesaplama neden sadece matematik problemi degildir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Cunku puantaj, yan hak, kesinti, onay ve dagitim adimlari birlikte ilerler. Sorunlar genelde rakamdan once veri ve akis tarafinda ortaya cikar.',
      },
    },
    {
      '@type': 'Question',
      name: 'En buyuk darbogaz genelde nerededir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puantaj verisinin toplanmasi, anomalilerin bulunmasi, son dakika duzeltmeleri ve bordro oncesi kontrol listesinin daginik olmasi en buyuk darbogazlardan biridir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Bu sayfa kimi hedefler?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Duzenli bordro kapanisi yapan, puantaj ve kesinti akisinda tekrarlayan sorunlar yasayan IK ve finans ekiplerini hedefler.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Bordro ve Puantaj Operasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Bordro Hesaplamayi Son Gun Isinden Cikarip Isleyen Bir Kapanis Surecine Donusturun</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Bordro hesaplama cogu ekipte hesap tablosu problemi gibi gorunur. Oysa asil darbogaz puantaj verisinin toplanmasi, istisnalarin fark edilmesi, kesintilerin kontrolu ve son onay adimlarinin birbirine bagli olmamasidir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Puantaj</h2>
        <p class="text-muted-foreground">
          Vardiya, mesai, eksik gun veya izin bilgisinin farkli dosya ve kisilerden toplanmasi bordro oncesi ilk darbogazdir.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Kontrol</h2>
        <p class="text-muted-foreground">
          Son dakika duzeltmeleri, supheli saatler, eksik belgeler ve manuel teyitler ayni takvime yigilir.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Onay ve Dagitim</h2>
        <p class="text-muted-foreground">
          Bordro hazir olduktan sonra kimin onay verecegi, ne zaman cikti alinacagi ve personele nasil iletilecegi net olmayabilir.
        </p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Bordro Hesaplama Ihtiyacinin Buyudugu Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Coklu lokasyon ve vardiya:</strong> Veri tek yerde toplanmadiginda ay sonu kapanis yavaslar.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Tekrarlayan istisnalar:</strong> Mesai, prim, avans ve farkli kesinti tipleri sureci zorlastirir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Son gun yogunlugu:</strong> Kontrol listeleri ve onay surecleri gec olustugu icin ekip hep son asamada sıkışır.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asil Cozum</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Bordro hesaplama talebi bizim acimizdan puantaj verisinin temizlenmesi, kontrol akisi, onay ve dagitim surecinin birlikte ele alinmasi demektir. Yani tek bir hesap motorundan cok, bordro hazirlik katmanini sistemlestirme problemidir.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Veri Toplama Disiplini</h3>
          <p class="text-sm text-muted-foreground">Puantaj ve ilgili bordro girdileri son gun degil, surec icinde daha duzenli toplanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Anomali Gorunurlugu</h3>
          <p class="text-sm text-muted-foreground">Supheli saatler, eksik veri ve tekrar kontrol gerektiren noktalar daha erken fark edilir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Kapanis Akisi</h3>
          <p class="text-sm text-muted-foreground">Onay, dagitim ve sonraki adimlar kisi hafizasina degil surec mantigina baglanir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bordro hesaplama neden sadece matematik problemi degildir?</h3>
          <p class="text-muted-foreground">Cunku puantaj, yan hak, kesinti, onay ve dagitim adimlari birlikte ilerler. Sorunlar genelde rakamdan once veri ve akis tarafinda ortaya cikar.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">En buyuk darbogaz genelde nerededir?</h3>
          <p class="text-muted-foreground">Puantaj verisinin toplanmasi, anomalilerin bulunmasi, son dakika duzeltmeleri ve bordro oncesi kontrol listesinin daginik olmasi en buyuk darbogazlardan biridir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa kimi hedefler?</h3>
          <p class="text-muted-foreground">Duzenli bordro kapanisi yapan, puantaj ve kesinti akisinda tekrarlayan sorunlar yasayan IK ve finans ekiplerini hedefler.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
