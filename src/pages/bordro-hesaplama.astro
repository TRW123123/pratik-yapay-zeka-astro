---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Bordro Hesaplama | Puantaj, Kontrol ve Bordro Hazırlık Akışı';
const description = 'Bordro hesaplama arayan ekipler için asıl darboğaz hesap değil; puantaj, kesinti, kontrol ve onay adimlarinin dağınık ilerlemesidir.';
const keywords = 'bordro hesaplama, puantaj otomasyonu, bordro kontrolu, bordro hazırlama, ik bordro süreci';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bordro hesaplama neden sadece matematik problemi değildir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Çünkü puantaj, yan hak, kesinti, onay ve dagitim adımları birlikte ilerler. Sorunlar genelde rakamdan önce veri ve akış tarafinda ortaya çıkar.',
      },
    },
    {
      '@type': 'Question',
      name: 'En büyük darboğaz genelde nerededir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Puantaj verisinin toplanmasi, anomalilerin bulunması, son dakika duzeltmeleri ve bordro oncesi kontrol listesinin dağınık olmasi en büyük darbogazlardan biridir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Bu sayfa kimi hedefler?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Düzenli bordro kapanisi yapan, puantaj ve kesinti akışında tekrarlayan sorunlar yasayan IK ve finans ekiplerini hedefler.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Bordro ve Puantaj Operasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Bordro Hesaplamayi Son Gün Isinden Cikarip Işleyen Bir Kapanis Sürecine Donusturun</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Bordro hesaplama çoğu ekipte hesap tablosu problemi gibi görünür. Oysa asıl darboğaz puantaj verisinin toplanmasi, istisnalarin fark edilmesi, kesintilerin kontrolu ve son onay adimlarinin birbirine bagli olmamasidir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Puantaj</h2>
        <p class="text-muted-foreground">
          Vardiya, mesai, eksik gün veya izin bilgisinin farklı dosya ve kisilerden toplanmasi bordro oncesi ilk darbogazdir.
        </p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Kontrol</h2>
        <p class="text-muted-foreground">
          Son dakika duzeltmeleri, supheli saatler, eksik belgeler ve manuel teyitler ayni takvime yigilir.
        </p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Onay ve Dagitim</h2>
        <p class="text-muted-foreground">
          Bordro hazır olduktan sonra kimin onay vereceği, ne zaman çıktı alınacağı ve personele nasıl iletileceği net olmayabilir.
        </p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-sm border border-border">
      <h2 class="text-2xl font-semibold mb-6">Bordro Hesaplama Ihtiyacının Buyudugu Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Çoklu lokasyon ve vardiya:</strong> Veri tek yerde toplanmadiginda ay sonu kapanis yavaslar.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Tekrarlayan istisnalar:</strong> Mesai, prim, avans ve farklı kesinti tipleri süreci zorlastirir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Son gün yogunlugu:</strong> Kontrol listeleri ve onay süreçleri gec oluştuğu için ekip hep son aşamada sıkışır.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Işaret Ettigi Asıl Çözüm</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Bordro hesaplama talebi bizim acimizdan puantaj verisinin temizlenmesi, kontrol akışı, onay ve dagitim sürecinin birlikte ele alınması demektir. Yani tek bir hesap motorundan çok, bordro hazırlık katmanini sistemlestirme problemidir.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Veri Toplama Disiplini</h3>
          <p class="text-sm text-muted-foreground">Puantaj ve ilgili bordro girdileri son gün değil, süreç içinde daha düzenli toplanir.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Anomali Görünürlüğü</h3>
          <p class="text-sm text-muted-foreground">Supheli saatler, eksik veri ve tekrar kontrol gerektiren noktalar daha erken fark edilir.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Kapanis Akışı</h3>
          <p class="text-sm text-muted-foreground">Onay, dagitim ve sonraki adımlar kişi hafizasina değil süreç mantigina baglanir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bordro hesaplama neden sadece matematik problemi değildir?</h3>
          <p class="text-muted-foreground">Çünkü puantaj, yan hak, kesinti, onay ve dagitim adımları birlikte ilerler. Sorunlar genelde rakamdan önce veri ve akış tarafinda ortaya çıkar.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">En büyük darboğaz genelde nerededir?</h3>
          <p class="text-muted-foreground">Puantaj verisinin toplanmasi, anomalilerin bulunması, son dakika duzeltmeleri ve bordro oncesi kontrol listesinin dağınık olmasi en büyük darbogazlardan biridir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa kimi hedefler?</h3>
          <p class="text-muted-foreground">Düzenli bordro kapanisi yapan, puantaj ve kesinti akışında tekrarlayan sorunlar yasayan IK ve finans ekiplerini hedefler.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
