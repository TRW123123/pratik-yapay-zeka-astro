    { title: "ERP ve Finans Verisine Baglanma", description: "Mevcut ticari yazılım veya muhasebe yapisindan okunacak alanlar daha düzenli bir servis akisina baglanir." },
    { title: "Teslim ve Takip", description: "Bilgi WhatsApp, panel, e-posta veya ic ekran üzerinden iletilir; gerekirse tahsilat ve follow-up akislariyla birlestirilir." }
  ]}
  featuresTitle="Cari Hesap Ekstresi Sayfasinin Gerçek Görevi"
  features={[
    { title: "Self-Service Bakiye Erişimi", description: "Müşteri veya bayi basit bakiye soruları için muhasebe ekibini beklemek zorunda kalmaz." },
    { title: "PDF ve Ozet Bilgi Katmani", description: "Gerektiginde tam ekstre, gerektiginde yalnizca ozet bakiye veya vadesi gelen tutar gosterilebilir." },
    { title: "Yetki ve Görünürlük Kontrolu", description: "Kim hangi cari kayda ulasabilir sorusu daha kontrollu bicimde ele alınır." },
    { title: "Tahsilat ve Satış Akisina Bağlantı", description: "Ekstre talebi yalnizca belge gonderimi olarak kalmaz; tahsilat ve satış sürecine de veri sağlar." }
  ]}
  benefitsTitle="Cari Bilgi Akisindaki Net Kazanc"
  benefits={[
    "Daha Az Ic Yazisma", "Ekstre ve bakiye soruları için ekipler arasi ileri geri trafik azalir.",
    "%100", "Daha görünür cari bilgi akışı. Kim hangi bilgiye ulasiyor ve ne zaman guncellendi daha net gorulur.",
    "Daha Hızlı Tahsilat", "Müşteri ve ekipler güncel hesap durumunu daha erken gordugu için aksiyon daha hızlı alinabilir."
  ]}
  caseStudyDescription="Bayi agindan sik bakiye ve ekstre talebi alan bir şirket, cari bilgi akislarini self-service mantigina tasidiktan sonra hem muhasebe üzerindeki kesinti yukunu azalttı hem de tahsilat ve satış ekibine daha hızlı veri saglamaya başladı."
  finalCtaTitle="Cari Ekstre Surecini PDF Istegi Olmaktan Cikaralim"
  finalCtaSubtitle="Bayi, müşteri ve ic ekiplerin hangi cari bilgiye ne kadar hızlı ulasmasi gerektiğini birlikte cikaralim; buna gore en uygun self-service akisini tasarlayalim."
  sectorTheme="muhasebe"
  faqs={[
    { question: "Bu sayfa bir WhatsApp botu mu anlatiyor?", answer: "WhatsApp olasi kanallardan biridir, ama asıl konu cari bilgiye self-service erişim mantigidir. Kanalı şirket yapiniza gore seciyoruz." },
    { question: "Yalnizca dış müşteriler için mi uygundur?", answer: "Hayır. Satış ekipleri, plasiyerler, bayiler ve ic finans operasyonu için de çok faydali olabilir." },
    { question: "Tüm muhasebe verileri paylasilmak zorunda mi?", answer: "Hayır. Hangi alanlarin kimlere gosterilecegi, sadece okunur ve yetkili erişim prensibiyle kurgulanir." }
