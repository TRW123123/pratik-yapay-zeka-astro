---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ChatGPT Kullanım Rehberi | Pratik Yapay Zeka" description="ChatGPT'yi etkili kullanmak için pratik rehber ve ipuçları." noindex={true}>
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">ChatGPT Kullanım Rehberi</h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">ChatGPT'yi iş süreçlerinizde etkili kullanmanız için pratik ipuçları ve örnekler.</p>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-3xl space-y-8">
      <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-sm p-6">
        <h2 class="text-xl font-semibold mb-3">📝 Prompt Mühendisliği</h2>
        <p class="text-[var(--color-text-muted)]">Doğru soruyu sormak, doğru cevabı almak demektir. ChatGPT'den en iyi sonuçları almak için spesifik, bağlam verilen ve rol atanmış promptlar kullanın.</p>
      </div>
      <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-sm p-6">
        <h2 class="text-xl font-semibold mb-3">🏢 İş Kullanım Alanları</h2>
        <p class="text-[var(--color-text-muted)]">E-posta yazımı, müşteri hizmeti scriptleri, içerik oluşturma, veri analizi, rapor hazırlama ve daha fazlası.</p>
      </div>
      <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-sm p-6">
        <h2 class="text-xl font-semibold mb-3">⚡ Otomasyon ile Birleştirme</h2>
        <p class="text-[var(--color-text-muted)]">ChatGPT'nin API'sini Make.com veya n8n gibi otomasyon araçları ile birleştirerek iş akışlarınızı otomatikleştirin.</p>
      </div>
    </div>
  </section>
</BaseLayout>
