---
import SolutionLayout from '../../../layouts/SolutionLayout.astro';
import rawPseoData from '../../../data/pseo_data_tr.json';
import { PseoDataSchema } from '../../../data/pseo-schema';

export async function getStaticPaths() {
  // Build-time Zod validation — fail fast if JSON is malformed
  const pseoData = PseoDataSchema.parse(rawPseoData);
  return pseoData.map((data) => ({
    params: {
      sektor: data.slug_branche,
      problem: data.slug_problem,
    },
    props: { data },
  }));
}

const { data } = Astro.props;

// Process Features array for standard Layout mapping
const featuresList = data.loesung_features.map((feat: string, i: number) => {
  if (feat.includes(':')) {
    const splitIndex = feat.indexOf(':');
    return { 
      title: feat.substring(0, splitIndex).trim(), 
      description: feat.substring(splitIndex + 1).trim() 
    };
  }
  return { 
    title: `Otonom Çözüm ${i + 1}`, 
    description: feat 
  };
});

// Pack Hard Metrics into the Benefits section
const benefitsList = [
  data.hard_metrics.lead_cost,
  data.hard_metrics.time_saved,
  data.hard_metrics.conversion_rate
];
---

<SolutionLayout
  title={data.seo_title}
  description={data.seo_description}
  ogImage={`/og-${data.slug_branche}.jpg`}
  heroTitle={data.loesung_titel}
  heroSubtitle={data.seo_description}
  problems={data.schmerzpunkte}
  processTitle={`${data.branche} Sektöründe Pazar Payı Kazanımı`}
  processSteps={[
    { title: 'Sektörel Analiz', description: `${data.branche} dinamiklerine ve rakip açıklarına özel strateji geliştirme.` },
    { title: 'Mimari Tasarım', description: 'Privacy-First (Gizlilik Odaklı) ve hedefe yönelik yapay zeka modellemesi.' },
    { title: 'Sistem Entegrasyonu', description: 'Mevcut CRM, ERP ve operasyon altyapınıza kusursuz, arka planda bağlantı.' },
    { title: 'Otonom Ölçekleme', description: 'Botlar devreye girer girmez zaman kayıplarını sıfırlama ve ROI artışı.' }
  ]}
  featuresTitle="Sistematik Geliştirme Haritası"
  features={featuresList}
  benefitsTitle="Ölçülebilir Dönüşüm (Hard Metrics)"
  benefits={benefitsList}
  sectorTheme={data.slug_branche}
  sectorName={data.branche}
  faqs={data.faqs}
  caseStudyDescription={`${data.branche} sektöründe yapay zeka ile kurduğumuz büyüme sistemlerinin operasyonel detayları ve vaka çalışmaları için teknik ekibimizle görüşün.`}
  finalCtaTitle="Sisteminizi Hemen Ölçeklendirin"
  finalCtaSubtitle={`${data.branche} alanında manuel operasyonlarla zaman kaybetmeyi bırakın.`}
/>

