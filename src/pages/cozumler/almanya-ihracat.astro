---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Almanya'ya İhracat – Dijital Altyapı ve Satış Sistemi" description="Türk şirketleri için Almanya pazarına giriş. Dijital kimlik, lead generation, ve Alman iş kültürüne uygun satış otomasyonu.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="text-6xl mb-6">🇩🇪</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-6">Almanya'ya İhracat – Dijital Altyapı ve Pazar Girişi</h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">Türk şirketleri için Almanya pazarına profesyonel giriş: Dijital Alman kimliği, lead generation, ve Alman iş kültürüne uygun satış otomasyonu.</p>
      <a href="/cozumler/" class="bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300">Ücretsiz Danışmanlık</a>
    </div>
  </section>

  <section class="py-20 bg-[var(--color-surface-light)]">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Neden Almanya?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-[var(--color-surface)]/60 border border-[var(--color-border)] rounded-2xl p-6 text-center">
          <p class="text-3xl font-bold text-[var(--color-primary)] mb-2">83M+</p>
          <p class="text-sm text-[var(--color-text-muted)]">Nüfus</p>
        </div>
        <div class="bg-[var(--color-surface)]/60 border border-[var(--color-border)] rounded-2xl p-6 text-center">
          <p class="text-3xl font-bold text-[var(--color-primary)] mb-2">#1</p>
          <p class="text-sm text-[var(--color-text-muted)]">Avrupa'nın en büyük ekonomisi</p>
        </div>
        <div class="bg-[var(--color-surface)]/60 border border-[var(--color-border)] rounded-2xl p-6 text-center">
          <p class="text-3xl font-bold text-[var(--color-primary)] mb-2">3.4M+</p>
          <p class="text-sm text-[var(--color-text-muted)]">Kayıtlı şirket</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-8 text-center">Hizmet Kapsamı</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6">
          <h3 class="font-semibold mb-2">Dijital Alman Kimliği</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Profesyonel Almanca web sitesi, sosyal medya profilleri, kurumsal kimlik ve güven oluşturan dijital varlık.</p>
        </div>
        <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6">
          <h3 class="font-semibold mb-2">Pazar Araştırması</h3>
          <p class="text-sm text-[var(--color-text-muted)]">ICP analizi, rakip tespiti, hedef sektör ve firmaların yapay zeka ile belirlenmesi.</p>
        </div>
        <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6">
          <h3 class="font-semibold mb-2">Lead Generation</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Outbound e-posta ve LinkedIn kampanyaları ile Alman firmalarda nitelikli randevu kazanımı.</p>
        </div>
        <div class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6">
          <h3 class="font-semibold mb-2">Kültürel Danışmanlık</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Alman iş kültürü, pünktüellik, doğrudan iletişim ve süreçsel karar alma kültürüne uyum.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/5">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Almanya'ya İhracat İçin Hazır mısınız?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">Yapay zeka destekli dijital altyapı ile Almanya pazarına profesyonel giriş yapın.</p>
      <a href="/cozumler/" class="bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 text-lg">Ücretsiz Danışmanlık</a>
    </div>
  </section>
</BaseLayout>
