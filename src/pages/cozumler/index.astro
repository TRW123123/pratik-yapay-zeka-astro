---
import BaseLayout from '../../layouts/BaseLayout.astro';

const solutions = [
  { href: '/cozumler/lead-generation/', title: 'Yapay Zeka Lead Üretimi', description: 'Otomatik araştırma, kişiselleştirilmiş iletişim, akıllı takip.', metric: 'Ayda +30 randevu' },
  { href: '/cozumler/satis-otomasyonu/', title: 'Satış Otomasyonu', description: 'Outbound, takipler ve ilk nitelendirmeyi yapay zeka ile otomatikleştirin.', metric: '%50 daha fazla zaman' },
  { href: '/cozumler/pazarlama-otomasyonu/', title: 'Pazarlama Otomasyonu', description: 'İçerik oluşturma, sosyal medya ve reklam optimizasyonu.', metric: '5x içerik' },
  { href: '/cozumler/crm-otomasyonu/', title: 'CRM Otomasyonu', description: 'CRM, veri işleme ve tekrarlayan süreçleri otomatikleştirin.', metric: '%90 temiz veri' },
  { href: '/cozumler/musteri-hizmeti-otomasyonu/', title: 'Müşteri Hizmeti Otomasyonu', description: 'Chatbot ve voicebot ile 7/24 destek.', metric: '7/24 erişim' },
  { href: '/cozumler/almanya-ihracat/', title: '🇩🇪 Almanya\'ya İhracat', description: 'Almanya pazarına giriş için dijital altyapı ve satış sistemi.', metric: 'Alman Kimliği' },
];
---

<BaseLayout title="Çözümler - Pratik Yapay Zeka" description="Lead generation, pazarlama, satış ve müşteri başarısı için yapay zeka destekli otomasyon çözümleri.">
  <section class="py-32 lg:py-48 relative overflow-hidden bg-[#0B0F14]">
    <div class="absolute inset-0 bg-[url('/noise.png')] opacity-20 mix-blend-overlay pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[var(--color-primary)]/10 rounded-full blur-[150px] pointer-events-none opacity-60"></div>
    <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-[#FFFFFF] drop-shadow-lg">Bir sonraki adım için hazır mısınız?</h1>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">Sizin için çözümü geliştirelim</p>
    </div>
  </section>
  <section class="pb-32 relative z-10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {solutions.map((sol) => (
          <a href={sol.href} class="neon-bleed-border bg-[var(--color-surface-light)]/40 backdrop-blur-sm p-8 hover:bg-[var(--color-surface-light)]/60 transition-all duration-500 group block relative rounded-2xl overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <h2 class="text-xl font-bold mb-3 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors relative z-10">{sol.title}</h2>
            <p class="text-[var(--color-text-muted)] mb-6 leading-relaxed relative z-10">{sol.description}</p>
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 relative z-10">
              {sol.metric}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
