---
import BaseLayout from '../../layouts/BaseLayout.astro';
import pseoData from '../../data/pseo_data_tr.json';

const sectorSolutions = pseoData.map(data => ({
  href: `/cozumler/${data.slug_branche}/${data.slug_problem}/`,
  title: data.branche,
  description: data.seo_description,
  metric: data.hard_metrics.conversion_rate.split(' ').slice(0, 4).join(' ') + '...'
}));

const assistants = [
  { href: '/crm-programi/', title: 'Yapay Zeka CRM', desc: 'Müşteri ilişkilerini otonom yöneten, satış fırsatlarını takip eden akıllı CRM sistemi.' },
  { href: '/on-muhasebe-ve-fatura/', title: 'Ön Muhasebe Botu', desc: 'Fatura kesme, tahsilat takibi ve muhasebe süreçlerini otomatikleştiren yapay zeka.' },
  { href: '/e-fatura-kesme-programi/', title: 'E-Fatura Otomasyonu', desc: 'GİB entegrasyonlu, tek tuşla e-fatura ve e-arşiv fatura kesim sistemi.' },
  { href: '/yapay-zeka-chatbot/', title: 'Yapay Zeka Chatbot', desc: '7/24 müşteri sorularını yanıtlayan, randevu alan ve satış yapan AI chatbot.' },
  { href: '/whatsapp-ve-siparis-botlari/', title: 'WhatsApp & Sipariş Botları', desc: 'WhatsApp üzerinden otomatik sipariş alma, onaylama ve takip sistemi.' },
  { href: '/b2b-musteri-bulma/', title: 'B2B Müşteri Bulma', desc: 'Hedef sektördeki potansiyel müşterileri bulan ve analiz eden yapay zeka.' },
  { href: '/b2b-musteri-takip-ve-plasiyer/', title: 'B2B Takip & Plasiyer', desc: 'Saha satış ekiplerini yöneten, rut planlayan ve performans takibi yapan sistem.' },
  { href: '/marketing-otomasyonu/', title: 'Marketing Otomasyonu', desc: 'E-posta, SMS ve sosyal medya kampanyalarını otonom yöneten pazarlama motoru.' },
  { href: '/e-ticaret-ve-pazaryeri-otomasyonu/', title: 'E-Ticaret Otomasyonu', desc: 'Trendyol, Hepsiburada ve N11 pazaryeri entegrasyonlu stok ve sipariş yönetimi.' },
  { href: '/stok-takibi-programi/', title: 'Stok Takip Sistemi', desc: 'Gerçek zamanlı stok seviyesi takibi, otomatik sipariş önerisi ve depo optimizasyonu.' },
  { href: '/teklif-hazirlama-programi/', title: 'Teklif Hazırlama', desc: 'Profesyonel teklif şablonları, otomatik fiyatlandırma ve dijital onay süreçleri.' },
  { href: '/kurumsal-e-posta-otomasyonu/', title: 'Kurumsal E-Posta', desc: 'Toplu e-posta yönetimi, spam koruması ve kurumsal iletişim altyapısı.' },
];

const financeTools = [
  { href: '/maas-hesaplama-motoru/', title: 'Maaş Hesaplama', desc: 'Net maaş, SGK ve vergi kesintilerini otomatik hesaplayan motor.' },
  { href: '/bordro-hesaplama/', title: 'Bordro Hesaplama', desc: 'Aylık bordro hazırlama, puantaj okuma ve teşvik entegrasyonu.' },
  { href: '/kidem-tazminati-hesaplama/', title: 'Kıdem Tazminatı', desc: 'Güncel tavan üzerinden kıdem tazminatı hesaplama ve belge hazırlama.' },
  { href: '/ihbar-tazminati-hesaplama/', title: 'İhbar Tazminatı', desc: 'İhbar süresi ve tazminat tutarını otomatik hesaplayan sistem.' },
  { href: '/isverene-maliyet-hesaplama/', title: 'İşverene Maliyet', desc: 'Toplam işveren yükünü, SGK primlerini ve vergileri hesaplayan araç.' },
  { href: '/fazla-mesai-hesaplama/', title: 'Fazla Mesai Hesaplama', desc: 'Yasal fazla mesai ücretlerini ve sınırlarını otomatik hesaplayan motor.' },
  { href: '/yillik-izin-ucreti-hesaplama/', title: 'Yıllık İzin Ücreti', desc: 'Kullanılmayan yıllık izin günlerinin parasal karşılığını hesaplama.' },
  { href: '/gecikme-zammi-hesaplama/', title: 'Gecikme Zammı', desc: 'Vergi ve SGK ödemelerindeki gecikme zammını otomatik hesaplayan araç.' },
  { href: '/vergi-iadesi-hesaplama/', title: 'Vergi İadesi', desc: 'Hak ettiğiniz vergi iadesini analiz eden ve başvuru sürecini yöneten sistem.' },
  { href: '/arac-deger-kaybi-hesaplama/', title: 'Araç Değer Kaybı', desc: 'Kaza sonrası araç değer kaybını hesaplayan ve tazminat tahmini sunan araç.' },
  { href: '/kdv-hesaplama/', title: 'KDV Hesaplama', desc: 'KDV dahil/hariç fiyat hesaplama ve fiyatlandırma stratejisi aracı.' },
  { href: '/brutten-nete/', title: 'Brütten Nete', desc: 'Brüt maaştan net maaşa geçişi tüm kesintilerle gösteren hesaplayıcı.' },
  { href: '/e-arsiv-portali/', title: 'E-Arşiv Portalı', desc: 'GİB e-arşiv fatura portalı entegrasyonu ve otomasyon çözümleri.' },
  { href: '/defter-beyan/', title: 'Defter Beyan', desc: 'Defter beyan sistemi OCR entegrasyonu ve otomatik kayıt işleme.' },
  { href: '/e-beyanname/', title: 'E-Beyanname', desc: 'Elektronik beyanname hazırlama ve GİB entegrasyonu süreçleri.' },
  { href: '/sgk-hizmet-dokumu/', title: 'SGK Hizmet Dökümü', desc: 'SGK hizmet dökümü sorgulama ve personel kayıt doğrulama botu.' },
  { href: '/ticaret-sicil-gazetesi/', title: 'Ticaret Sicil Gazetesi', desc: 'Ticaret sicil gazetesi sorgulama ve B2B firma istihbarat radarı.' },
  { href: '/acik-fatura-kapali-fatura/', title: 'Açık & Kapalı Fatura', desc: 'Açık ve kapalı fatura farkları, tahsilat takibi ve otomatik hatırlatma.' },
  { href: '/cari-hesap-ekstresi/', title: 'Cari Hesap Ekstresi', desc: 'Cari hesap ekstre oluşturma ve WhatsApp üzerinden otomatik gönderim.' },
  { href: '/mutabakat-mektubu/', title: 'Mutabakat Mektubu', desc: 'BA-BS mutabakat mektubu oluşturma ve otonom çapraz kontrol sistemi.' },
];
---

<BaseLayout title="Tüm Çözümler - Pratik Yapay Zeka" description="İşletmeniz için yapay zeka destekli otomasyon çözümleri, hesaplama araçları ve otonom asistanlar. 36+ araç ve çözüm tek platformda.">
  <!-- Hero -->
  <section class="py-32 lg:py-48 relative overflow-hidden bg-[#0B0F14]">
    <div class="absolute inset-0 opacity-20 mix-blend-overlay pointer-events-none"></div>
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[var(--color-primary)]/10 rounded-full blur-[150px] pointer-events-none opacity-60"></div>
    <div class="container mx-auto px-4 max-w-4xl text-center relative z-10">
      <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-[#FFFFFF] drop-shadow-lg">Tüm Çözümler & Araçlar</h1>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto leading-relaxed">36+ yapay zeka destekli araç, otonom asistan ve hesaplama motoru — hepsi tek platformda.</p>
    </div>
  </section>

  <!-- Sektörel Çözümler (pSEO) -->
  <section class="py-16 relative z-10">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-bold mb-8 text-[var(--color-text)]">🏢 Sektörel Çözümler</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {sectorSolutions.map((sol) => (
          <a href={sol.href} class="neon-bleed-border bg-[var(--color-surface-light)]/40 backdrop-blur-sm p-8 hover:bg-[var(--color-surface-light)]/60 transition-all duration-500 group block relative rounded-2xl overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
            <h3 class="text-lg font-bold mb-3 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors relative z-10">{sol.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] mb-4 leading-relaxed relative z-10">{sol.description}</p>
            <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 relative z-10">
              {sol.metric}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Otonom Asistanlar -->
  <section class="py-16 relative z-10">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-bold mb-8 text-[var(--color-text)]">🤖 Otonom Asistanlar</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {assistants.map((item) => (
          <a href={item.href} class="bg-[var(--color-surface-light)]/40 backdrop-blur-sm p-6 hover:bg-[var(--color-surface-light)]/60 transition-all duration-500 group block rounded-2xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/30">
            <h3 class="text-lg font-bold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Finans & Hesaplama Araçları -->
  <section class="py-16 pb-32 relative z-10">
    <div class="container mx-auto px-4 max-w-5xl">
      <h2 class="text-2xl font-bold mb-8 text-[var(--color-text)]">📊 Finans & Hesaplama Araçları</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {financeTools.map((item) => (
          <a href={item.href} class="bg-[var(--color-surface-light)]/40 backdrop-blur-sm p-6 hover:bg-[var(--color-surface-light)]/60 transition-all duration-500 group block rounded-2xl border border-[var(--color-border)] hover:border-[var(--color-primary)]/30">
            <h3 class="text-lg font-bold mb-2 text-[var(--color-text)] group-hover:text-[var(--color-primary)] transition-colors">{item.title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

