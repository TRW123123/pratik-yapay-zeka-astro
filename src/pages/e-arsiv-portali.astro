---
import SolutionLayout from '../layouts/SolutionLayout.astro';
---
<SolutionLayout
  title="E-Arsiv Portali Alternatifi | Portal Uzerindeki Manuel Isleri Azaltin"
  description="E-arsiv portali arayan bircok ekip aslinda yeni bir portal degil; portal uzerine yikilan veri toplama, belge hazirlama ve tekrar giris yukunu azaltmak istiyor."
  heroTitle="E-Arsiv Portali Kullanmakla Ugrasmak Yerine Etrafindaki Isi Azaltin"
  heroSubtitle="GIB e-arsiv portali sizin resmi cikis noktaniz olabilir. Biz portal oncesindeki belge toplama, veri hazirlama, kontrol ve gonderim surecini daha duzenli hale getirerek ekibin portal basinda gecirdigi zamani azaltan otomasyonlar kuruyoruz."
  problems={[
    "E-arsiv islemleri icin musteri bilgileri, kalemler ve tutarlarin farkli kanallardan toplanip portala tekrar tekrar elle girilmesi.",
    "Portal kullaniliyor olsa bile ekip icinde kimin belgeyi hazirlayacagi, kimin kontrol edecegi ve kimin kesimi tamamlayacaginin net olmamasi.",
    "Ozellikle perakende, hizmet ve dağinik siparis yapilarinda portalin kendisinden cok portal oncesindeki veri toplama asamasinin yorucu hale gelmesi."
  ]}
  processTitle="Portal Oncesi Yuku Nasil Azaltiyoruz?"
  processSteps={[
    { title: "Belge Kaynaklarini Toplama", description: "WhatsApp, e-posta, Excel veya form uzerinden gelen bilgiler ortak bir akista toplanir." },
    { title: "Taslak Veri Hazirlama", description: "Cari, belge tipi, kalem ve tutar gibi alanlar duzenli bir taslak yapisina getirilir; eksik alanlar isaretlenir." },
    { title: "Kontrol ve Onay", description: "Hangi belgelerin hemen ilerleyecegi, hangilerinin insan kontrolu gerektirdigi netlestirilir." },
    { title: "Portal veya Entegrator Uzerinden Tamamlama", description: "Resmi kesim asamasi mevcut yapiya gore portal ya da entegrator uzerinden tamamlanir; ekip sadece gerekli noktada devreye girer." }
  ]}
  featuresTitle="E-Arsiv Portal Aramalarinda Asil Deger Ureten Katman"
  features={[
    { title: "Portal Degil Operasyon Bakisi", description: "Sorunu yeni bir ekranla degil, portal uzerindeki manuel isi azaltarak cozmeye odaklaniyoruz." },
    { title: "Daginik Veri Kaynaklarini Toplama", description: "Siparis ve belge bilgileri farkli kanallardan gelse bile tek bir is akisi gibi ele alinabilir." },
    { title: "Eksik Alan ve Hata Gosterimi", description: "VKN, unvan, tutar veya belge tipi eksikleri daha portal asamasina gelmeden fark edilir." },
    { title: "Muhasebe ve Operasyon Uyumu", description: "Satis, operasyon ve muhasebe arasinda belge hazirlama sorumlulugu daha net paylastirilir." }
  ]}
  benefitsTitle="Portal Uzerindeki Is Yukundeki Net Azalma"
  benefits={[
    "Daha Az Elle Giris", "Portal ekranina yazilan veri miktari ve tekrar eden belge hazirlama isi azalir.",
    "Daha Hızlı Donus", "Siparis veya hizmet tamamlandiktan sonra belgenin hazir hale gelme suresi kisalir.",
    "Daha Az Karisiklik", "Hangi belgenin hazir oldugu, hangisinin eksik veri bekledigi daha görünür olur."
  ]}
  caseStudyDescription="E-arsiv belgelerini farkli kanallardan topladigi verilerle elle hazirlayan bir ekip, belge oncesi veri toplama ve kontrol katmanini sistemlestirince portal basinda gecirdigi zamani belirgin bicimde azaltti."
  finalCtaTitle="E-Arsiv Portali Yukunu Hafifletelim"
  finalCtaSubtitle="Sifirdan yeni bir yapi kurmadan, mevcut portal veya entegratorunuzun etrafindaki manuel adimlari birlikte cikaralim ve nerede otomasyonun en cok kazanc getirecegini netlestirelim."
  sectorTheme="muhasebe"
  faqs={[
    { question: "Bu sayfa GIB portalinin yerine gecen bir sistem mi anlatiyor?", answer: "Hayir. Odak, resmi kesim noktasinin oncesindeki veri toplama, belge hazirlama ve kontrol yukunu azaltmaktir." },
    { question: "E-arsiv portali kullanan kucuk ekipler icin de anlamli mi?", answer: "Evet. Ozellikle belge bilgisi farkli kanallardan geliyorsa veya tek bir kisi her seyi elle toparliyorsa ciddi rahatlama saglar." },
    { question: "En cok hangi yapilarda fayda saglar?", answer: "Daginik siparis akisina sahip e-ticaret, hizmet, toptan satis ve kucuk operasyon ekiplerinde portal oncesi yuk genellikle asil darboğazdir." }
  ]}
  sectorName="E-Arsiv Operasyon Akisi"
/>
