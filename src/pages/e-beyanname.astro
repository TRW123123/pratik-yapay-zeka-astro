---
import SolutionLayout from '../layouts/SolutionLayout.astro';
---
<SolutionLayout
  title="E-Beyanname Otomasyonu | Kapanis Kontrolu ve Beyan Hazirlama Akisi"
  description="E-beyanname tarafinda en buyuk sorun son gonderim ekrani degil; kapanis oncesi kontrol, veri uyumu ve hata yakalama surecinin daginik ilerlemesidir."
  heroTitle="E-Beyanname Surecini Son Gun Paniginden Cikarip Kontrol Altina Alin"
  heroSubtitle="KDV, muhtasar ve diger beyan sureclerinde ekiplerin asil zorlandigi nokta son adim degil; kapanis oncesi veri toplama, uyumsuzluk bulma ve kontrol listesidir. Biz resmi beyan oncesi hazirlik katmanini daha izlenebilir hale getiriyoruz."
  problems={[
    "Ay sonu ve donem kapanisinda verilerin farkli rapor, Excel ve ekipler arasinda daginik kalmasi nedeniyle son dakika kontrol krizlerinin yasamasi.",
    "Beyan oncesi hata yakalamanin kisi hafizasina ve elle kontrol listelerine bagli kalmasi.",
    "Finans ekibinin beyan hazirligi yerine veri arama, tutarsizlik bulma ve tekrar kontrol islerinde bogulmasi."
  ]}
  processTitle="E-Beyanname Oncesi Kontrol Katmani Nasil Calisiyor?"
  processSteps={[
    { title: "Kapanis Verilerini Toplama", description: "Beyan oncesi gerekli tablo, mizan, hareket ve kontrol noktalarini ortak bir akis altinda topluyoruz." },
    { title: "Tutarsizlik ve Eksik Kayit Kontrolu", description: "Uyumsuz satirlar, eksik kayitlar veya supheli hareketler isaretlenerek son dakika surprizleri azaltılıyor." },
    { title: "Onay ve Sorumluluk Akisi", description: "Hangi kontrol finans ekipte, hangisi muhasebecide, hangisi yonetici onayinda netlestirilir." },
    { title: "Beyan Hazirligina Uygun Cikti", description: "Son resmi gonderim oncesi ekip, daginik veri yerine duzenli bir kontrol ve hazirlik cikti setiyle ilerler." }
  ]}
  featuresTitle="E-Beyanname Surecinde Deger Ureten Hazirlik Katmani"
  features={[
    { title: "Kapanis Checklist Mantigi", description: "Beyan hazirligi kisiye bagli notlardan cikarak daha sistemli bir kontrol dizisine donusur." },
    { title: "Uyumsuzluk Gorunurlugu", description: "Supheli hareketler ve eksik veri noktaları daha erken fark edilir." },
    { title: "Ekipler Arasi Akis Netligi", description: "Muhasebe, finans ve dis mali musavir arasindaki sorumluluk dagilimi daha görünür olur." },
    { title: "Raporlama ve Takip", description: "Hangi kalemin temizlendiği, hangisinin beklediği ve hangi adimda tıkandigi izlenebilir hale gelir." }
  ]}
  benefitsTitle="Beyan Hazirligindaki Net Kazanc"
  benefits={[
    "Daha Az Son Gun Stresi", "Kontroller donem sonuna yigilmadan daha duzenli ilerler.",
    "%100", "Takip edilebilir kontrol sureci. Hangi kontrolün tamamlandigi ve hangisinin bekledigi daha net görünür.",
    "Daha Az Tekrar Kontrol", "Ayni veriyi farkli kisilerin tekrar tekrar aramasi ve teyit etmesi azalir."
  ]}
  caseStudyDescription="Kapanis dönemlerinde ayni veriyi farkli ekiplerden tekrar tekrar toplamak zorunda kalan bir finans ekibi, beyan oncesi kontrol katmanini sistemlestirince sureci daha erken temizlemeye ve son gun baskisini azaltmaya basladi."
  finalCtaTitle="E-Beyanname Surecini Son Adimda Degil, Onceki Adimlarda Guclendirelim"
  finalCtaSubtitle="Kapanis ve beyan hazirligi akisinizi birlikte cikaralim; hangi kontrol noktalarinin dağinik kaldigini ve nerede otomasyonun en faydali olacagini netlestirelim."
  sectorTheme="muhasebe"
  faqs={[
    { question: "Bu cozum resmi beyan gonderimini otomatik mi yapiyor?", answer: "Odak resmi son gonderimden onceki veri toplama, kontrol ve hazirlik surecini iyilestirmektir. Son resmi adim kurum yapiniza ve yetki modelinize gore belirlenir." },
    { question: "Kimler icin daha uygun?", answer: "Kapanis ve beyan surecinde birden fazla ekipten veri toplayan; kontrol listelerini hala e-posta ve Excel ile yürüten yapilar icin daha uygundur." },
    { question: "Dis mali musavirle calisan sirketlerde de kullanilabilir mi?", answer: "Evet. Hatta en faydali senaryolardan biri, ic ekip ile dis mali musavir arasindaki veri ve kontrol akislarini daha düzenli hale getirmektir." }
  ]}
  sectorName="E-Beyanname Hazirlik ve Kontrol"
/>
