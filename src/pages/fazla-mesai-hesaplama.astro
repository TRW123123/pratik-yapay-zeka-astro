---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Fazla Mesai Hesaplama | Puantaj, Onay ve Bordroya Aktarma Akisi';
const description = 'Fazla mesai ihtiyaci cogu ekipte hesap probleminden cok veri toplama, amir onayi ve bordroya dogru aktarma problemine donusur.';
const keywords = 'fazla mesai hesaplama, puantaj, mesai onayi, vardiya takibi, bordroya aktarma';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi mesai hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa, fazla mesai ihtiyacinin neden sahadan veri toplama, onay ve bordro aktarimi problemi oldugunu anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asil darboğaz genelde nerede olur?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asil darboğaz genelde mesai saatinin bulunmasinda degil; kimin ne kadar calistigi bilgisinin daginik gelmesi ve amir onayi beklemesinde olur.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler icin daha degerlidir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Vardiyali, saha veya mavi yaka agirlikli yapilarda puantaj akisi karmasiklastikca bu sayfa daha degerli hale gelir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Puantaj ve Saha Operasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Fazla Mesaiyi Formulle Degil, Sahadan Bordroya Giden Akisla Yonetin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Fazla mesai konusu cogu sirket icin matematikten once veri toplama problemidir. Saatler farkli vardiya listelerinden, amir notlarindan ve son dakika duzeltmelerinden geliyorsa asil sorun hesap degil, puantaj akisidir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Sahadan Veri</h2>
        <p class="text-muted-foreground">Mesai bilgisi cogu zaman tek sistemden degil, farkli kaynaklardan gelir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Amir Onayi</h2>
        <p class="text-muted-foreground">Hangi mesainin onaylandigi ve hangisinin duzeltme bekledigi gec gorunur olabilir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Bordro Aktarimi</h2>
        <p class="text-muted-foreground">Onayli bilgi bordroya gec aktariliyorsa itiraz, tekrar kontrol ve zaman kaybi artar.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Fazla Mesai Surecinin Zorlastigi Tipik Alanlar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Vardiyali yapilar:</strong> Birden fazla ekip ve zaman dilimi oldugunda veri dagiliyor.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Saha ekipleri:</strong> Yazili olmayan bildirimler ve sonradan gelen teyitler sureci zorlastiriyor.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Ay sonu kapanisi:</strong> Tum duzeltmeler son anda geliyorsa bordro ve IK ayni anda sikisiyor.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Asil Gittigi Cozum</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Fazla mesai aramasi bizim icin bir puantaj ve onay akisi sinyalidir. Deger, saatlik hesabi gostermekten cok mesai verisini toplamak, amir onayini netlestirmek ve sonucu bordroya daha temiz aktarmakta ortaya cikar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Veri Toplama Disiplini</h3>
          <p class="text-sm text-muted-foreground">Mesai bilgisi farkli kanallardan gelse bile ortak akista toplanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Onay Gorunurlugu</h3>
          <p class="text-sm text-muted-foreground">Hangi kaydin onayli, hangisinin beklemede oldugu daha net gorulur.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Bordro Gecisi</h3>
          <p class="text-sm text-muted-foreground">Sonuc son dakika kopyala-yapistir isine degil, daha temiz veri akisina doner.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi mesai hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa, fazla mesai ihtiyacinin neden sahadan veri toplama, onay ve bordro aktarimi problemi oldugunu anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asil darboğaz genelde nerede olur?</h3>
          <p class="text-muted-foreground">Asil darboğaz cogu zaman mesainin miktarindan once, verinin daginik gelmesi ve amir onayinin gecikmesinde olur.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler icin daha degerlidir?</h3>
          <p class="text-muted-foreground">Vardiyali, saha veya mavi yaka agirlikli yapilarda puantaj karmasiklastikca daha degerli hale gelir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
