---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Gecikme Zammı Hesaplama | Açık Alacak ve Tahsilat Takip Akışı';
const description = 'Gecikme zammı ihtiyacı çoğu durumda tek faiz hesabı değil; açık alacaklari görmek, takip etmek ve tahsilat iletisimini düzenli yonetmektir.';
const keywords = 'gecikme zammı hesaplama, açık alacak, tahsilat takibi, vadesi geçmiş fatura, borc hatirlatma';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi faiz hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayır. Bu sayfa, gecikme zammı ihtiyacının neden açık alacak ve tahsilat takibi problemine donustugunu anlatır.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asıl darboğaz nerede çıkar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asıl darboğaz çoğu zaman faizi formulle bulmakta değil; hangi faturanin hangi durumda oldugunu görmek ve tahsilat iletisimini planli yurutmektedir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler için daha kritiktir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Vadeli çalışan, tekrarlayan tahsilat takibi yapan ve açık hesap trafigi yüksek olan B2B yapilar için daha kritiktir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Tahsilat ve Açık Alacak Takibi</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Gecikme Zammini Tek Rakam Olarak Değil, Tahsilat Sürecinin Parçası Olarak Ele Alin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Gecikme zammı sorusu tek basina nadiren yeterlidir. Gercekte ekiplerin ihtiyacı, hangi faturanin vadesi gectigini görmek, hangi musteride hangi asamada olundugunu bilmek ve tahsilat iletisimini kisilere bagli kalmadan yurutmektir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Açık Alacak Görünürlüğü</h2>
        <p class="text-muted-foreground">Hangi faturanin hangi tarihte geciktigi net gorunmuyorsa faiz hesabı da gec kalir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Iletişim Sekansi</h2>
        <p class="text-muted-foreground">Hatirlatma, takip ve geri donuslerin plansiz yurutulmesi tahsilati zayiflatir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Kapanis</h2>
        <p class="text-muted-foreground">Ödeme geldikten sonra dosyanin kapanmasi ve gereksiz takibin bitmesi de ayni derecede onemlidir.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Gecikme Zammı Konusunun Buyudugu Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Vadeli satış yapan yapilarda:</strong> Farklı vade tarihleri ve cari gruplari takip yukunu arttirir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Tahsilat kisiye bagliysa:</strong> Kim hangi musteriyi aradi, ne cevap alindi bilgisi dagilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Açık hesap yogunsa:</strong> Geciken dosyalar gözden kacmaya başlar ve tahsilat ritmi bozulur.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asıl Çözüm</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Gecikme zammı konusu bizim için bir faiz formulu değil, tahsilat takip sistemidir. Değer, açık alacaklari net gormekte, hatirlatma akislarini planlamakta ve dosyanin tahsilatla kapanisina kadar süreci izlenebilir kilmakta ortaya çıkar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Acil Dosya Görünürlüğü</h3>
          <p class="text-sm text-muted-foreground">Vadesi geçmiş dosyalar daha erken ve daha net ayrisir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Takip Disiplini</h3>
          <p class="text-sm text-muted-foreground">Hatirlatma ve cevap akışı kisilere değil surece baglanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Tahsilat Kapanisi</h3>
          <p class="text-sm text-muted-foreground">Ödeme sonrasi dosya ve cari durumu daha temiz şekilde kapanir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi faiz hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayır. Bu sayfa, gecikme zammı ihtiyacının neden açık alacak ve tahsilat takibi problemine donustugunu anlatır.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asıl darboğaz nerede çıkar?</h3>
          <p class="text-muted-foreground">Asıl darboğaz çoğu zaman formulle hesaplamakta değil; hangi faturanin hangi durumda oldugunu görmek ve takip sekansini düzenli yurutmektedir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler için daha kritiktir?</h3>
          <p class="text-muted-foreground">Vadeli çalışan ve tekrarlayan tahsilat takibi yapan B2B yapilar için daha kritiktir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
