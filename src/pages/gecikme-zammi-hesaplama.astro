---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Gecikme Zammi Hesaplama | Acik Alacak ve Tahsilat Takip Akisi';
const description = 'Gecikme zammi ihtiyaci cogu durumda tek faiz hesabi degil; acik alacaklari gormek, takip etmek ve tahsilat iletisimini duzenli yonetmektir.';
const keywords = 'gecikme zammi hesaplama, acik alacak, tahsilat takibi, vadesi gecmis fatura, borc hatirlatma';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi faiz hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa, gecikme zammi ihtiyacinin neden acik alacak ve tahsilat takibi problemine donustugunu anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asil darboğaz nerede cikar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asil darboğaz cogu zaman faizi formulle bulmakta degil; hangi faturanin hangi durumda oldugunu gormek ve tahsilat iletisimini planli yurutmektedir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler icin daha kritiktir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Vadeli calisan, tekrarlayan tahsilat takibi yapan ve acik hesap trafigi yuksek olan B2B yapilar icin daha kritiktir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Tahsilat ve Acik Alacak Takibi</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Gecikme Zammini Tek Rakam Olarak Degil, Tahsilat Surecinin Parcasi Olarak Ele Alin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Gecikme zammi sorusu tek basina nadiren yeterlidir. Gercekte ekiplerin ihtiyaci, hangi faturanin vadesi gectigini gormek, hangi musteride hangi asamada olundugunu bilmek ve tahsilat iletisimini kisilere bagli kalmadan yurutmektir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Acik Alacak Gorunurlugu</h2>
        <p class="text-muted-foreground">Hangi faturanin hangi tarihte geciktigi net gorunmuyorsa faiz hesabi da gec kalir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Iletisim Sekansi</h2>
        <p class="text-muted-foreground">Hatirlatma, takip ve geri donuslerin plansiz yurutulmesi tahsilati zayiflatir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Kapanis</h2>
        <p class="text-muted-foreground">Odeme geldikten sonra dosyanin kapanmasi ve gereksiz takibin bitmesi de ayni derecede onemlidir.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Gecikme Zammi Konusunun Buyudugu Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Vadeli satis yapan yapilarda:</strong> Farkli vade tarihleri ve cari gruplari takip yukunu arttirir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Tahsilat kisiye bagliysa:</strong> Kim hangi musteriyi aradi, ne cevap alindi bilgisi dagilir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Acik hesap yogunsa:</strong> Geciken dosyalar gozden kacmaya baslar ve tahsilat ritmi bozulur.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asil Cozum</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Gecikme zammi konusu bizim icin bir faiz formulu degil, tahsilat takip sistemidir. Deger, acik alacaklari net gormekte, hatirlatma akislarini planlamakta ve dosyanin tahsilatla kapanisina kadar sureci izlenebilir kilmakta ortaya cikar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Acil Dosya Gorunurlugu</h3>
          <p class="text-sm text-muted-foreground">Vadesi gecmis dosyalar daha erken ve daha net ayrisir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Takip Disiplini</h3>
          <p class="text-sm text-muted-foreground">Hatirlatma ve cevap akisi kisilere degil surece baglanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Tahsilat Kapanisi</h3>
          <p class="text-sm text-muted-foreground">Odeme sonrasi dosya ve cari durumu daha temiz sekilde kapanir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi faiz hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa, gecikme zammi ihtiyacinin neden acik alacak ve tahsilat takibi problemine donustugunu anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asil darboğaz nerede cikar?</h3>
          <p class="text-muted-foreground">Asil darboğaz cogu zaman formulle hesaplamakta degil; hangi faturanin hangi durumda oldugunu gormek ve takip sekansini duzenli yurutmektedir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler icin daha kritiktir?</h3>
          <p class="text-muted-foreground">Vadeli calisan ve tekrarlayan tahsilat takibi yapan B2B yapilar icin daha kritiktir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
