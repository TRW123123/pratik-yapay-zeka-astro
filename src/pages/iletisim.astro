---
import BaseLayout from '../layouts/BaseLayout.astro';

const sourcePage = Astro.url.searchParams.get('kaynak') || '';
const packageParam = Astro.url.searchParams.get('paket') || '';
const areaParam = Astro.url.searchParams.get('alan') || '';
const ctaParam = Astro.url.searchParams.get('cta') || '';

const packageLabels: Record<string, string> = {
  'lead-flow-audit': 'Lead akışı analizi',
  'operasyon-haritasi': 'Operasyon haritası',
  'ik-surec-analizi': 'IK süreç analizi',
  'finans-operasyon-analizi': 'Finans operasyon analizi',
};

const selectedPackage = packageLabels[packageParam] || '';
const defaultGoalByPackage: Record<string, string> = {
  'lead-flow-audit': 'quick-win',
  'operasyon-haritasi': 'full-roadmap',
  'ik-surec-analizi': 'cost-reduction',
  'finans-operasyon-analizi': 'cost-reduction',
};

const selectedGoal = defaultGoalByPackage[packageParam] || '';

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Iletişim', url: '/iletisim/' },
];
---

<BaseLayout
  title="Ücretsiz AI Otomasyon Analizi | Pratik Yapay Zeka"
  description="Isletmenizde hangi sureclerin yapay zeka ile otomatiklesebilecegini birlikte cikaralim. Kısa formu doldurun, size uygun otomasyon senaryolarini geri donelim."
  breadcrumbs={breadcrumbs}
  schemaType="ContactPage"
>
  <section data-santral-reveal class="pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="container mx-auto max-w-6xl px-6 lg:px-10">
      <div class="flex items-center gap-4 mb-10">
        <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
        <span class="santral-overline">İletişim · Ücretsiz Ön Analiz</span>
      </div>
      <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-8">
          <div class="space-y-5">
            <h1 class="santral-display text-4xl md:text-6xl leading-[1.05]" style="font-weight:400;text-wrap:balance">
              İşletmenize özel yapay zeka otomasyonunu <em class="santral-italic">birlikte</em> çıkaralım.
            </h1>
            <p class="max-w-2xl santral-body text-lg md:text-xl">
              Satış, pazarlama, muhasebe, WhatsApp, CRM veya operasyon tarafında size en hızlı geri dönüş getirecek otomasyon alanlarını belirleyelim. Formu doldurun, size uygun senaryoları net bir şekilde geri dönelim.
            </p>
          </div>

          {selectedPackage && (
            <div class="santral-hat px-5 py-4 max-w-xl" style="border-color: rgba(224, 150, 84, 0.3)">
              <p class="santral-overline">Seçilen Analiz</p>
              <p class="mt-2 santral-display text-lg" style="font-weight:500">{selectedPackage}</p>
            </div>
          )}

          <div class="grid gap-4 md:grid-cols-3">
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 01</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">Süreci anlarız</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">
                Darboğaz yaratan adımı, manuel işleri ve kaçırılan fırsatları netleştiririz.
              </p>
            </div>
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 02</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">Uygun senaryo kurarız</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">
                Hangi entegrasyonun, botun veya agent yapısının size uyduğunu belirleriz.
              </p>
            </div>
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 03</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">Net sonraki adım veririz</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">
                Soyut fikir değil, uygulanabilir bir yol haritası ve ilk kurulum önerisi alırsınız.
              </p>
            </div>
          </div>

          <div class="santral-hat p-8">
            <span class="santral-overline block mb-4">İdeal Profil · 04</span>
            <h2 class="santral-display text-2xl" style="font-weight:500">Bu analiz kimler için ideal?</h2>
            <ul class="mt-5 space-y-3 text-[var(--color-paper-ecru-dim)]">
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>WhatsApp, e-posta veya formlardan gelen talepleri hızlı yönetemeyen ekipler</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>CRM, teklif, muhasebe veya satış operasyonunda manuel veri girişi yaşayan şirketler</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>Organik ya da reklam trafiğini lead'e çevirmekte zorlanan ekipler</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>E-ticaret, finans, muhasebe, HR veya B2B operasyonlarını otomatikleştirmek isteyenler</span></li>
            </ul>
          </div>
        </div>

        <div class="santral-hat p-8">
          <div class="mb-6">
            <span class="santral-overline block">Lead Formu · 05</span>
            <h2 class="mt-3 santral-display text-3xl" style="font-weight:500">Kısa bilgileri <em class="santral-italic">bırakın</em></h2>
            <p class="mt-3 santral-body leading-relaxed">
              Genelde ilk geri dönüşü 1 iş günü içinde yapıyoruz. Ne kadar somut yazarsanız, dönüşümüz o kadar faydalı olur.
            </p>
          </div>

          <form
            name="lead-discovery"
            method="POST"
            action="/tesekkurler/"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="lead-discovery" />
            <input type="hidden" name="source_page" value={sourcePage} data-source-page />
            <input type="hidden" name="request_package" value={packageParam} data-request-package />
            <input type="hidden" name="cta_context" value={ctaParam} data-cta-context />
            <input type="hidden" name="referrer" value="" data-referrer />
            <p class="hidden">
              <label>Bu alani doldurmayin: <input name="bot-field" /></label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Ad Soyad</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="text" name="name" autocomplete="name" required />
              </label>

              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">E-posta</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="email" name="email" autocomplete="email" required />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Şirket</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="text" name="company" autocomplete="organization" required />
              </label>

              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Telefon / WhatsApp</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="tel" name="phone" autocomplete="tel" />
              </label>
            </div>

            <label class="space-y-2">
              <span class="text-sm font-medium text-[var(--color-text)]">En çok ilgilendiginiz alan</span>
              <select class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" name="interest_area" required>
                <option value="" selected={!areaParam}>Bir alan seçin</option>
                <option value="crm-sales" selected={areaParam === 'crm-sales'}>CRM ve satış otomasyonu</option>
                <option value="marketing-leads" selected={areaParam === 'marketing-leads'}>Pazarlama ve lead yönetimi</option>
                <option value="finance-accounting" selected={areaParam === 'finance-accounting'}>Muhasebe ve finans operasyonu</option>
                <option value="whatsapp-chatbot" selected={areaParam === 'whatsapp-chatbot'}>WhatsApp / chatbot otomasyonu</option>
                <option value="ecommerce-ops" selected={areaParam === 'ecommerce-ops'}>E-ticaret ve operasyon</option>
                <option value="other" selected={areaParam === 'other'}>Diğer</option>
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-sm font-medium text-[var(--color-text)]">Bu gorusmeden ne bekliyorsunuz?</span>
              <select class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" name="request_goal" data-request-goal>
                <option value="" selected={!selectedGoal}>Bir hedef seçin</option>
                <option value="quick-win" selected={selectedGoal === 'quick-win'}>En hızlı geri dönüş verecek ilk otomasyon</option>
                <option value="full-roadmap" selected={selectedGoal === 'full-roadmap'}>Tam süreç haritası ve yol haritası</option>
                <option value="tool-selection" selected={selectedGoal === 'tool-selection'}>Hangi araç veya entegrasyon uygundur</option>
                <option value="cost-reduction" selected={selectedGoal === 'cost-reduction'}>Manuel is ve maliyet azaltma</option>
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-sm font-medium text-[var(--color-text)]">Hangi süreci otomatiklestirmek istiyorsunuz?</span>
              <textarea class="min-h-40 w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" name="message" placeholder="Örnek: WhatsApp'tan gelen talepleri CRM'e dusurmek, teklif olusturmayi hizlandirmak, muhasebede veri girisini azaltmak..." required></textarea>
            </label>

            <button type="submit" class="inline-flex w-full items-center justify-center rounded-sm bg-[var(--color-primary)] px-6 py-4 text-lg font-black text-black transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-light)]">
              Ücretsiz analizi talep et
            </button>

            <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">
              Formu gondererek sizinle e-posta veya telefon üzerinden iletisime gecmemizi kabul etmis olursunuz. Verileriniz yalnizca talebinizi degerlendirmek için kullanilir.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    /** Sanitize URL param: strip HTML tags and limit length */
    function cleanParam(val) {
      if (!val) return '';
      return val.replace(/<[^>]*>/g, '').replace(/["'<>]/g, '').substring(0, 200);
    }

    var sourceInput = document.querySelector('[data-source-page]');
    var packageInput = document.querySelector('[data-request-package]');
    var ctaInput = document.querySelector('[data-cta-context]');
    var referrerInput = document.querySelector('[data-referrer]');
    var requestGoalSelect = document.querySelector('[data-request-goal]');
    var interestAreaSelect = document.querySelector('select[name="interest_area"]');
    var params = new URLSearchParams(window.location.search);
    var packageGoalMap = {
      'lead-flow-audit': 'quick-win',
      'operasyon-haritasi': 'full-roadmap',
      'ik-surec-analizi': 'cost-reduction',
      'finans-operasyon-analizi': 'cost-reduction',
    };

    if (sourceInput && params.get('kaynak')) {
      sourceInput.value = cleanParam(params.get('kaynak'));
    }

    if (packageInput && params.get('paket')) {
      packageInput.value = cleanParam(params.get('paket'));
    }

    if (ctaInput && params.get('cta')) {
      ctaInput.value = cleanParam(params.get('cta'));
    }

    if (interestAreaSelect && params.get('alan')) {
      interestAreaSelect.value = cleanParam(params.get('alan'));
    }

    if (requestGoalSelect && params.get('paket') && !requestGoalSelect.value) {
      requestGoalSelect.value = packageGoalMap[cleanParam(params.get('paket'))] || '';
    }

    if (referrerInput) {
      referrerInput.value = cleanParam(document.referrer || '');
    }
  </script>
</BaseLayout>
