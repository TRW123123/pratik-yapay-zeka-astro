---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroExecutive from '../components/HeroExecutive.astro';
import FeaturesExecutive from '../components/FeaturesExecutive.astro';
import FAQExecutive from '../components/FAQExecutive.astro';
import CTAExecutive from '../components/CTAExecutive.astro';

// FAQ Content for Schema (reused here for JSON-LD SEO, visually rendered in FAQExecutive.astro)
const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.' },
  { question: 'Veri güvenliği nasıl sağlanır?', answer: 'Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. Tüm altyapımız GDPR uyumlu olarak kurgulanmıştır.' },
  { question: 'Teknik bilgi gerekli mi?', answer: 'Hayır. Tüm süreci biz yönetiyoruz. Sizin sadece hedeflerinizi ve iş süreçlerinizi bizimle paylaşmanız yeterli.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka – Satış ve Pazarlama Otomasyonu"
  description="Lead'den meeting'e tam otomatik yapay zeka. Outbound & Inbound, içerik ve sosyal medya otomasyonu ile satışlarınızı artırın."
  ogImage="/og/og-homepage.png"
  schemaType="FAQPage"
>
  <!-- New Executive High-Tech Hero Section -->
  <HeroExecutive />

  <!-- Features Component (GSAP ScrollTrigger + Emerald Glassmorphism) -->
  <FeaturesExecutive />

  <!-- FAQ Component (GSAP Accordion) -->
  <FAQExecutive />

  <!-- Liquid Emerald Call To Action Component -->
  <CTAExecutive />
  
  <!-- FAQ Schema.org JSON-LD for rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
</BaseLayout>
