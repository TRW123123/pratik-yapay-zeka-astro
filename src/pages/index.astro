---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.' },
  { question: 'Veri güvenliği nasıl sağlanır?', answer: 'Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. GDPR uyumlu çalışıyoruz.' },
  { question: 'Teknik bilgi gerekli mi?', answer: 'Hayır. Tüm süreci biz yönetiyoruz. Sadece iş süreçlerinizi anlamamız yeterli.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka – Satış ve Pazarlama Otomasyonu"
  description="Lead'den meeting'e tam otomatik yapay zeka. Outbound & Inbound, içerik ve sosyal medya otomasyonu ile satışlarınızı artırın."
  schemaType="FAQPage"
>
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-surface)] via-[var(--color-surface-light)] to-[var(--color-primary-dark)]/20"></div>
    <div class="relative z-10 container mx-auto px-4 text-center max-w-4xl">
      <p class="text-[var(--color-primary-light)] font-medium mb-4 tracking-wide uppercase text-sm">
        100+ B2B ekip için pratik otomasyon kurguladık.
      </p>
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
        Siz şirketi yönetin.
        <span class="bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-accent)] bg-clip-text text-transparent">
          Biz Yapay Zekayı kurarız.
        </span>
      </h1>
      <p class="text-xl md:text-2xl text-[var(--color-text-muted)] mb-10 max-w-2xl mx-auto">
        Yapay Zeka + Otomasyon ile Şirketinizi Daha da Büyütün – Fazladan Çaba Harcamadan.
      </p>
      <a
        href="/cozumler/"
        class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-[var(--color-primary)]/25 text-lg"
      >
        Şimdi ücretsiz başlayın
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-24 bg-[var(--color-surface-light)]">
    <div class="container mx-auto px-4">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Yapay Zeka Destekli İş Çözümleri</h2>
        <p class="text-[var(--color-text-muted)]">İşletmenizle birlikte büyüyen kapsamlı otomasyon araçları</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-[var(--color-surface)]/60 backdrop-blur-sm border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Outbound Satış Otomasyonu</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">Kişiselleştirilmiş e-postalar ve akıllı takip.</p>
          <span class="text-xs text-[var(--color-primary)] font-medium">Günde 500+ kişiselleştirilmiş mesaj</span>
        </div>
        <div class="bg-[var(--color-surface)]/60 backdrop-blur-sm border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Pazarlama Otomasyonu</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">Otomatik içerik, SEO ve reklam optimizasyonu.</p>
          <span class="text-xs text-[var(--color-primary)] font-medium">SEO skorunda garantili +%85 artış</span>
        </div>
        <div class="bg-[var(--color-surface)]/60 backdrop-blur-sm border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Müşteri İletişimi (Chatbot)</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">7/24 kişiselleştirilmiş yanıtlar.</p>
          <span class="text-xs text-[var(--color-primary)] font-medium">+%40 müşteri memnuniyeti</span>
        </div>
        <div class="bg-[var(--color-surface)]/60 backdrop-blur-sm border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300">
          <div class="w-12 h-12 rounded-xl bg-[var(--color-primary)]/10 flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Veri Analizi</h3>
          <p class="text-sm text-[var(--color-text-muted)] mb-3">Gerçek zamanlı içgörüler, daha iyi kararlar.</p>
          <span class="text-xs text-[var(--color-primary)] font-medium">%60 daha hızlı karar verme</span>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Sıkça Sorulan Sorular</h2>
        <p class="text-[var(--color-text-muted)]">Yapay zeka otomasyon platformumuz hakkında bilmeniz gereken her şey</p>
      </div>
      <div class="space-y-4">
        <details class="group bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-xl">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-medium">
            Kurulum ne kadar sürer?
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-6 pb-6 text-[var(--color-text-muted)]">Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.</p>
        </details>
        <details class="group bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-xl">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-medium">
            Veri güvenliği nasıl sağlanır?
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-6 pb-6 text-[var(--color-text-muted)]">Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. GDPR uyumlu çalışıyoruz.</p>
        </details>
        <details class="group bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-xl">
          <summary class="flex items-center justify-between p-6 cursor-pointer font-medium">
            Teknik bilgi gerekli mi?
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="px-6 pb-6 text-[var(--color-text-muted)]">Hayır. Tüm süreci biz yönetiyoruz. Sadece iş süreçlerinizi anlamamız yeterli.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/5">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">İşletmenizi Dönüştürmeye Hazır mısınız?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">Yapay zeka ve otomasyon ile satış ve pazarlama süreçlerinizi optimize edin. Ücretsiz danışmanlık için hemen iletişime geçin.</p>
      <a
        href="/cozumler/"
        class="inline-flex items-center gap-2 bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 hover:scale-105 text-lg"
      >
        Ücretsiz Danışmanlık Alın
      </a>
    </div>
  </section>
  <!-- FAQ Schema.org JSON-LD for rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
