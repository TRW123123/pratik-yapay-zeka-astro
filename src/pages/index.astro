---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Agitate from '../components/Agitate.astro';
import WhyUs from '../components/WhyUs.astro';
import Timeline from '../components/Timeline.astro';
import MiniCases from '../components/MiniCases.astro';

const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle birkaç gün ile birkaç hafta arasinda degisir. Basit akışları hızlı, çok sistemli kurulumlari daha aşamalı ilerletiyoruz.' },
  { question: 'Veri guvenligi nasıl sağlanır?', answer: 'Müşteri verileri yalnizca gerekli akislar için kullanilir. Yetki, erişim ve veri akışı proje yapisina gore sinirlandirilir.' },
  { question: 'Teknik ekip gerekiyor mu?', answer: 'Hayır. Teknik koordinasyonu biz ustlenebiliriz. Sizden asıl gereken, sürecin nasıl isledigini ve nerede tıkandığını gostermenizdir.' },
  { question: 'Sadece satış ve pazarlama mi yapiyorsunuz?', answer: 'Hayır. Satış ve pazarlama güçlü alanlarimizdan biri olsa da CRM, finans, belge akışı, destek, IK ve operasyon sureclerinde de calisiyoruz.' },
  { question: 'Fiyat nasıl belirlenir?', answer: 'Fiyat, sorunun buyuklugune, temas edilen sistem sayisina ve ne kadar özel akisa ihtiyac olduguna gore belirlenir.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka - Is Otomasyonu ve Yapay Zeka Sistemleri"
  description="Satış, pazarlama, CRM, finans ve operasyon süreçlerini yapay zeka destekli akislara donusturen otomasyon sistemleri kuruyoruz."
  ogImage="/og-homepage.jpg"
>
  <Hero />

  <section class="relative z-10 border-b border-[var(--color-border)] py-16">
    <div class="container mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-tight text-[var(--color-text)] md:text-3xl">Yapay Zeka ile Is Otomasyonu Nedir?</h2>
      <div class="space-y-4 text-base leading-relaxed text-[var(--color-text-muted)] md:text-lg">
        <p>Yapay zeka ile is otomasyonu, işletmelerin satış, pazarlama, CRM, finans, destek ve operasyon sureclerindeki tekrar eden adımları daha akıllı sistemlerle yurutmesidir. Bu sistemler; lead araştırması, teklif ve takip akışları, belge okuma, fatura ve mutabakat süreçleri, personel destek soruları ve sohbet tabanlı operasyon gibi alanlarda insan üzerindeki tekrar yukunu azaltır.</p>
        <p>Pratik Yapay Zeka olarak, Türkiye ve Almanya'daki KOBI'lere n8n, Make ve özel yapay zeka ajanlari ile uctan uca otomasyon sistemleri kuruyoruz. Odagimiz tek bir kanal değil; hangi sürecin tekrarlı, dağınık ve kisilere bagli kaldigini bulup onu daha görünür, daha hızlı ve daha olceklenebilir hale getirmektir.</p>
      </div>
    </div>
  </section>

  <Agitate />
  <WhyUs />
  <Timeline />
  <MiniCases />

  <section class="relative z-10 border-t border-[var(--color-border)] bg-[#0F151B]/30 py-24">
    <div class="container mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-16 text-center text-3xl font-extrabold tracking-tight text-[var(--color-text)] md:text-5xl">Sikca Sorulan Sorular</h2>
      <div class="space-y-4">
        {faqItems.map((faq) => (
          <details class="group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-light)]/40 backdrop-blur-md transition-colors hover:border-[var(--color-primary)]/30">
            <summary class="flex cursor-pointer items-center justify-between p-6 text-lg font-bold text-[var(--color-text)] transition-colors group-open:text-[var(--color-primary-light)]">
              {faq.question}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-4 h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-6 text-base leading-relaxed text-[var(--color-text-muted)]">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
