---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Agitate from '../components/Agitate.astro';
import WhyUs from '../components/WhyUs.astro';
import Timeline from '../components/Timeline.astro';
import MiniCases from '../components/MiniCases.astro';

// FAQ Content for Schema (SEO JSON-LD)
const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.' },
  { question: 'Veri güvenliği nasıl sağlanır?', answer: 'Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. GDPR uyumlu çalışıyoruz.' },
  { question: 'İçeriğin sahipliği kime ait?', answer: 'Üretilen tüm içerikler size aittir. Telif hakkı sorunu yaşamazsınız.' },
  { question: 'Fiyat nasıl belirlenir?', answer: 'İhtiyaç ve entegrasyonlara göre özel paketler sunuyoruz. Ücretsiz analiz sonrası net fiyat alırsınız.' },
  { question: 'Teknik bilgi gerekli mi?', answer: 'Hayır. Tüm süreci biz yönetiyoruz. Sadece iş süreçlerinizi anlamamız yeterli.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka – Satış ve Pazarlama Otomasyonu"
  description="Lead'den meeting'e tam otomatik yapay zeka. Outbound & Inbound, içerik ve sosyal medya otomasyonu ile satışlarınızı artırın."
  ogImage="/og/og-homepage.png"
  schemaType="FAQPage"
>
  <!-- 1. Hero Section (original copy) -->
  <Hero />

  <!-- 2. Agitate Section (3-tab "why not DIY/inhouse/wait") -->
  <Agitate />

  <!-- 3. Why Us Section (4 GlowCards) -->
  <WhyUs />

  <!-- 4. Timeline Section (5-step end-to-end automation) -->
  <Timeline />

  <!-- 5. Mini Cases Section (6 case study cards) -->
  <MiniCases />
  
  <!-- FAQ Schema.org JSON-LD for rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
