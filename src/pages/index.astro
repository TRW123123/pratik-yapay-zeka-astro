---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Agitate from '../components/Agitate.astro';
import WhyUs from '../components/WhyUs.astro';
import Timeline from '../components/Timeline.astro';
import MiniCases from '../components/MiniCases.astro';

const faqItems = [
  { question: 'Kurulum ne kadar surer?', answer: 'Genellikle birkac gun ile birkac hafta arasinda degisir. Basit akislari hizli, cok sistemli kurulumlari daha asamali ilerletiyoruz.' },
  { question: 'Veri guvenligi nasil saglanir?', answer: 'Musteri verileri yalnizca gerekli akislar icin kullanilir. Yetki, erisim ve veri akisi proje yapisina gore sinirlandirilir.' },
  { question: 'Teknik ekip gerekiyor mu?', answer: 'Hayir. Teknik koordinasyonu biz ustlenebiliriz. Sizden asil gereken, surecin nasil isledigini ve nerede tikandigini gostermenizdir.' },
  { question: 'Sadece satis ve pazarlama mi yapiyorsunuz?', answer: 'Hayir. Satis ve pazarlama guclu alanlarimizdan biri olsa da CRM, finans, belge akisi, destek, IK ve operasyon sureclerinde de calisiyoruz.' },
  { question: 'Fiyat nasil belirlenir?', answer: 'Fiyat, sorunun buyuklugune, temas edilen sistem sayisina ve ne kadar ozel akisa ihtiyac olduguna gore belirlenir.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka - Is Otomasyonu ve Yapay Zeka Sistemleri"
  description="Satis, pazarlama, CRM, finans ve operasyon sureclerini yapay zeka destekli akislara donusturen otomasyon sistemleri kuruyoruz."
  ogImage="/og-homepage.jpg"
>
  <Hero />

  <section class="relative z-10 border-b border-[var(--color-border)] py-16">
    <div class="container mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-2xl font-extrabold tracking-tight text-[var(--color-text)] md:text-3xl">Yapay Zeka ile Is Otomasyonu Nedir?</h2>
      <div class="space-y-4 text-base leading-relaxed text-[var(--color-text-muted)] md:text-lg">
        <p>Yapay zeka ile is otomasyonu, isletmelerin satis, pazarlama, CRM, finans, destek ve operasyon sureclerindeki tekrar eden adimlari daha akilli sistemlerle yurutmesidir. Bu sistemler; lead arastirmasi, teklif ve takip akislari, belge okuma, fatura ve mutabakat surecleri, personel destek sorulari ve sohbet tabanli operasyon gibi alanlarda insan uzerindeki tekrar yukunu azaltir.</p>
        <p>Pratik Yapay Zeka olarak, Turkiye ve Almanya'daki KOBI'lere n8n, Make ve ozel yapay zeka ajanlari ile uctan uca otomasyon sistemleri kuruyoruz. Odagimiz tek bir kanal degil; hangi surecin tekrarli, daginik ve kisilere bagli kaldigini bulup onu daha gorunur, daha hizli ve daha olceklenebilir hale getirmektir.</p>
      </div>
    </div>
  </section>

  <Agitate />
  <WhyUs />
  <Timeline />
  <MiniCases />

  <section class="relative z-10 border-t border-[var(--color-border)] bg-[#0F151B]/30 py-24">
    <div class="container mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-16 text-center text-3xl font-extrabold tracking-tight text-[var(--color-text)] md:text-5xl">Sikca Sorulan Sorular</h2>
      <div class="space-y-4">
        {faqItems.map((faq) => (
          <details class="group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface-light)]/40 backdrop-blur-md transition-colors hover:border-[var(--color-primary)]/30">
            <summary class="flex cursor-pointer items-center justify-between p-6 text-lg font-bold text-[var(--color-text)] transition-colors group-open:text-[var(--color-primary-light)]">
              {faq.question}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-4 h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-6 text-base leading-relaxed text-[var(--color-text-muted)]">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
