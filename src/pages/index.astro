---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Agitate from '../components/Agitate.astro';
import WhyUs from '../components/WhyUs.astro';
import Timeline from '../components/Timeline.astro';
import MiniCases from '../components/MiniCases.astro';

// FAQ Content for Schema (SEO JSON-LD)
const faqItems = [
  { question: 'Kurulum ne kadar sürer?', answer: 'Genellikle 2 gün. Basit entegrasyonlar aynı gün, karmaşık sistemler 1 hafta sürebilir.' },
  { question: 'Veri güvenliği nasıl sağlanır?', answer: 'Müşteri verileri tamamen gizli tutulur, erişimler sınırlıdır. GDPR uyumlu çalışıyoruz.' },
  { question: 'İçeriğin sahipliği kime ait?', answer: 'Üretilen tüm içerikler size aittir. Telif hakkı sorunu yaşamazsınız.' },
  { question: 'Fiyat nasıl belirlenir?', answer: 'İhtiyaç ve entegrasyonlara göre özel paketler sunuyoruz. Ücretsiz analiz sonrası net fiyat alırsınız.' },
  { question: 'Teknik bilgi gerekli mi?', answer: 'Hayır. Tüm süreci biz yönetiyoruz. Sadece iş süreçlerinizi anlamamız yeterli.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Pratik Yapay Zeka – Satış ve Pazarlama Otomasyonu"
  description="Lead'den meeting'e tam otomatik yapay zeka. Outbound & Inbound, içerik ve sosyal medya otomasyonu ile satışlarınızı artırın."
  ogImage="/og/og-homepage.png"
>
  <!-- 1. Hero Section (original copy) -->
  <Hero />

  <!-- 2. Agitate Section (3-tab "why not DIY/inhouse/wait") -->
  <Agitate />

  <!-- 3. Why Us Section (4 GlowCards) -->
  <WhyUs />

  <!-- 4. Timeline Section (5-step end-to-end automation) -->
  <Timeline />

  <!-- 5. Mini Cases Section (6 case study cards) -->
  <MiniCases />

  <!-- 6. FAQ Section (visible rendering — DOM Parity Fix 3.2) -->
  <section class="py-24 relative z-10 bg-[#0F151B]/30 border-t border-[var(--color-border)]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-16 text-center tracking-tight text-[var(--color-text)]">Sıkça Sorulan Sorular</h2>
      <div class="space-y-4">
        {faqItems.map((faq) => (
          <details class="group bg-[var(--color-surface-light)]/40 backdrop-blur-md border border-[var(--color-border)] rounded-2xl overflow-hidden hover:border-[var(--color-primary)]/30 transition-colors">
            <summary class="flex items-center justify-between p-6 cursor-pointer text-lg font-bold text-[var(--color-text)] group-open:text-[var(--color-primary-light)] transition-colors">
              {faq.question}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0 ml-4 transition-transform group-open:rotate-180 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-6 text-[var(--color-text-muted)] leading-relaxed text-base">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
  
  <!-- FAQ Schema.org JSON-LD for rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
