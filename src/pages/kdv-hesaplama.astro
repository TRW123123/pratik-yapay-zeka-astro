---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';
import VatCalculator from '../components/VatCalculator';

const title = 'KDV Hesaplama | KDV Dahil ve Haric Tutar Hesaplama Araci';
const description = 'KDV hesaplama araci ile net tutardan KDV dahil toplam fiyat bulun ya da KDV dahil tutardan matrah ve KDV payini aninda ayristirin.';
const keywords = 'kdv hesaplama, kdv dahil hesaplama, kdv haric hesaplama, matrah hesaplama, kdv dahil fiyattan kdv ayirma';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'KDV dahil tutardan KDV nasil ayristirilir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'KDV dahil tutar, 1 arti KDV oranina bolunerek matrah bulunur. KDV tutarı ise toplamdan matrahin cikartilmasiyla hesaplanir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Ayni belgede farklı KDV oranlari varsa ne yapmak gerekir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Her satiri kendi KDV oranina gore ayri hesaplamak gerekir. Tek bir toplam tutar üzerinden farklı oranli kalemleri sağlıklı ayristirmak doğru sonuç vermez.',
      },
    },
    {
      '@type': 'Question',
      name: 'Bu sayfa sadece hesap araci mi, yoksa hizmet de sunuyor musunuz?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Bu sayfa anlik KDV hesaplamasi için pratik bir araç sunar. Teklif, fatura ve fiyat akisini sürekli olarak manuel yurutuyorsaniz, bu süreci otomatiklestiren hizmetler de sunuyoruz.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Finans ve Teklif Operasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">KDV Hesabini Hızlıca Yapin, Sonra Süreci Sistemlestirin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        KDV dahil ve haric tutarlar arasinda hızlı geçiş yapabilmek günlük operasyon için hala gerekli. Ama ekip sürekli ayni hesaplari teklif, sipariş ve fatura arasinda tekrar ediyorsa asıl sorun hesap değil, sürecin dağınık olmasidir. Bu sayfa ikisini de ayiriyor: önce pratik hesap, sonra operasyonel çözüm.
      </p>
    </section>

    <VatCalculator client:visible />

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Bu araç ne için ideal?</h2>
        <p class="text-muted-foreground">
          Tek bir teklif kalemi, tek oranli bir hizmet bedeli ya da tek tutar üzerinden hızlı matrah-KDV ayrimi yapmak için idealdir.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Ne zaman yetmez?</h2>
        <p class="text-muted-foreground">
          Birden fazla ürün satiri, farklı KDV oranlari, özel iskonto kurallari veya ERP senkronu devreye giriyorsa tekil hesap araci yetmez; is akisinin duzenlenmesi gerekir.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Nerede hizmete doner?</h2>
        <p class="text-muted-foreground">
          Teklif, fiyat, fatura ve onay süreçleri her gün tekrar ediyorsa bu sayfanin devam noktasi manuel hesap değil, fiyatlandirma ve belge otomasyonudur.
        </p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">KDV Hesaplamasi Hangi Noktada Operasyon Sorununa Donusur?</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Teklif hazirlarken:</strong> Ekip, net ve KDV dahil fiyatlari her seferinde farklı Excel dosyalarinda yeniden uretir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Fatura oncesinde:</strong> Sipariş, iskonto ve belge tipi bilgileri farklı kisilerde oldugu için son dakika kontrol ihtiyacı doğar.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>ERP tarafinda:</strong> Matrah, KDV ve toplam tutar önce hesaplanip sonra farklı sisteme tekrar girildiginde hata ve gecikme riski artar.</p>
        </li>
      </ul>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">KDV dahil tutardan KDV nasil ayristirilir?</h3>
          <p class="text-muted-foreground">Toplam tutarı 1 arti KDV oranina bolerek matrahi bulabilirsiniz. KDV tutarı ise toplam ile matrah arasindaki farktir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Ayni belgede farklı KDV oranlari varsa ne yapmak gerekir?</h3>
          <p class="text-muted-foreground">Her satiri kendi oranina gore ayri hesaplamak gerekir. Tek bir toplam rakam üzerinden tüm satirlari doğru ayristirmak sağlıklı sonuç vermez.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa sadece hesap araci mi, yoksa hizmet de sunuyor musunuz?</h3>
          <p class="text-muted-foreground">Bu sayfa önce pratik hesaplama için var. Ama KDV hesabı teklif, sipariş ve fatura akisinizda sürekli tekrar eden bir problemse bunu otomasyon projesine donusturebiliyoruz.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
