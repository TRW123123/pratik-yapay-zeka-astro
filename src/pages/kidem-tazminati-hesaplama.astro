---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Kidem Tazminati Hesaplama | Offboarding ve Fesih Hazirlik Akisi';
const description = 'Kidem tazminati ihtiyaci cogu zaman tek bir hesap degil; cikis karari, belge hazirligi, bordro etkisi ve hukuki surecin birlikte yonetilmesidir.';
const keywords = 'kidem tazminati hesaplama, fesih sureci, offboarding, cikis hesaplamasi, ik cikis hazirligi';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi tazminat hesaplayici mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa, kidem tazminati ihtiyacinin neden cikis sureci ve belge hazirligiyla birlikte ele alinmasi gerektigini anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asil darbogaz nerede cikar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Darbogaz cogu zaman rakamdan once, personel verisinin toparlanmasi, cikis tipinin netlestirilmesi ve ilgili belgelerin dogru akista ilerlemesinde cikar.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler icin daha kritik bir sayfadir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Duzenli personel cikisi yoneten, birden fazla onay ve belge adimi olan IK ve operasyon ekipleri icin daha kritiktir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Offboarding ve Cikis Hazirligi</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Kidem Tazminatini Tek Formul Gibi Degil, Cikis Surecinin Bir Parcasi Olarak Yonetin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Kidem tazminati sorusu ilk bakista tek bir rakam gibi gorunur. Oysa ekiplerin gercekte zorlandigi konu, cikis tipini netlestirmek, gerekli veriyi toparlamak, bordro etkisini gormek ve belge adimlarini zamaninda ilerletmektir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Veri Toplama</h2>
        <p class="text-muted-foreground">Calisma suresi, ucret yapisi, yan hak ve cikis tipi gibi bilgiler daginik kalabilir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Cikis Kurgusu</h2>
        <p class="text-muted-foreground">Hangi senaryoda neyin hazirlanacagi, kimin onay verecegi ve hangi belgenin gerekli oldugu net olmayabilir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Bordro ve Belge</h2>
        <p class="text-muted-foreground">Hesap bilgisi bordro, tahakkuk ve belge tarafina duzenli akmiyorsa son dakika riski artar.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Kidem Tazminati Ihtiyacinin Buyudugu Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Cok adimli cikislarda:</strong> IK, yonetici, finans ve gerekirse hukuk ayni dosya uzerinde ilerler.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Son dakika cikis kararlarinda:</strong> Belgeler ve hesap bilgisi hizli hazirlanmak zorunda kalir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Tekrarlayan dosyalarda:</strong> Ayni cikis adimlari her seferinde sifirdan koordine ediliyorsa ekip yipraniyor demektir.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asil Cozum</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Kidem tazminati bizim icin yalnizca bir hesap degil, offboarding akisinin temel dugumlerinden biridir. Bu nedenle deger, cikis verisinin toparlanmasi, hesap bilgisinin gorunur hale gelmesi ve belge-bordro akisina dogru sekilde baglanmasinda ortaya cikar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Cikis Checklisti</h3>
          <p class="text-sm text-muted-foreground">Hangi bilgi ve belge olmadan dosyanin ilerlemeyecegi netlesir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Tahakkuk Gorunurlugu</h3>
          <p class="text-sm text-muted-foreground">Hesap bilgisi bordro ve odeme tarafina daha erken baglanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Belge Hazirligi</h3>
          <p class="text-sm text-muted-foreground">Fesih ve cikis evraklari daha sistemli ilerleyen bir akis haline gelir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi tazminat hesaplayici mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa, kidem tazminati ihtiyacinin neden cikis sureci ve belge hazirligiyla birlikte ele alinmasi gerektigini anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asil darbogaz nerede cikar?</h3>
          <p class="text-muted-foreground">Darbogaz cogu zaman rakamdan once, personel verisinin toparlanmasi ve belge akisinin dogru kurulmasinda cikar.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler icin daha kritik bir sayfadir?</h3>
          <p class="text-muted-foreground">Duzenli personel cikisi yoneten, birden fazla onay ve belge adimi olan IK ve operasyon ekipleri icin daha kritiktir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
