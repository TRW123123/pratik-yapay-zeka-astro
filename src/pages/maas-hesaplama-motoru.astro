---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';


const title = "Maaş Hesaplama Motoru (Brütten Nete, Netten Brüte) | Pratik Yapay Zeka";
const description = "Güncel SGK tavanı, vergi dilimleri ve BES kesintileriyle 2026 yılı için sıfır hatayla brütten nete veya netten brüte maaş hesaplayan yapay zeka destekli İK aracı.";
const keywords = "maaş hesaplama motoru, brütten nete hesaplama, netten brüte maaş hesaplama, agi hesaplama, sgk kesintisi";

// FAQ Schema
const faqData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Bes ve İcra kesintileri maaş hesaplamasına otomatik dahil edilebilir mi?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Evet, yapay zeka destekli otonom bordro sistemimiz personelin özlük dosyasındaki BES, nafaka veya icra gibi yasal kesintileri takip ederek net yatırılacak tutarı sıfır hatayla hesaplar."
      }
    },
    {
      "@type": "Question",
      "name": "Maaş hesaplama motorunuz güncel 2026 asgari ücret istisnasını hesaplıyor mu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kesinlikle. Her yıl güncellenen asgari ücret gelir vergisi istisnası, damga vergisi muafiyeti ve güncel SGK taban/tavan matrahları robotumuza otomatik olarak entegre edilir."
      }
    },
    {
      "@type": "Question",
      "name": "Bu hesaplamaları bir bordro programına nasıl aktarabilirim?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Hesaplama motorumuz tekil işlemler için tasarlanmıştır. Ancak 'Finansal İK Yapay Zekası' çözümümüz ile Logo, Zirve veya Mikro gibi sistemlere entegre olarak yüzlerce personelin maaşını tek tıkla bordrolaştırabilirsiniz."
      }
    }
  ]
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <!-- Hero Section -->
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 border-primary text-primary mb-4">İK ve Finans Otomasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Maaş Hesaplamada Hata ve Manuel Giriş Riskini Sıfırlayın</h1>
      <p class="text-xl text-muted-foreground leading-relaxed mb-8">
        "Şu personelin net maaşı ne kadar olur? Vergi dilimine girerse maliyeti ne kadar artar?" soruları için Excel formülleriyle boğuşmaktan yoruldunuz mu? Sadece brütten nete maaş hesaplayan bir robot kullanmak yerine, hesaplamaları otonom yöneten ve bordro sisteminize entegre eden İK Yapay Zekası ile tanışın.
      </p>
    </section>

    <!-- The Pain Points -->
    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Neden Geleneksel Maaş Hesaplamaları Şirketinize Zarar Verir?</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <svg class="w-6 h-6 text-destructive flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <p><strong>Değişen Vergi Mevzuatı:</strong> SGK tavanları ve gelir vergisi dilimleri sürekli güncellenir. Excel'de formülü güncellemeyi unutmak, eksik vergi ödenmesine ve idari cezalara neden olur.</p>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-6 h-6 text-destructive flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <p><strong>Cevaplanamayan Simülasyonlar:</strong> Şirket yöneticisi "Tüm ekibe %20 zam yaparsam Ekim ayındaki vergi maliyeti bütçemi ne kadar aşar?" diye sorduğunda, saatlerce manuel hesap yapmanız gerekir.</p>
        </li>
        <li class="flex items-start gap-3">
          <svg class="w-6 h-6 text-destructive flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <p><strong>Manuel Veri Aktarımı:</strong> Hesaplanan maaş verilerinin bordro onay sistemine kopyalanıp yapıştırılması her ay personel başına ekstra veri giriş eforu gerektirir.</p>
        </li>
      </ul>
    </section>

    <!-- The Solution -->
    <section>
      <h2 class="text-3xl font-bold mb-6">Maaş Hesaplayan Değil, Bordro Sürecini Yöneten Otonom Zeka</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Pratik Yapay Zeka'nın "Finans ve İK Asistanı", basit bir hesap makinesi değildir. Doğrudan sizin ERP veya muhasebe veritabanınıza konuşan akıllı bir analiz katmanıdır.
      </p>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">🤖</span>
          </div>
          <h3 class="text-xl font-semibold mb-2">WhatsApp Maaş Simülatörü</h3>
          <p class="text-sm text-muted-foreground">"Mehmet Bey'e 80.000 TL net maaş verirsek Ağustos ayı brütü ne olur?" sorusunu WhatsApp'tan yazın, AI size tabloyu hazırlayıp anında dönsün.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">⚡</span>
          </div>
          <h3 class="text-xl font-semibold mb-2">Sıfır Mevzuat Uyum Riski</h3>
          <p class="text-sm text-muted-foreground">Yeni vergi dilimleri, asgari ücret istisnası veya BES kesinti kuralları değiştiğinde sistem kendini Resmi Gazete'den otonom günceller.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <span class="text-2xl">📊</span>
          </div>
          <h3 class="text-xl font-semibold mb-2">Oto-Bordro Entegrasyonu</h3>
          <p class="text-sm text-muted-foreground">Maaş zamlarını ve hesaplamaları onayladığınız an, sistem bu verileri Logo, Zirve veya Mikro gibi sistemlere tek tıkla e-Bordro olarak gönderir.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sıkça Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bes ve İcra kesintileri maaş hesaplamasına otomatik dahil edilebilir mi?</h3>
          <p class="text-muted-foreground">Evet, yapay zeka destekli otonom bordro sistemimiz personelin özlük dosyasındaki BES, nafaka veya icra gibi yasal kesintileri takip ederek net yatırılacak tutarı sıfır hatayla hesaplar.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Maaş hesaplama motorunuz güncel 2026 asgari ücret istisnasını hesaplıyor mu?</h3>
          <p class="text-muted-foreground">Kesinlikle. Her yıl güncellenen asgari ücret gelir vergisi istisnası, damga vergisi muafiyeti ve güncel SGK taban/tavan matrahları robotumuza otomatik olarak entegre edilir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu hesaplamaları bir bordro programına nasıl aktarabilirim?</h3>
          <p class="text-muted-foreground">Hesaplama motorumuz tekil işlemler için tasarlanmıştır. Ancak 'Finansal İK Yapay Zekası' çözümümüz ile Logo, Zirve veya Mikro gibi sistemlere entegre olarak yüzlerce personelin maaşını tek tıkla bordrolaştırabilirsiniz.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
