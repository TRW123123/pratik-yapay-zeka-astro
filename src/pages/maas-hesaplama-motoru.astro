---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Maas Hesaplama Motoru | Brut-Net Senaryo ve Bordro Sureci';
const description = 'Maas hesaplama motoru arayan ekipler icin asil sorun tek bir hesap degil; brut-net senaryolari, zam kararlarini ve bordro etkisini hizli gorebilmektir.';
const keywords = 'maas hesaplama motoru, brutten nete, netten brute maas, maas senaryosu, bordro otomasyonu';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa resmi bordro hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa maas hesaplama ihtiyacinin operasyon tarafini aciklar ve brut-net senaryolarinin neden surec sorunu haline geldigini anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Ne zaman tekil hesap yetmez?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Birden fazla personel, farkli yan haklar, zam senaryolari veya bordro onay akisiniz varsa tekil hesap yeterli olmaz; surecin birlikte ele alinmasi gerekir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Bu konu hangi ekipler icin kritik hale gelir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'IK, finans ve yonetim ayni anda maas senaryolari, isveren maliyeti ve bordro etkisi gormek istediginde kritik hale gelir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">IK ve Bordro Operasyonu</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Maas Hesabini Tek Formulden Cikarip Karar Surecine Tasiyin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Maas hesaplama motoru arayan ekipler genelde tek bir rakam degil; zam, brut-net gecis, yeni ise alim ve bordro etkisini hizli anlamak ister. Sorun yalnizca hesap degil, ayni sorularin tekrar tekrar IK, finans ve yonetim arasinda dolasmasidir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Ne oluyor?</h2>
        <p class="text-muted-foreground">
          Yoneticiler zam senaryosu soruyor, personel brut-net farkini merak ediyor, IK ise ayni hesaplari farkli dosyalarda tekrar yapiyor.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Neden buyuyor?</h2>
        <p class="text-muted-foreground">
          Maas sorulari tek kisilik bir hesap olmaktan cikiyor; yan hak, prim, donemsel degisim ve bordro takvimine baglaniyor.
        </p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Nereye donusur?</h2>
        <p class="text-muted-foreground">
          Eger ayni hesaplar surekli tekrarlaniyorsa konu artik hesap makinesi degil, IK-yardim masasi ve bordro operasyonu problemidir.
        </p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Maas Hesaplama Ihtiyaci Hangi Noktada Operasyon Yukune Donusur?</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Zam donemlerinde:</strong> Birden fazla senaryo ayni anda degerlendirilir ve ekipler hizli brut-net cevabi ister.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Ise alim surecinde:</strong> Adaya teklif verirken net maas, toplam maliyet ve bordro etkisi ayni anda gormek gerekir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Personel sorularinda:</strong> Vergi dilimi, yan hak ve kesinti sorulari IK ekibi icin tekrar eden destek talebine donusur.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Buradaki Asil Cozum Sayfasi Neye Isaret Ediyor?</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Maas hesaplama motoru tek basina bir son urun degil. Bizim acimizdan bu sayfa, brut-net senaryo sorularini, personel destek yukunu ve bordroya giden veri akislarini daha sistemli hale getiren IK otomasyon katmanina acilan bir gecis noktasi.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Senaryo Hizlandirma</h3>
          <p class="text-sm text-muted-foreground">Zam, teklif ve yeni ise alim senaryolari ayni mantikla daha hizli degerlendirilir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">IK Yardim Masasi</h3>
          <p class="text-sm text-muted-foreground">Tekrar eden brut-net ve bordro sorulari kisilere degil, daha sistemli bir yardim akisine baglanir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Bordroya Gecis</h3>
          <p class="text-sm text-muted-foreground">Senaryo ve hesap tarafinda toplanan bilgiler bordro surecinden kopuk kalmaz.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa resmi bordro hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa maas hesaplama ihtiyacinin operasyon tarafini aciklar ve bu ihtiyacin neden IK ve bordro surecine baglandigini anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Ne zaman tekil hesap yetmez?</h3>
          <p class="text-muted-foreground">Birden fazla personel, farkli yan haklar, zam senaryolari veya bordro onay akisiniz varsa tekil hesap yeterli olmaz; konu surec tasarimina doner.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu konu hangi ekipler icin kritik hale gelir?</h3>
          <p class="text-muted-foreground">IK, finans ve yonetim ayni anda maas senaryolari, isveren maliyeti ve bordro etkisi gormek istediginde kritik hale gelir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
