    { title: "Yapay Zeka İçerik Motoru", description: "Sizin dilinize uygun içerik ve e-posta taslaklarını otomatik hazırlayacak sistemi eğitiyoruz." },
    { title: "Canlı Yayına Alma", description: "Tüm sistemi test edip reklamlardan gelen trafiği anında karşılayacak şekilde aktive ediyoruz." }
  ]}
  featuresTitle="Büyümenizi Hızlandıracak Yapay Zeka Özellikleri"
  features={[
    { title: "Anında Lead Karşılama", description: "Müşteri Instagram'da formu doldurduğu saniye, adına özel WhatsApp mesajı telefonuna düşer." },
    { title: "Otomatik Nurturing Sistemi", description: "Sıcak olmayan müşterilere haftada bir değer katan, otomatize edilmiş kişisel e-posta serileri gönderilir." },
    { title: "Sosyal Medya Otomasyonu", description: "Blog yazılarınız veya şirket haberleriniz otomatik olarak LinkedIn ve Instagram formatına çevrilip planlanır." },
    { title: "Detaylı Metrik Takibi", description: "Hangi kampanyadan, hangi otomasyon mesajından kaç para kazandığınızı canlı tablolarla görürsünüz." }
  ]}
  benefitsTitle="Ölçülebilir Pazarlama ROI'si"
  benefits={[
    "%300", "Potansiyel müşteriye dönüş hızındaki artış sayesinde artan reklam verimliliği (ROAS).",
    "40 Saat", "Her ay sosyal medya ve e-posta kampanyaları oluştururken harcanan zamandan tasarruf.",
    "Sıfır Sızıntı", "Sisteme giren hiçbir müşterinin unutulmadan veya gözden kaçmadan takip edilmesi."
  ]}
  caseStudyDescription="Y Ajansı, manuel lead takibi yüzünden ayda %30 potansiyel müşteriyi kaçırıyordu. Otomasyon sonrası geri dönüş hızı 1 saniyeye indi ve reklam ROI'si 3 katına çıktı."
  finalCtaTitle="Uyumayan Pazarlama Makinenizi Kuralım"
