---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yapay Zeka ile Pazarlama Otomasyonu" description="SEO, içerik ve sosyal medya otomasyonu ile işletmelerin dijital büyümesini hızlandırıyoruz.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">Yapay Zeka ile Pazarlama Otomasyonu</h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">SEO, içerik üretimi ve sosyal medya otomasyonu ile işletmenizin dijital büyümesini hızlandırın.</p>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/cozumler/pazarlama-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Pazarlama Otomasyonu</h2>
        <p class="text-sm text-[var(--color-text-muted)]">İçerik, sosyal medya ve reklam optimizasyonu.</p>
      </a>
      <a href="/cozumler/lead-generation/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Lead Üretimi</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Yapay zeka ile otomatik B2B lead kazanımı.</p>
      </a>
      <a href="/blog/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Blog & İçgörüler</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Pazarlama otomasyonu hakkında makaleler.</p>
      </a>
    </div>
  </section>
</BaseLayout>
