---
import SolutionLayout from '../layouts/SolutionLayout.astro';
---
<SolutionLayout
  title="Mutabakat Mektubu Otomasyonu | BA-BS ve Bakiye Follow-Up Akisi"
  description="Mutabakat mektubu surecinde asil problem mektubun PDF'i degil; gonderim, cevap toplama, takip ve uyumsuzluk yonetiminin dağinik kalmasidir."
  heroTitle="Mutabakat Mektubunu Belge Olarak Degil, Takip Sureci Olarak Yonetin"
  heroSubtitle="Bayi, musteri veya tedarikcilerle mutabakat almak icin tek tek e-posta kovalamak zorunda kalmayin. Biz mutabakat mektubu gonderimi, cevap takibi, follow-up ve uyumsuzluk yonetimini daha sistemli hale getiren finans akislari kuruyoruz."
  problems={[
    "Mutabakat mektuplarinin toplu gonderildikten sonra kimin cevap verdigi, kimin vermedigi ve hangi firmada uyumsuzluk oldugunun daginik takip edilmesi.",
    "E-postayla gelen serbest metinli yanitlarin ekip icinde elle yorumlanmasi ve ilgili cariyle eslestirilmesinin zaman almasi.",
    "Ay sonu kapanisa yaklasirken follow-up ve hatirlatma surecinin kisi hafizasina bagli kalmasi."
  ]}
  processTitle="Mutabakat Takip Akisi Nasil Sistemlestiriliyor?"
  processSteps={[
    { title: "Liste ve Gonderim Hazirligi", description: "Hangi cari gruplarina hangi formatla cikilacagi belirlenir; mutabakat cikti ve kanal mantigi standartlasir." },
    { title: "Cevap ve Durum Takibi", description: "Gelen yanitlar ilgili cariyle eslestirilir; cevaplandi, cevap bekleniyor ve uyumsuzluk var gibi durumlar netlesir." },
    { title: "Follow-Up Sekansi", description: "Yanitsiz kalan veya eksik donen firmalar icin otomatik hatirlatma akislari kurulur." },
    { title: "Uyumsuzluk ve Kapanis Yonetimi", description: "Fark cikan hesaplar ayrı isaretlenir; ekip kapanisa giderken sadece sorunlu dosyalara odaklanir." }
  ]}
  featuresTitle="Mutabakat Mektubunda Asil Deger Ureten Yapi"
  features={[
    { title: "Toplu Gonderim Disiplini", description: "Hangi cari grubuna ne zaman cikildigi ve ne döndugu tek akista izlenebilir hale gelir." },
    { title: "Yanıt Siniflama", description: "Basit onay, fark bildirimi veya geri donus bekliyor gibi durumlar ekip icin daha görünür olur." },
    { title: "Takip ve Hatirlatma", description: "Mutabakat sureci tek seferlik mail degil, planli bir follow-up akisina donusur." },
    { title: "Finans Ekibi Odagi", description: "Ekip tum listeyi elle kovalamak yerine yalnizca fark cikan ve kapanis riski olan dosyalara odaklanir." }
  ]}
  benefitsTitle="Mutabakat Surecindeki Net Kazanc"
  benefits={[
    "Daha Hızlı Kapanis", "Uyumsuz olmayan dosyalar daha erken temizlenir; ekip kapanisa daha kontrollu ilerler.",
    "%100", "Durum görünürlüğü. Kim cevap verdi, kim bekliyor, kimde fark var daha net gorulur.",
    "Daha Az Takip Yuku", "Finans ekibinin e-posta kovalamaya ayirdigi zaman belirgin bicimde azalir."
  ]}
  caseStudyDescription="Aylik mutabakat listelerini manuel takip ettigi icin kapanis döneminde zorlanan bir ekip, gonderim ve follow-up akislarini sistemlestirdikten sonra hangi cari dosyalarina odaklanmasi gerektigini daha erken gormeye basladi."
  finalCtaTitle="Mutabakat Surecinizi PDF Gonderiminden Ileri Tasiyalim"
  finalCtaSubtitle="Mevcut mutabakat akisinizi birlikte cikaralim; gonderim, cevap toplama ve fark yonetiminde hangi adimlarin en cok zaman kaybettirdigini netlestirelim."
  sectorTheme="muhasebe"
  faqs={[
    { question: "Bu sayfa sadece BA-BS icin mi uygun?", answer: "Hayir. BA-BS en net orneklerden biri olsa da, bakiye ve hesap onayi gerektiren bircok cari mutabakat sureci icin ayni mantik kullanilabilir." },
    { question: "Serbest e-posta cevaplari da surece dahil olabilir mi?", answer: "Evet. Ozellikle yanitlar standart portal akisi disinda geliyorsa bunlari siniflamak ve ilgili cariyle eslestirmek en degerli alanlardan biridir." },
    { question: "Tum surec tamamen otomatik ilerlemek zorunda mi?", answer: "Hayir. Hedef, rutin gonderim ve takip yukunu azaltmak; farkli ve riskli dosyalari ise ekip kontrolunde tutmaktir." }
  ]}
  sectorName="Mutabakat ve Follow-Up"
/>
