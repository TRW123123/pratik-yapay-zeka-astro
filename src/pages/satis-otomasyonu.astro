---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yapay Zeka ile Satış Otomasyonu" description="Yapay zeka ve otomasyon ile B2B satış süreçlerinizi optimize edin. Outbound, CRM ve takip otomasyonu.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">Yapay Zeka ile Satış Otomasyonu</h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">Outbound, CRM entegrasyonu ve akıllı takip ile B2B satış süreçlerinizi otomatikleştirin.</p>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/cozumler/satis-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Satış Otomasyonu</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Outbound, takipler ve CRM senkronizasyonu.</p>
      </a>
      <a href="/cozumler/lead-generation/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Lead Üretimi</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Yapay zeka ile otomatik B2B lead kazanımı.</p>
      </a>
      <a href="/vaka-calismalari/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Başarı Hikayeleri</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Gerçek müşterilerden satış otomasyonu sonuçları.</p>
      </a>
    </div>
  </section>
</BaseLayout>
