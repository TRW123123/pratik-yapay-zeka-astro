---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'SGK Hizmet Dökümü | Belge Dogrulama ve Aday Kontrol Akışı';
const description = 'SGK hizmet dökümü ihtiyacı çoğu zaman belgeyi okumaktan çok, aday beyanini, çalışma gecmisini ve dogrulama adımlarını daha düzenli yönetme ihtiyacidir.';
const keywords = 'sgk hizmet dökümü, sgk dökümü kontrolu, aday dogrulama, background check, çalışma gecmisi dogrulama';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa SGK dökümü indirme araci mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayır. Bu sayfa, SGK hizmet dokumunun IK, risk ve dogrulama sürecinde nasıl kullanildigini ve operasyonel olarak hangi noktada değer urettigini anlatır.',
      },
    },
    {
      '@type': 'Question',
      name: 'En çok hangi ekipler için kritiktir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Aday dogrulama yapan IK ekipleri, sahada personel alan operasyonlar ve belge tabanlı risk kontrolu yapan yapilar için daha kritiktir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asıl sorun belgeyi okumak mi, süreci yonetmek mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Çoğu zaman asıl sorun belgeyi acmak değil; çalışma gecmisini, aday beyanini ve kontrol sonucunu düzenli bir karar akisina baglamaktir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Aday ve Risk Dogrulama</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">SGK Hizmet Dokumunu Dosya Olarak Değil, Dogrulama Sürecinin Bir Parçası Olarak Kullanin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        SGK hizmet dökümü aramasi yapan kullanici genelde sadece PDF okumak istemez. Asıl ihtiyac, adayin veya calisanin beyan ettigi gecmisi kontrol etmek, supheli farklari görmek ve bu belgeyi IK kararina daha düzenli baglamaktir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Belgeyi Acmak</h2>
        <p class="text-muted-foreground">Tek basina dökümü görmek kolaydir; zor olan çalışma surelerini, kopukluklari ve beyanla iliskisini anlamaktir.</p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Beyanla Karsilastirmak</h2>
        <p class="text-muted-foreground">CV, basvuru formu ve resmi belge birbirinden farklı bilgi tasiyabilir; asıl karar değeri bu farklarda ortaya çıkar.</p>
      </div>
      <div class="rounded-sm border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Karara Baglamak</h2>
        <p class="text-muted-foreground">Belge kontrolu sonucta bir evrak inceleme isi değil, ise alim ve risk değerlendirme karari destekleme isidir.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-sm border border-border">
      <h2 class="text-2xl font-semibold mb-6">SGK Hizmet Dökümü Hangi Noktada Operasyonel Soruna Donusur?</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Yüksek hacimli alimlarda:</strong> Çok sayida aday için belge kontrolu manuel ilerlediginde süreç yavaslar.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Sahadaki rollerde:</strong> Devamsizlik, sik is degistirme veya beyan farklari daha kritik hale gelir.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Belge agirlikli sureclerde:</strong> Kontrol sonucu notlara, e-postalara ve kisilerin hafizasina dagildiginda tekrar is artar.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Asıl Gittigi Çözüm</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Bu konu bizim için bir dokuman okuma probleminden çok, aday ve personel dogrulama akisidir. SGK hizmet dökümü; belge alma, kârşılaştırma, not dusme ve karar destek adimlariyla birlikte ele alindiginda anlamli hale gelir.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Belge Okuma ve Ayiklama</h3>
          <p class="text-sm text-muted-foreground">Süre ve kayit bilgileri daha okunabilir ciktiya donusturulur.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Beyan Kârşılaştırma</h3>
          <p class="text-sm text-muted-foreground">Adayin anlattigi geçmiş ile resmi kayit arasindaki farklar görünür hale gelir.</p>
        </div>
        <div class="bg-card p-6 rounded-sm border border-border">
          <h3 class="text-xl font-semibold mb-2">Karar Takibi</h3>
          <p class="text-sm text-muted-foreground">Kontrol sonucu ilgili IK ve operasyon akisina daha düzenli aktarilir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa SGK dökümü indirme araci mi?</h3>
          <p class="text-muted-foreground">Hayır. Bu sayfa, SGK hizmet dokumunun IK ve risk kontrol sürecinde nasıl kullanildigini ve hangi noktada süreç problemine donustugunu anlatır.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">En çok hangi ekipler için kritiktir?</h3>
          <p class="text-muted-foreground">Aday dogrulama yapan IK ekipleri, saha operasyonlari ve belge temelli risk kontrolu yapan yapilar için daha kritiktir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asıl sorun belgeyi okumak mi, süreci yonetmek mi?</h3>
          <p class="text-muted-foreground">Çoğu durumda asıl sorun belgeyi acmak değil; sonucu karar sürecine düzenli baglamaktir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
