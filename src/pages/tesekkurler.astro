---
import BaseLayout from '../layouts/BaseLayout.astro';

const submissionType = Astro.url.searchParams.get('tip') || '';
const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'İletişim', url: '/iletisim/' },
  { name: 'Teşekkürler', url: '/tesekkurler/' },
];

const isResourceRequest = submissionType === 'resource';
---

<BaseLayout
  title="Teşekkürler | Pratik Yapay Zeka"
  description="Talebiniz bize ulaştı. Ekibiniz için en uygun otomasyon alanlarını geri dönmek üzere inceleyeceğiz."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <section data-santral-reveal class="flex min-h-[70vh] items-center py-24">
    <div class="container mx-auto max-w-3xl px-6 lg:px-10 text-center">
      <div class="santral-hat p-10 md:p-14">
        <div class="mx-auto flex items-center justify-center gap-3 mb-8">
          <span class="inline-block h-[8px] w-[8px] rounded-full bg-[var(--color-patina-copper-bright)]" style="animation: morse-pulse 2.2s ease-in-out infinite"></span>
          <span class="font-mono text-[0.72rem] tracking-[0.18em] uppercase text-[var(--color-patina-copper-bright)]">Bağlantı · Kuruldu</span>
        </div>

        <h1 class="santral-display text-4xl md:text-5xl" style="font-weight:400;text-wrap:balance">
          Talebiniz bize <em class="santral-italic">ulaştı</em>.
        </h1>
        <p class="mt-6 santral-body text-lg md:text-xl max-w-xl mx-auto">
          {isResourceRequest
            ? 'Checklist talebiniz bize ulaştı. Kaynağı ve sonraki yönlendirmeyi size en kısa sürede paylaşacağız.'
            : 'Gönderdiğiniz bilgiler için teşekkürler. Uygun otomasyon alanlarını ve en mantıklı ilk adımı değerlendirip size geri döneceğiz.'}
        </p>

        <div class="mt-10 grid gap-4 text-left md:grid-cols-2">
          <div class="border border-[var(--color-hairline)] bg-[var(--color-void-ink-deep)]/55 p-6" style="border-radius:2px">
            <span class="santral-overline block mb-3">Bu sırada · 01</span>
            <h2 class="santral-display text-lg" style="font-weight:500">Ne oluyor?</h2>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">
              {isResourceRequest
                ? 'Talebinizi kaydedip size checklisti ve isterseniz uygun sonraki adımı iletecek şekilde hazırlıyoruz.'
                : 'Talebinizi sayfa kaynağı ve ihtiyaç alanına göre inceleyip size uygun bir sonraki adımı hazırlıyoruz.'}
            </p>
          </div>
          <div class="border border-[var(--color-hairline)] bg-[var(--color-void-ink-deep)]/55 p-6" style="border-radius:2px">
            <span class="santral-overline block mb-3">Bu sırada · 02</span>
            <h2 class="santral-display text-lg" style="font-weight:500">Ne yapabilirsiniz?</h2>
            <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">
              {isResourceRequest
                ? 'Bu arada çözüm sayfalarımızı veya vaka çalışmalarımızı inceleyerek hangi alana daha yakın olduğunuzu görebilirsiniz.'
                : 'Bu arada vaka çalışmalarımızı inceleyebilir veya bize doğrudan e-posta gönderebilirsiniz.'}
            </p>
          </div>
        </div>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href={isResourceRequest ? '/cozumler/' : '/vaka-calismalari/'} class="santral-salter">
            {isResourceRequest ? 'Çözüm sayfalarını incele' : 'Vaka çalışmalarını incele'}
          </a>
          <a href="mailto:s.tepecik@pratik-yapayzeka.com" class="santral-salter santral-salter-copper">
            E-posta gönder
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
