---
import BaseLayout from '../layouts/BaseLayout.astro';

const sourcePage = Astro.url.searchParams.get('kaynak') || '';

const breadcrumbs = [
  { name: 'Ana Sayfa', url: '/' },
  { name: 'Ücretsiz Checklist', url: '/ucretsiz-otomasyon-checklistesi/' },
];
---

<BaseLayout
  title="Ücretsiz Otomasyon Öncelik Checklisti | Pratik Yapay Zeka"
  description="Hangi surecinizde otomasyonun önce ele alınması gerektiğini görmek için ücretsiz öncelik checklistini talep edin."
  breadcrumbs={breadcrumbs}
>
  <section data-santral-reveal class="relative overflow-hidden pt-28 pb-16 md:pt-36 md:pb-24">
    <div class="pointer-events-none absolute -top-32 right-[-10%] h-[420px] w-[520px] rounded-full opacity-[0.14] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>
    <div class="container relative z-10 mx-auto max-w-6xl px-6 lg:px-10">
      <div class="flex items-center gap-4 mb-10">
        <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
        <span class="santral-overline">Brief · Ücretsiz Checklist</span>
      </div>
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="space-y-8">
          <div class="space-y-5">
            <h1 class="santral-display text-4xl md:text-6xl leading-[1.05]" style="font-weight:400;text-wrap:balance">
              Ücretsiz otomasyon öncelik <em class="santral-italic">checklisti</em> alın.
            </h1>
            <p class="max-w-2xl santral-body text-lg md:text-xl">
              Bu checklist, ekibinizde hangi sürecin en çok zaman yediğini, nerede tekrar iş oluştuğunu ve hangi otomasyon adımının önce ele alınması gerektiğini daha net görmenize yardım eder.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-3">
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 01</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">Süreci puanlayın</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">Tekrar işi, gecikme, hata riski ve ekip bağımlılığını hızlı şekilde değerlendirin.</p>
            </div>
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 02</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">Darboğazı bulun</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">CRM, marketing, finans, WhatsApp veya iç operasyon tarafında asıl sıkışanı görün.</p>
            </div>
            <div class="santral-hat p-6">
              <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">Adım · 03</p>
              <h2 class="mt-3 santral-display text-xl" style="font-weight:500">İlk adımı seçin</h2>
              <p class="mt-3 text-sm leading-relaxed text-[var(--color-paper-ecru-dim)]">Tüm işleri aynı anda değil, en hızlı geri dönüş verecek ilk düğümü seçin.</p>
            </div>
          </div>

          <div class="santral-hat p-8">
            <span class="santral-overline block mb-4">İçerik · 04</span>
            <h2 class="santral-display text-2xl" style="font-weight:500">Checklistte neler var?</h2>
            <ul class="mt-5 space-y-3 text-[var(--color-paper-ecru-dim)]">
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>Tekrar iş ve darboğaz tespiti için puanlama mantığı</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>Süreç önceliklendirme matrisi</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>Hangi işler otomasyon için uygun, hangileri değil ayrımı</span></li>
              <li class="flex items-start gap-3"><span class="mt-2 h-[6px] w-[6px] rounded-full bg-[var(--color-patina-copper-bright)] shrink-0"></span><span>İlk 30 günlük uygulama notları</span></li>
            </ul>
          </div>
        </div>

        <div class="santral-hat p-8">
          <div class="mb-6">
            <span class="santral-overline block">Talep · 05</span>
            <h2 class="mt-3 santral-display text-3xl" style="font-weight:500">Checklisti <em class="santral-italic">isteyin</em></h2>
            <p class="mt-3 santral-body leading-relaxed">
              Kısa formu bırakın. Checklisti size gönderelim ve isterseniz hangi satırın sizin için en kritik olduğunu da birlikte netleştirelim.
            </p>
          </div>

          <form
            name="resource-checklist-request"
            method="POST"
            action="/tesekkurler/?tip=resource"
            data-netlify="true"
            netlify-honeypot="bot-field"
            class="space-y-5"
          >
            <input type="hidden" name="form-name" value="resource-checklist-request" />
            <input type="hidden" name="resource_name" value="otomasyon-oncelik-checklistesi" />
            <input type="hidden" name="source_page" value={sourcePage || '/ucretsiz-otomasyon-checklistesi/'} />
            <p class="hidden">
              <label>Bu alani doldurmayin: <input name="bot-field" /></label>
            </p>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Ad Soyad</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="text" name="name" autocomplete="name" required />
              </label>

              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">E-posta</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="email" name="email" autocomplete="email" required />
              </label>
            </div>

            <div class="grid gap-5 sm:grid-cols-2">
              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Şirket</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="text" name="company" autocomplete="organization" />
              </label>

              <label class="space-y-2">
                <span class="text-sm font-medium text-[var(--color-text)]">Rolunuz</span>
                <input class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" type="text" name="role" placeholder="Kurucu, operasyon, satış..." />
              </label>
            </div>

            <label class="space-y-2">
              <span class="text-sm font-medium text-[var(--color-text)]">En çok zorlandiginiz alan</span>
              <select class="w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" name="interest_area" required>
                <option value="">Bir alan seçin</option>
                <option value="crm-sales">CRM ve satış operasyonu</option>
                <option value="marketing-leads">Marketing ve lead yönetimi</option>
                <option value="finance-accounting">Finans ve muhasebe operasyonu</option>
                <option value="whatsapp-chatbot">WhatsApp ve chatbot akislar</option>
                <option value="ecommerce-ops">E-ticaret ve operasyon</option>
                <option value="other">Diğer</option>
              </select>
            </label>

            <label class="space-y-2">
              <span class="text-sm font-medium text-[var(--color-text)]">Kısa not</span>
              <textarea class="min-h-32 w-full rounded-sm border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-[var(--color-text)] outline-none transition focus:border-[var(--color-primary)]" name="message" placeholder="Örnek: teklifler dağinik, leadler geri donmeden kayboluyor, belge girişi çok manuel..."></textarea>
            </label>

            <button type="submit" class="inline-flex w-full items-center justify-center rounded-sm bg-[var(--color-primary)] px-6 py-4 text-lg font-black text-black transition hover:-translate-y-0.5 hover:bg-[var(--color-primary-light)]">
              Checklisti gonderin
            </button>

            <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">
              Bu form bir satış baskisi değil. Amacimiz önce size yararli bir giriş noktasi vermek ve isterseniz ondan sonra bir sonraki adımı konusmak.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
