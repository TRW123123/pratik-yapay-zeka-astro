---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildContactHref } from '../../lib/contactHref';

const caseStudies = [
  {
    href: '/vaka-calismalari/acilsatis/',
    title: 'Acilsatis',
    description: 'Hızlı bilinirlik ve daha istikrarli trafik.',
    metric: '+%45 görünürlük',
  },
  {
    href: '/vaka-calismalari/car-studio-ai/',
    title: 'Car Studio AI',
    description: 'Ekip buyutmeden yeni pazarlara acilma.',
    metric: '3x pazar genişlemesi',
  },
  {
    href: '/vaka-calismalari/salevium/',
    title: 'Salevium',
    description: 'Içerik üretimi saatlerden dakikalara indi.',
    metric: '%90 zaman tasarrufu',
  },
  {
    href: '/vaka-calismalari/erpa-teknoloji/',
    title: 'ERPA Teknoloji',
    description: 'Yapay zeka destekli stratejik Avrupa pazari girişi.',
    metric: 'Ilk ayda meetingler',
  },
  {
    href: '/vaka-calismalari/cemkimsan/',
    title: 'Cemkimsan',
    description: '20+ ulkede satış ve pazarlama kampanyalari.',
    metric: '6 yeni firsat',
  },
  {
    href: '/vaka-calismalari/dkm-coach-bilge/',
    title: 'DKM Coach Bilge',
    description: 'Oyun formatinda lead funnel ile yuzlerce ek lead.',
    metric: '+300 lead',
  },
];

const caseIndexContactHref = buildContactHref({
  source: '/vaka-calismalari/',
  packageName: 'lead-flow-audit',
  area: 'marketing-leads',
  cta: 'case-index-final-panel',
});
---

<BaseLayout
  title="Vaka Çalışmaları - Başarı Hikayeleri | Pratik Yapay Zeka"
  description="Yapay zeka otomasyonu ile büyüyen sirketlerden gerçek vaka çalışmaları. %90 zaman tasarrufu, +300 lead ve 3x pazar genişlemesi gibi somut sonuçlar iceren başarı hikayeleri."
>
  <section class="relative overflow-hidden bg-[var(--color-void-ink-deep)] py-32 lg:py-48">
    <div class="pointer-events-none absolute inset-0 opacity-20 mix-blend-overlay"></div>
    <div class="pointer-events-none absolute left-1/2 top-1/4 h-[800px] w-[800px] -translate-x-1/2 rounded-full bg-[var(--color-primary)]/10 blur-[150px] opacity-60"></div>
    <div class="container relative z-10 mx-auto max-w-4xl px-4 text-center">
      <h1 class="mb-6 text-4xl font-extrabold tracking-tight text-[#FFFFFF] drop-shadow-lg md:text-6xl">Başarı Hikayeleri</h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-[var(--color-text-muted)]">
        Yapay zeka otomasyonu ile büyüyen sirketlerden gerçek sonuçlar
      </p>
    </div>
  </section>

  <section class="relative z-10 pb-24">
    <div class="container mx-auto grid max-w-5xl gap-8 px-4 md:grid-cols-2 lg:grid-cols-3">
      {caseStudies.map((item) => (
        <a href={item.href} class="group neon-bleed-border relative block overflow-hidden rounded-sm bg-[var(--color-surface-light)]/40 p-8 backdrop-blur-sm transition-all duration-500 hover:bg-[var(--color-surface-light)]/60">
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
          <h2 class="relative z-10 mb-3 text-xl font-bold text-[var(--color-text)] transition-colors group-hover:text-[var(--color-primary)]">{item.title}</h2>
          <p class="relative z-10 mb-6 leading-relaxed text-[var(--color-text-muted)]">{item.description}</p>
          <span class="relative z-10 inline-flex items-center rounded-full border border-[var(--color-primary)]/20 bg-[var(--color-primary)]/10 px-3 py-1.5 text-xs font-semibold text-[var(--color-primary)]">
            {item.metric}
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="relative overflow-hidden py-24">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent via-[var(--color-primary)]/5 to-transparent"></div>
    <div class="container relative z-10 mx-auto max-w-4xl px-4">
      <div class="neon-bleed-border rounded-3xl bg-[var(--color-void-ink-deep)]/80 p-12 text-center shadow-2xl backdrop-blur-md lg:p-16">
        <h2 class="mb-6 text-3xl font-extrabold tracking-tight text-[var(--color-text)] md:text-4xl">Benzer bir sistemi kendi isletmenize uyarlayin</h2>
        <p class="mx-auto mb-10 max-w-2xl text-xl leading-relaxed text-[var(--color-text-muted)]">
          Vaka calismalarinda gordugunuz sonuclarin hangi süreç ve hangi otomasyon dugumu ile size uyarlanabilecegini birlikte cikaralim.
        </p>
        <a href={caseIndexContactHref} class="magnetic-glow-btn inline-flex items-center gap-2 rounded-sm bg-[var(--color-primary)] px-8 py-4 text-lg font-bold text-[var(--color-void-ink-deep)] transition-all duration-300 hover:bg-[var(--color-primary-dark)]">
          Ücretsiz analiz talep et
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
