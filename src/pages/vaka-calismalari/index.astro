---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildContactHref } from '../../lib/contactHref';

const caseStudies = [
  {
    href: '/vaka-calismalari/acilsatis/',
    title: 'Acilsatis',
    description: 'Hızlı bilinirlik ve daha istikrarli trafik.',
    metric: '+%45 görünürlük',
  },
  {
    href: '/vaka-calismalari/car-studio-ai/',
    title: 'Car Studio AI',
    description: 'Ekip buyutmeden yeni pazarlara acilma.',
    metric: '3x pazar genişlemesi',
  },
  {
    href: '/vaka-calismalari/salevium/',
    title: 'Salevium',
    description: 'Içerik üretimi saatlerden dakikalara indi.',
    metric: '%90 zaman tasarrufu',
  },
  {
    href: '/vaka-calismalari/erpa-teknoloji/',
    title: 'ERPA Teknoloji',
    description: 'Yapay zeka destekli stratejik Avrupa pazari girişi.',
    metric: 'Ilk ayda meetingler',
  },
  {
    href: '/vaka-calismalari/cemkimsan/',
    title: 'Cemkimsan',
    description: '20+ ulkede satış ve pazarlama kampanyalari.',
    metric: '6 yeni firsat',
  },
  {
    href: '/vaka-calismalari/dkm-coach-bilge/',
    title: 'DKM Coach Bilge',
    description: 'Oyun formatinda lead funnel ile yuzlerce ek lead.',
    metric: '+300 lead',
  },
];

const caseIndexContactHref = buildContactHref({
  source: '/vaka-calismalari/',
  packageName: 'lead-flow-audit',
  area: 'marketing-leads',
  cta: 'case-index-final-panel',
});
---

<BaseLayout
  title="Vaka Çalışmaları - Başarı Hikayeleri | Pratik Yapay Zeka"
  description="Yapay zeka otomasyonu ile büyüyen sirketlerden gerçek vaka çalışmaları. %90 zaman tasarrufu, +300 lead ve 3x pazar genişlemesi gibi somut sonuçlar iceren başarı hikayeleri."
>
  <section data-santral-reveal class="relative overflow-hidden pt-28 pb-16 md:pt-36">
    <div class="pointer-events-none absolute -top-32 right-[-10%] h-[460px] w-[560px] rounded-full opacity-[0.14] blur-[160px]" style="background: radial-gradient(circle, var(--color-patina-copper-bright) 0%, transparent 70%);" aria-hidden="true"></div>
    <div class="container relative z-10 mx-auto max-w-6xl px-6 lg:px-10">
      <div class="flex items-center gap-4 mb-10">
        <span class="h-[1px] w-10 bg-[var(--color-patina-copper-bright)]"></span>
        <span class="santral-overline">Kayıtlar · Arşiv — 6 Vaka</span>
      </div>
      <h1 class="santral-display text-4xl md:text-6xl leading-[1.05] max-w-4xl" style="font-weight:400;text-wrap:balance">
        Başarı <em class="santral-italic">Hikayeleri</em>
      </h1>
      <p class="mt-8 santral-body text-lg md:text-xl max-w-2xl">
        Yapay zeka otomasyonu ile büyüyen şirketlerden gerçek sonuçlar.
      </p>
    </div>
  </section>

  <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-16 md:py-24">
    <div class="container mx-auto max-w-6xl px-6 lg:px-10">
      <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {caseStudies.map((item, i) => (
          <a href={item.href} class="santral-hat group relative block overflow-hidden p-7 lg:p-8">
            <span class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-[var(--color-paper-ecru-mute)]">
              Kayıt · {String(i + 1).padStart(3, '0')}
            </span>
            <h2 class="mt-5 santral-display text-xl md:text-[1.35rem] transition-colors group-hover:text-[var(--color-patina-copper-bright)]" style="font-weight:500;letter-spacing:-0.01em">
              {item.title}
            </h2>
            <p class="mt-4 text-[0.9rem] leading-[1.55] text-[var(--color-paper-ecru-dim)]">{item.description}</p>
            <div class="mt-7 flex items-end justify-between border-t border-[var(--color-hairline)] pt-4">
              <div>
                <span class="santral-label block">Sonuç</span>
                <span class="mt-1 font-mono text-sm text-[var(--color-patina-copper-bright)]">{item.metric}</span>
              </div>
              <span class="font-mono text-[0.72rem] tracking-[0.14em] uppercase text-[var(--color-paper-ecru-dim)] transition-colors group-hover:text-[var(--color-patina-copper-bright)]">
                Detay →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section data-santral-reveal class="relative border-t border-[var(--color-hairline)] py-20 md:py-28">
    <div class="container mx-auto max-w-4xl px-6 lg:px-10 text-center">
      <div class="mb-8 flex items-center justify-center gap-4">
        <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
        <span class="santral-overline">Sonraki Adım</span>
        <span class="h-[1px] w-10 bg-[var(--color-hairline-strong)]"></span>
      </div>
      <h2 class="santral-display text-3xl md:text-5xl leading-[1.1]" style="font-weight:400;text-wrap:balance">
        Benzer bir sistemi <em class="santral-italic">kendi işletmenize</em> uyarlayın
      </h2>
      <p class="mt-6 santral-body max-w-2xl mx-auto">
        Vaka çalışmalarında gördüğünüz sonuçların hangi süreç ve hangi otomasyon düğümü ile size uyarlanabileceğini birlikte çıkaralım.
      </p>
      <div class="mt-8 flex justify-center">
        <a href={caseIndexContactHref} class="santral-salter santral-salter-copper">
          Ücretsiz analiz talep et
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
