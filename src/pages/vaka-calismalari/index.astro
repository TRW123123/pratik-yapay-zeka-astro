---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Vaka Çalışmaları – Başarı Hikayeleri | Pratik Yapay Zeka" description="Yapay zeka otomasyonu ile büyüyen şirketlerden gerçek vaka çalışmaları ve başarı hikayeleri.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-4">Başarı Hikayeleri</h1>
      <p class="text-lg text-[var(--color-text-muted)]">Yapay zeka otomasyonu ile büyüyen şirketlerden gerçek sonuçlar</p>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      <a href="/vaka-calismalari/acilsatis/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Acilsatis</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Hızlı bilinirlik, istikrarlı trafik.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">+%45 görünürlük</span>
      </a>
      <a href="/vaka-calismalari/car-studio-ai/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Car Studio AI</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Ekip büyütmeden yeni pazarlara açılma.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">3x pazar genişlemesi</span>
      </a>
      <a href="/vaka-calismalari/salevium/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Salevium</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">İçerik üretimi: saatlerden dakikalara.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">%90 zaman tasarrufu</span>
      </a>
      <a href="/vaka-calismalari/erpa-teknoloji/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">ERPA Teknoloji</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Yapay zeka destekli stratejik Avrupa pazarı girişi.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">İlk ayda meetingler</span>
      </a>
      <a href="/vaka-calismalari/cemkimsan/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Cemkimsan</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">20+ ülkede satış ve pazarlama kampanyaları.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">6 yeni fırsat</span>
      </a>
      <a href="/vaka-calismalari/dkm-coach-bilge/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">DKM Coach Bilge</h2>
        <p class="text-sm text-[var(--color-text-muted)] mb-3">Oyun formatında Lead Funnel ile yüzlerce ek Lead.</p>
        <span class="text-xs text-[var(--color-primary)] font-medium">+300 Lead</span>
      </a>
    </div>
  </section>
  <section class="py-20 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/5">
    <div class="container mx-auto px-4 text-center max-w-2xl">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">İşletmenizi Dönüştürmeye Hazır mısınız?</h2>
      <p class="text-[var(--color-text-muted)] mb-8">Yapay zeka ve otomasyon ile satış ve pazarlama süreçlerinizi optimize edin.</p>
      <a href="/cozumler/" class="bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-4 rounded-xl transition-all duration-300 text-lg">Ücretsiz Analiz Talep Et</a>
    </div>
  </section>
</BaseLayout>
