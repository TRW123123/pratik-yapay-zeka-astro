---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Yapay Zeka Otomasyonu – İşletmeler İçin Kapsamlı Çözümler" description="Yapay zeka ve otomasyon ile satış, pazarlama, müşteri hizmeti ve iş süreçlerinizi dönüştürün.">
  <section class="py-24">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <h1 class="text-3xl md:text-5xl font-bold mb-6">Yapay Zeka Otomasyonu</h1>
      <p class="text-lg text-[var(--color-text-muted)] mb-8 max-w-2xl mx-auto">İşletmenizin her alanında yapay zeka ile verimlilik artışı: satış, pazarlama, müşteri hizmeti ve iş süreçleri.</p>
      <a href="/cozumler/" class="bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-semibold px-8 py-3 rounded-xl transition-all duration-300">Tüm Çözümleri Keşfedin</a>
    </div>
  </section>
  <section class="pb-24">
    <div class="container mx-auto px-4 max-w-5xl grid md:grid-cols-2 gap-6">
      <a href="/cozumler/lead-generation/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Lead Üretimi</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Yapay zeka ile otomatik B2B lead kazanımı ve kişiselleştirilmiş iletişim.</p>
      </a>
      <a href="/cozumler/satis-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Satış Otomasyonu</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Outbound, CRM senkronizasyonu ve akıllı takip.</p>
      </a>
      <a href="/cozumler/pazarlama-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Pazarlama Otomasyonu</h2>
        <p class="text-sm text-[var(--color-text-muted)]">İçerik, sosyal medya ve reklam optimizasyonu.</p>
      </a>
      <a href="/cozumler/crm-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">CRM Otomasyonu</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Süreç optimizasyonu ve veri zenginleştirme.</p>
      </a>
      <a href="/cozumler/musteri-hizmeti-otomasyonu/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">Müşteri Hizmeti</h2>
        <p class="text-sm text-[var(--color-text-muted)]">7/24 chatbot ve voicebot desteği.</p>
      </a>
      <a href="/cozumler/almanya-ihracat/" class="bg-[var(--color-surface-light)] border border-[var(--color-border)] rounded-2xl p-6 hover:border-[var(--color-primary)]/30 transition-all duration-300 block">
        <h2 class="text-lg font-semibold mb-2">🇩🇪 Almanya'ya İhracat</h2>
        <p class="text-sm text-[var(--color-text-muted)]">Dijital altyapı ile Almanya pazarına giriş.</p>
      </a>
    </div>
  </section>
</BaseLayout>
