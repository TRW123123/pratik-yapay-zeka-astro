---
import CalculatorLayout from '../layouts/CalculatorLayout.astro';

const title = 'Yillik Izin Ucreti Hesaplama | Izin Bakiye ve Cikis Akisi';
const description = 'Yillik izin ucreti ihtiyaci cogu zaman tek hesap degil; izin bakiyesi, hak edis takibi, personel self-service ve cikis surecinin birlikte yonetilmesidir.';
const keywords = 'yillik izin ucreti hesaplama, izin bakiyesi, hak edis takibi, izin yonetimi, cikista izin ucreti';

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Bu sayfa izin bakiyesi hesap makinesi mi?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Hayir. Bu sayfa, izin bakiyesi ve kullanilmayan izin ucretinin neden IK sureci, personel self-service ve cikis operasyonuyla birlikte ele alinmasi gerektigini anlatir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Asil problem hangi noktada ortaya cikar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Asil problem genelde gun sayisini bilmekten cok, hak edis takibini, devreden izinleri ve cikista kullanilmayan izin etkisini duzenli izleyememektedir.',
      },
    },
    {
      '@type': 'Question',
      name: 'Kimler icin daha faydalidir?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Personel sorulari yogun olan, izin takibini hala daginik dosyalarda yapan ve cikis surecinde izin bakiyesiyle zorlanan IK ekipleri icin daha faydalidir.',
      },
    },
  ],
};
---

<CalculatorLayout
  title={title}
  description={description}
  keywords={keywords}
  schema={JSON.stringify(faqData)}
>
  <div class="space-y-12">
    <section>
      <div class="inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold border-primary text-primary mb-4">Izin ve Ozluk Surecleri</div>
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight mb-6">Yillik Izin Konusunu Bakiye Sorusu Olmaktan Cikarip Surec Haline Getirin</h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-4xl">
        Yillik izin ucreti ve izin bakiyesi aramalari cogu zaman sadece gun hesabiyla ilgili degildir. Gercek sorun, kimin ne kadar hak ettigi, ne kadar devreden izni oldugu ve cikis aninda bunun nasil ele alinacaginin daginik ilerlemesidir.
      </p>
    </section>

    <section class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Hak Edis</h2>
        <p class="text-muted-foreground">Personelin ne zaman hak kazandigi ve hangi baremde ilerledigi her zaman gorunur olmayabilir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Kullanim ve Bakiye</h2>
        <p class="text-muted-foreground">Kullanilan, devreden ve kalan izin bilgisi farkli yerlerde tutuluyorsa ekip zorlanir.</p>
      </div>
      <div class="rounded-2xl border border-border bg-card p-6">
        <h2 class="text-xl font-semibold mb-3">Cikis Etkisi</h2>
        <p class="text-muted-foreground">Personel ayrildiginda kullanilmayan izinlerin hesap ve tahakkuk tarafina yansimasi son dakika problemi olabilir.</p>
      </div>
    </section>

    <section class="bg-muted/30 p-8 rounded-2xl border border-border">
      <h2 class="text-2xl font-semibold mb-6">Yillik Izin Surecinin Dagildigi Tipik Noktalar</h2>
      <ul class="space-y-4">
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Personel sorularinda:</strong> Bakiye bilgisi self-service degilse IK tekrarlayan mesajlarla ugrasmaya baslar.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Uzun sureli ekiplerde:</strong> Devreden ve parcali kullanilan izinler izlenmesi zor yapiya donusur.</p>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1 h-2.5 w-2.5 rounded-full bg-primary"></span>
          <p><strong>Cikis dosyalarinda:</strong> Kullanilmayan izin bilgisi tahakkuk surecine gec ya da eksik yansiyabilir.</p>
        </li>
      </ul>
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Bu Sayfanin Isaret Ettigi Asil Sistem</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Yillik izin ucreti konusu bizim icin bir izin ve ozluk akisi problemidir. Deger, personelin bakiye sorularini azaltmakta, hak edis takibini gorunur kilmakta ve cikis aninda kullanilmayan izin etkisini duzenli yonetmekte ortaya cikar.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Hak Edis Takibi</h3>
          <p class="text-sm text-muted-foreground">Personelin izin yolculugu daha net ve izlenebilir olur.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Self-Service Bilgi</h3>
          <p class="text-sm text-muted-foreground">IK uzerindeki tekrar eden bakiye sorusu yuku azalir.</p>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <h3 class="text-xl font-semibold mb-2">Cikis Baglantisi</h3>
          <p class="text-sm text-muted-foreground">Kullanilmayan izin etkisi bordro ve tahakkuk akisina daha temiz yansir.</p>
        </div>
      </div>
    </section>

    <section class="max-w-3xl">
      <h2 class="text-2xl font-bold mb-6">Sikca Sorulan Sorular</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold mb-2">Bu sayfa izin bakiyesi hesap makinesi mi?</h3>
          <p class="text-muted-foreground">Hayir. Bu sayfa, izin bakiyesi ve kullanilmayan izin ucretinin neden IK sureci ve cikis operasyonuyla birlikte ele alinmasi gerektigini anlatir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Asil problem hangi noktada ortaya cikar?</h3>
          <p class="text-muted-foreground">Asil problem genelde gun sayisini bilmekten cok, hak edis, devreden bakiye ve cikis etkisini duzenli izleyememektedir.</p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-2">Kimler icin daha faydalidir?</h3>
          <p class="text-muted-foreground">Personel sorulari yogun olan ve izin takibini daginik dosyalarda yapan IK ekipleri icin daha faydalidir.</p>
        </div>
      </div>
    </section>
  </div>
</CalculatorLayout>
